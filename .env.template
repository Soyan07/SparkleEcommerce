# Render Environment Variables Template
# Copy these to Render Dashboard > Your Service > Environment

# Database Connection - Get this from Render PostgreSQL dashboard
ConnectionStrings__DefaultConnection=Host=your-db-host.internal;Database=your_db_name;Username=postgres;Password=your_password;Port=5432

# JWT Settings - Generate a secure random key
JWT__Key=YourSuperSecretKeyThatShouldBeAtLeast32CharactersLong!

# Application Settings
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
