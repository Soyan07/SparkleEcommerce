@model IEnumerable<Sparkle.Domain.System.ActivityLog>
@{
    ViewData["Title"] = "Activity Logs";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-list-check"></i>Activity Logs</h2>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate">
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Entity Type</label>
                    <select name="entityType" class="form-select">
                        <option value="">All Types</option>
                        <option value="Banners" selected="@(ViewBag.EntityType == "Banners")">Banners</option>
                        <option value="Products" selected="@(ViewBag.EntityType == "Products")">Products</option>
                        <option value="Orders" selected="@(ViewBag.EntityType == "Orders")">Orders</option>
                        <option value="Users" selected="@(ViewBag.EntityType == "Users")">Users</option>
                        <option value="Sellers" selected="@(ViewBag.EntityType == "Sellers")">Sellers</option>
                        <option value="Categories" selected="@(ViewBag.EntityType == "Categories")">Categories</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Action</label>
                    <input type="text" name="action" class="form-control" placeholder="e.g., POST, DELETE" value="@ViewBag.Action">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="card">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                    <p class="text-muted mt-3">No activity logs found.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Timestamp</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Entity</th>
                                <th>IP Address</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td>
                                        <small>@log.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss")</small>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.UserId))
                                        {
                                            <span class="badge bg-primary">@log.UserId.Substring(0, Math.Min(8, log.UserId.Length))</span>
                                        }
                                    </td>
                                    <td>
                                        <code>@log.Action</code>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.EntityType))
                                        {
                                            <span class="badge bg-info">@log.EntityType</span>
                                            if (!string.IsNullOrEmpty(log.EntityId))
                                            {
                                                <small class="text-muted">#@log.EntityId</small>
                                            }
                                        }
                                    </td>
                                    <td><small>@log.IpAddress</small></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.Details))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary" 
                                                    data-bs-toggle="modal" data-bs-target="#detailsModal"
                                                    onclick="showDetails(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(log.Details)))">
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                                    <a class="page-link" href="?page=@i&startDate=@ViewBag.StartDate&endDate=@ViewBag.EndDate&action=@ViewBag.Action&entityType=@ViewBag.EntityType">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }

                <div class="text-muted text-center mt-3">
                    Showing @Model.Count() of @ViewBag.TotalCount logs
                </div>
            }
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="detailsContent" style="background: #f8f9fa; padding: 15px; border-radius: 5px; max-height: 400px; overflow: auto;"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showDetails(details) {
            document.getElementById('detailsContent').textContent = details;
        }
    </script>
}
