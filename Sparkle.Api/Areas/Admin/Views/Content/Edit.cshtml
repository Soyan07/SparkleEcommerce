@model Sparkle.Domain.Content.StaticPage
@{
    ViewData["Title"] = "Edit Page";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit Page</h2>
        <p class="text-muted">Update page content and settings.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="content-card">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label fw-bold">Page Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Slug" class="form-label fw-bold">Slug</label>
                        <input asp-for="Slug" class="form-control" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-bold">Page Content</label>
                    <textarea asp-for="Content" class="form-control" rows="15"></textarea>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">SEO & Settings</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="MetaTitle" class="form-label fw-bold">Meta Title</label>
                        <input asp-for="MetaTitle" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MetaDescription" class="form-label fw-bold">Meta Description</label>
                        <input asp-for="MetaDescription" class="form-control" />
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                         <label asp-for="Location" class="form-label fw-bold">Menu Location</label>
                         <select asp-for="Location" class="form-select">
                             <option value="Footer">Footer Menu</option>
                             <option value="Header">Header Menu</option>
                             <option value="Sidebar">Sidebar / Help Center</option>
                             <option value="None">None (Direct Link Only)</option>
                         </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DisplayOrder" class="form-label fw-bold">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" />
                    </div>
                    <div class="col-md-4">
                         <label class="form-label fw-bold">&nbsp;</label>
                         <div class="form-check form-switch mt-2">
                             <input asp-for="IsPublished" class="form-check-input" type="checkbox" />
                             <label asp-for="IsPublished" class="form-check-label">Published</label>
                         </div>
                    </div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    
                    <button type="button" class="btn btn-outline-danger ms-auto" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        Delete Page
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Page</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong>@Model.Title</strong>? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
