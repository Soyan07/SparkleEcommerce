@model Sparkle.Domain.Content.StaticPage
@{
    ViewData["Title"] = "Create Page";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Create Page</h2>
        <p class="text-muted">Add a new static content page to the site.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="content-card">
            <form asp-action="Create" method="post">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label fw-bold">Page Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g., Return Policy" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Slug" class="form-label fw-bold">Slug (Optional)</label>
                        <input asp-for="Slug" class="form-control" placeholder="return-policy (auto-generated if empty)" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-bold">Page Content</label>
                    <textarea asp-for="Content" class="form-control" rows="15" placeholder="Enter HTML content here..."></textarea>
                    <div class="form-text">Basic HTML tags are supported.</div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">SEO & Settings</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="MetaTitle" class="form-label fw-bold">Meta Title</label>
                        <input asp-for="MetaTitle" class="form-control" placeholder="Title for search engines" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MetaDescription" class="form-label fw-bold">Meta Description</label>
                        <input asp-for="MetaDescription" class="form-control" placeholder="Description for search results" />
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                         <label asp-for="Location" class="form-label fw-bold">Menu Location</label>
                         <select asp-for="Location" class="form-select">
                             <option value="Footer">Footer Menu</option>
                             <option value="Header">Header Menu</option>
                             <option value="Sidebar">Sidebar / Help Center</option>
                             <option value="None">None (Direct Link Only)</option>
                         </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DisplayOrder" class="form-label fw-bold">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" value="0" />
                    </div>
                    <div class="col-md-4">
                         <label class="form-label fw-bold">&nbsp;</label>
                         <div class="form-check form-switch mt-2">
                             <input asp-for="IsPublished" class="form-check-input" type="checkbox" checked />
                             <label asp-for="IsPublished" class="form-check-label">Published</label>
                         </div>
                    </div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Create Page
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
