@model Sparkle.Domain.System.SupportTicket
@using Sparkle.Domain.System
@{
    ViewData["Title"] = $"Ticket #{Model.TicketNumber}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="btn btn-light border btn-icon">
             <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="content-title mb-0">Ticket #@Model.TicketNumber</h2>
            <div class="d-flex gap-2 mt-1">
                <span class="badge bg-light text-dark border">@Model.Status</span>
                <span class="badge bg-@(Model.Priority == "Urgent" ? "danger" : "info")">@Model.Priority</span>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2">
        <form asp-action="UpdateStatus" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            
            @if (Model.Status != "Closed")
            {
                 <button type="submit" name="status" value="Resolved" class="btn btn-success">
                     <i class="bi bi-check2 me-2"></i>Mark Resolved
                 </button>
                 <button type="submit" name="status" value="Closed" class="btn btn-outline-secondary">
                     Close
                 </button>
            }
            else
            {
                <button type="submit" name="status" value="Open" class="btn btn-outline-primary">
                     Re-open
                 </button>
            }
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card mb-4">
             <h5 class="fw-bold mb-3">@Model.Subject</h5>
             <p class="text-muted border-bottom pb-3">@Model.Description</p>
             
             <div class="ticket-thread mt-4">
                 @foreach(var reply in Model.Messages.OrderBy(r => r.SentAt))
                 {
                     <div class="d-flex mb-3 gap-3 @(reply.IsStaffReply ? "flex-row-reverse" : "")">
                         <div class="flex-shrink-0">
                             <div class="avatar avatar-sm rounded-circle bg-@(reply.IsStaffReply ? "primary" : "secondary") text-white d-flex align-items-center justify-content-center">
                                 @(reply.IsStaffReply ? "S" : "U")
                             </div>
                         </div>
                         <div class="card border-0 shadow-sm @(reply.IsStaffReply ? "bg-primary-subtle" : "bg-light")" style="max-width: 85%;">
                             <div class="card-body p-3">
                                 <div class="d-flex justify-content-between align-items-center mb-1 gap-3">
                                     <strong class="small">@(reply.IsStaffReply ? "Staff Support" : "User")</strong>
                                     <small class="text-muted" style="font-size: 0.75rem;">@reply.SentAt.ToString("MMM dd hh:mm tt")</small>
                                 </div>
                                 <p class="mb-0">@reply.Message</p>
                             </div>
                         </div>
                     </div>
                 }
             </div>
        </div>

        <div class="content-card">
            <h5 class="fw-bold mb-3">Reply</h5>
            <form asp-action="Reply" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="mb-3">
                    <textarea name="message" class="form-control" rows="4" placeholder="Internal note or reply to user..." required></textarea>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Reply will notify the user via email.</small>
                    <button type="submit" class="btn btn-primary px-4">Send Reply</button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="content-card">
            <h6 class="fw-bold mb-3">User Details</h6>
            <div class="mb-3">
                <label class="small text-muted">User ID</label>
                <div class="font-monospace user-select-all">@Model.UserId</div>
            </div>
            <!-- More user info could be fetched if we had User/Profile loaded -->
        </div>
    </div>
</div>
