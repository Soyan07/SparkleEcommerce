@model Sparkle.Domain.Catalog.Category
@{
    ViewData["Title"] = "Edit Category";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit Category</h2>
        <p class="text-muted">Update category details.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label control-label">Category Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Slug" class="form-label control-label">Slug</label>
                    <input asp-for="Slug" class="form-control" />
                    <div class="form-text">URL-friendly name. Changing this may affect existing links.</div>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Icon" class="form-label control-label">Icon Class</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-star"></i></span>
                            <input asp-for="Icon" class="form-control" />
                        </div>
                        <span asp-validation-for="Icon" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DisplayOrder" class="form-label control-label">Display Order</label>
                        <input asp-for="DisplayOrder" class="form-control" type="number" />
                        <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label control-label">Category Image</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" style="max-width: 200px; max-height: 200px; object-fit: cover;" />
                        </div>
                    }
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" id="imageUpload" />
                    <div class="form-text">Upload a new image to replace the current one. Recommended size: 400x400px</div>
                    <input type="hidden" asp-for="ImageUrl" />
                </div>

                <div class="d-flex justify-content-between mt-4 border-top pt-3">
                     <button type="button" class="btn btn-danger" onclick="confirmDelete()">
                        <i class="bi bi-trash me-2"></i> Delete
                    </button>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
             <form id="deleteForm" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:none;"></form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function confirmDelete() {
            if(confirm('Are you sure you want to delete this category?')) {
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}
