@model Sparkle.Domain.Catalog.Category
@{
    ViewData["Title"] = "Create Category";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Add Category</h2>
        <p class="text-muted">Create a new product category.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label control-label">Category Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Electronics" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Slug" class="form-label control-label">Slug (Optional)</label>
                    <input asp-for="Slug" class="form-control" placeholder="Auto-generated if left blank" />
                    <div class="form-text">URL-friendly version of the name.</div>
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Icon" class="form-label control-label">Icon Class (Bootstrap Icons)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-star"></i></span>
                            <input asp-for="Icon" class="form-control" placeholder="bi-cpu" />
                        </div>
                        <div class="form-text">Example: bi-phone, bi-laptop</div>
                        <span asp-validation-for="Icon" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DisplayOrder" class="form-label control-label">Display Order</label>
                        <input asp-for="DisplayOrder" class="form-control" type="number" />
                        <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label control-label">Category Image</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" id="imageUpload" />
                    <div class="form-text">Upload an image for this category. Recommended size: 400x400px</div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary px-4">Create Category</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
