@model Sparkle.Api.Areas.Admin.Controllers.ReportsController.UserReportViewModel
@{
    ViewData["Title"] = "User Activity Report";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">User Activity Report</h4>
        <p class="text-muted mb-0">User growth and engagement metrics</p>
    </div>
    <a href="/Admin/Reports" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-people fs-1 text-primary mb-2"></i>
                <h3 class="fw-bold">@Model.TotalUsers</h3>
                <p class="text-muted mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-check-circle fs-1 text-success mb-2"></i>
                <h3 class="fw-bold">@Model.ActiveUsers</h3>
                <p class="text-muted mb-0">Active Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-person-plus fs-1 text-info mb-2"></i>
                <h3 class="fw-bold">@Model.NewUsersThisMonth</h3>
                <p class="text-muted mb-0">New This Month</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="bi bi-graph-up fs-1 text-warning mb-2"></i>
                <h3 class="fw-bold">@((Model.TotalUsers > 0 ? (Model.NewUsersThisMonth * 100.0 / Model.TotalUsers) : 0).ToString("F1"))%</h3>
                <p class="text-muted mb-0">Growth Rate</p>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0">Users by Role</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Role</th>
                        <th>Count</th>
                        <th class="pe-4">Percentage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model.UsersByRole)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@role.RoleName</td>
                            <td>@role.Count</td>
                            <td class="pe-4">
                                <div class="d-flex align-items-center">
                                    <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                        <div class="progress-bar" style="width: @((Model.TotalUsers > 0 ? (role.Count * 100.0 / Model.TotalUsers) : 0))%"></div>
                                    </div>
                                    <span class="text-muted small">@((Model.TotalUsers > 0 ? (role.Count * 100.0 / Model.TotalUsers) : 0).ToString("F1"))%</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
