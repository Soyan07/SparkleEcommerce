@model IEnumerable<Sparkle.Domain.Support.Report>
@{
    ViewData["Title"] = "Reported Issues";
}

<div class="row mb-4 align-items-center">
    <div class="col-6">
        <h2 class="mb-0">Reports</h2>
    </div>
    <div class="col-6 text-end">
        <div class="btn-group me-2">
            <a asp-controller="QualityIssues" asp-action="Index" class="btn btn-warning text-dark fw-bold">
                <i class="bi bi-shield-exclamation me-1"></i> Quality Monitoring
            </a>
        </div>
        <div class="btn-group">
            <a asp-action="Issues" asp-route-status="Pending" class="btn btn-outline-primary @(ViewBag.Status == "Pending" ? "active" : "")">Pending</a>
            <a asp-action="Issues" asp-route-status="Resolved" class="btn btn-outline-success @(ViewBag.Status == "Resolved" ? "active" : "")">Resolved</a>
            <a asp-action="Issues" asp-route-status="Dismissed" class="btn btn-outline-secondary @(ViewBag.Status == "Dismissed" ? "active" : "")">Dismissed</a>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Date</th>
                        <th>Reporter</th>
                        <th>Target</th>
                        <th>Reason</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToString("MMM dd, hh:mm tt")</td>
                            <td>
                                @if(item.Reporter != null) {
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-circle sm bg-light text-primary fw-bold">
                                            @(item.Reporter?.FullName?.Substring(0,1) ?? "U")
                                        </div>
                                        <div>
                                            <div class="fw-bold">@item.Reporter?.FullName</div>
                                            <div class="text-muted small">@item.Reporter?.Email</div>
                                        </div>
                                    </div>
                                } else { <span class="text-muted">Unknown</span> }
                            </td>
                            <td>
                                <span class="badge bg-secondary mb-1">@item.TargetType</span>
                                <div>
                                    @if(item.TargetType == "Product" && item.ProductId.HasValue)
                                    {
                                        <a asp-area="Admin" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none fw-bold">@(item.Product?.Name ?? "Product Details")</a>
                                        <div class="small text-muted">Seller: @(item.Seller?.ShopName ?? "N/A")</div>
                                    }
                                    else if (item.TargetType == "Seller" && item.Seller != null)
                                    {
                                        <a href="/Shop/@item.SellerId" target="_blank" class="text-decoration-none fw-bold">@(item.Seller?.ShopName ?? "Seller Profile")</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">ID: @(item.ProductId ?? item.SellerId) (Deleted)</span>
                                    }
                                </div>
                            </td>
                            <td><span class="fw-bold text-danger">@item.Reason</span></td>
                            <td>
                                <div class="text-wrap" style="max-width: 300px;">
                                    @item.Description
                                </div>
                            </td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#resolveModal-@item.Id">
                                        Resolve
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#dismissModal-@item.Id">
                                        Dismiss
                                    </button>
                                }
                                else
                                {
                                    <span class="badge @(item.Status == "Resolved" ? "bg-success" : "bg-secondary")">@item.Status</span>
                                    @if(!string.IsNullOrEmpty(item.ResolutionNotes))
                                    {
                                        <div class="small text-muted mt-1">Note: @item.ResolutionNotes</div>
                                    }
                                }
                            </td>
                        </tr>

                        <!-- Resolve Modal -->
                        <div class="modal fade" id="resolveModal-@item.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-action="Resolve" method="post">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Resolve Report</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="resolution" value="Resolved" />
                                            <div class="mb-3">
                                                <label class="form-label">Resolution Notes</label>
                                                <textarea name="notes" class="form-control" rows="3" required placeholder="Action taken..."></textarea>
                                            </div>
                                            @if (item.TargetType == "Product" && item.ProductId.HasValue)
                                            {
                                                <div class="form-check mb-3">
                                                    <input class="form-check-input" type="checkbox" name="suspendProduct" id="suspendProduct-@item.Id" value="true">
                                                    <label class="form-check-label text-danger fw-bold" for="suspendProduct-@item.Id">
                                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                                        Suspend this product
                                                    </label>
                                                    <div class="form-text">
                                                        The product will be marked as suspended and removed from public listings.
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-success">Mark as Resolved</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Dismiss Modal -->
                        <div class="modal fade" id="dismissModal-@item.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-action="Resolve" method="post">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Dismiss Report</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="resolution" value="Dismissed" />
                                            <div class="mb-3">
                                                <label class="form-label">Reason for Dismissal</label>
                                                <textarea name="notes" class="form-control" rows="3" required placeholder="Why is this being dismissed?"></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-secondary">Dismiss Report</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    No @(ViewBag.Status?.ToLower() ?? "pending") reports found.
                </div>
            }
        </div>
    </div>
</div>
