@model IEnumerable<Sparkle.Api.Areas.Admin.Controllers.ReportsController.SellerPerformanceViewModel>
@{
    ViewData["Title"] = "Seller Performance Report";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Seller Performance Report</h4>
        <p class="text-muted mb-0">Analyze seller sales and performance metrics</p>
    </div>
    <a href="/Admin/Reports" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Rank</th>
                        <th>Seller</th>
                        <th>Products</th>
                        <th>Orders</th>
                        <th>Total Sales</th>
                        <th>Rating</th>
                        <th class="pe-4">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                        foreach (var seller in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (rank == 1)
                                    {
                                        <span class="badge bg-warning text-dark">🥇 #@rank</span>
                                    }
                                    else if (rank == 2)
                                    {
                                        <span class="badge bg-secondary">🥈 #@rank</span>
                                    }
                                    else if (rank == 3)
                                    {
                                        <span class="badge bg-danger text-white">🥉 #@rank</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">#@rank</span>
                                    }
                                </td>
                                <td class="fw-medium">@seller.SellerName</td>
                                <td>@seller.TotalProducts products</td>
                                <td>@seller.TotalOrders orders</td>
                                <td class="fw-bold text-success">৳@seller.TotalSales.ToString("N0")</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-star-fill text-warning me-1"></i>
                                        <span>@seller.Rating.ToString("F1")</span>
                                    </div>
                                </td>
                                <td class="pe-4">
                                    @{
                                        var badgeClass = seller.Status switch
                                        {
                                            "Approved" => "success",
                                            "Pending" => "warning",
                                            "Rejected" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@badgeClass">@seller.Status</span>
                                </td>
                            </tr>
                            rank++;
                        }
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No seller data available
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
