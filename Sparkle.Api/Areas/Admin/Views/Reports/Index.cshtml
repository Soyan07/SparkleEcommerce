@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="mb-4">
    <h4 class="mb-1 fw-bold" style="font-size: 24px; color: #111827;">Reports & Analytics</h4>
    <p class="text-muted mb-0" style="font-size: 14px;">Comprehensive business intelligence and data exports</p>
</div>

<div class="row g-3">
    <!-- Sales Reports -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
            <div class="card-body text-center p-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                     style="width: 60px; height: 60px; background: #d1fae5;">
                    <i class="bi bi-graph-up" style="font-size: 24px; color: #10b981;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="font-size: 16px; color: #111827;">Sales Reports</h5>
                <p class="text-muted mb-3" style="font-size: 13px;">Track revenue, orders, and sales trends over time</p>
                <a href="/Admin/Reports/Sales" class="btn btn-success btn-sm w-100" style="border-radius: 8px; font-weight: 600;">
                    <i class="bi bi-bar-chart me-1"></i> View Sales
                </a>
            </div>
        </div>
    </div>

    <!-- User Activity -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
            <div class="card-body text-center p-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                     style="width: 60px; height: 60px; background: #dbeafe;">
                    <i class="bi bi-people" style="font-size: 24px; color: #2563eb;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="font-size: 16px; color: #111827;">User Activity</h5>
                <p class="text-muted mb-3" style="font-size: 13px;">Monitor user growth, engagement, and demographics</p>
                <a href="/Admin/Reports/Users" class="btn btn-info btn-sm w-100" style="border-radius: 8px; font-weight: 600;">
                    <i class="bi bi-person-lines-fill me-1"></i> View Users
                </a>
            </div>
        </div>
    </div>

    <!-- Seller Performance -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 12px;">
            <div class="card-body text-center p-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                     style="width: 60px; height: 60px; background: #fef3c7;">
                    <i class="bi bi-shop" style="font-size: 24px; color: #f59e0b;"></i>
                </div>
                <h5 class="fw-bold mb-2" style="font-size: 16px; color: #111827;">Seller Performance</h5>
                <p class="text-muted mb-3" style="font-size: 13px;">Analyze seller sales, products, and ratings</p>
                <a href="/Admin/Reports/Sellers" class="btn btn-warning btn-sm w-100" style="border-radius: 8px; font-weight: 600;">
                    <i class="bi bi-trophy me-1"></i> View Sellers
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Export -->
<div class="card border-0 shadow-sm mt-4" style="border-radius: 12px;">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0 fw-bold" style="font-size: 16px; color: #111827;">Quick Export</h5>
    </div>
    <div class="card-body p-4">
        <form action="/Admin/Reports/Export" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label" style="font-size: 13px; font-weight: 600; color: #374151;">Report Type</label>
                <select name="type" class="form-select" style="border-radius: 8px;">
                    <option value="sales">Sales Report</option>
                    <option value="users">User Report</option>
                    <option value="sellers">Seller Report</option>
                    <option value="products">Product Report</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" style="font-size: 13px; font-weight: 600; color: #374151;">From Date</label>
                <input type="date" name="from" class="form-control" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")" style="border-radius: 8px;">
            </div>
            <div class="col-md-3">
                <label class="form-label" style="font-size: 13px; font-weight: 600; color: #374151;">To Date</label>
                <input type="date" name="to" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" style="border-radius: 8px;">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100" style="border-radius: 8px; font-weight: 600;">
                    <i class="bi bi-download me-1"></i> Export CSV
                </button>
            </div>
        </form>
    </div>
</div>
