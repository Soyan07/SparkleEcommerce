@{
    ViewData["Title"] = "Send Notification";
}

<div class="mb-4">
    <h4 class="mb-1 fw-bold">Send Notification</h4>
    <p class="text-muted mb-0">Broadcast messages to users, sellers, or specific groups</p>
</div>

<div class="row">
    <div class="col-md-8">
        <form method="post" class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-medium">Target Audience</label>
                    <select name="Target" class="form-select">
                        <option value="all">All Users & Sellers</option>
                        <option value="users">Customers Only</option>
                        <option value="sellers">Sellers Only</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Title</label>
                    <input type="text" name="Title" class="form-control" placeholder="e.g., Flash Sale Alert!" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Message</label>
                    <textarea name="Message" class="form-control" rows="5" placeholder="Type your notification message here..." required></textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">Delivery Methods</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="SendInApp" id="inApp" checked>
                        <label class="form-check-label" for="inApp">
                            In-App Notification
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="SendEmail" id="email">
                        <label class="form-check-label" for="email">
                            Email Notification
                        </label>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send"></i> Send Notification
                    </button>
                    <a href="/Admin/Dashboard" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-light">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="bi bi-lightbulb"></i> Tips</h6>
                <ul class="small mb-0 ps-3">
                    <li class="mb-2">Keep messages concise and actionable</li>
                    <li class="mb-2">Use clear subject lines</li>
                    <li class="mb-2">Avoid excessive notifications</li>
                    <li>Test with small groups first</li>
                </ul>
            </div>
        </div>
    </div>
</div>
