@model IEnumerable<Sparkle.Api.Areas.Admin.Controllers.PaymentsController.SellerCommissionViewModel>
@{
    ViewData["Title"] = "Commission Tracking";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">Commission Tracking</h4>
        <p class="text-muted mb-0">Platform earnings from seller transactions (15% commission)</p>
    </div>
    <a href="/Admin/Payments" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Payments
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Seller</th>
                        <th>Total Sales</th>
                        <th>Orders</th>
                        <th>Commission (15%)</th>
                        <th>Seller Payout (85%)</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var seller in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-medium">@seller.SellerName</span>
                            </td>
                            <td class="fw-bold">৳@seller.TotalSales.ToString("N0")</td>
                            <td>
                                <span class="badge bg-primary">@seller.OrderCount orders</span>
                            </td>
                            <td class="text-success fw-bold">৳@seller.Commission.ToString("N0")</td>
                            <td class="text-warning">৳@seller.PayoutAmount.ToString("N0")</td>
                            <td class="text-end pe-4">
                                <a href="/Admin/Sellers/Details/@seller.SellerId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View Seller
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No commission data available yet
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
