@model Sparkle.Domain.Marketing.FlashDeal
@{
    ViewData["Title"] = "Create Flash Sale";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Create Flash Sale</h2>
        <p class="text-muted">Set up a new limited-time deal event.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="content-card">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row g-3 mb-4">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label fw-bold">Deal Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Midnight Madness" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BadgeText" class="form-label fw-bold">Badge Text</label>
                        <input asp-for="BadgeText" class="form-control" placeholder="e.g., 50% OFF" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the event..."></textarea>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Schedule</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="StartTime" class="form-label fw-bold">Start Time <span class="text-danger">*</span></label>
                        <input asp-for="StartTime" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndTime" class="form-label fw-bold">End Time <span class="text-danger">*</span></label>
                        <input asp-for="EndTime" type="datetime-local" class="form-control" required />
                        <span asp-validation-for="EndTime" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Display Settings</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="DisplayOrder" class="form-label fw-bold">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" value="0" />
                    </div>
                    <div class="col-md-6">
                         <div class="form-label fw-bold mb-2">Visibility</div>
                         <div class="form-check form-switch mb-2">
                             <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                             <label asp-for="IsActive" class="form-check-label">Active</label>
                         </div>
                         <div class="form-check form-switch">
                             <input asp-for="ShowOnHomepage" class="form-check-input" type="checkbox" checked />
                             <label asp-for="ShowOnHomepage" class="form-check-label">Show on Homepage</label>
                         </div>
                    </div>
                </div>
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Banner Image</label>
                    <input type="file" name="bannerImage" class="form-control" accept="image/*" />
                    <div class="form-text">Optional banner for the deal page.</div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Create Flash Sale
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
