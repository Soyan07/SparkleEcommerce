@model Sparkle.Domain.Support.Chat
@{
    ViewData["Title"] = "Chat Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .chat-detail-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }
    .chat-detail-header {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 1.5rem;
    }
    .participant-info {
        display: flex;
        align-items: center;
        gap: 2rem;
    }
    .participant {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .participant-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 1.25rem;
    }
    .chat-arrow {
        font-size: 1.5rem;
        opacity: 0.7;
    }
    .messages-container {
        max-height: 600px;
        overflow-y: auto;
        padding: 1.5rem;
        background: #f8fafc;
    }
    .message {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .message.from-user {
        flex-direction: row;
    }
    .message.from-seller {
        flex-direction: row-reverse;
    }
    .message-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
        flex-shrink: 0;
    }
    .message.from-user .message-avatar {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
    }
    .message.from-seller .message-avatar {
        background: linear-gradient(135deg, #10b981, #059669);
    }
    .message-content {
        max-width: 70%;
    }
    .message-bubble {
        padding: 0.75rem 1rem;
        border-radius: 16px;
        font-size: 0.95rem;
    }
    .message.from-user .message-bubble {
        background: white;
        border-bottom-left-radius: 4px;
    }
    .message.from-seller .message-bubble {
        background: #dcfce7;
        border-bottom-right-radius: 4px;
    }
    .message-meta {
        font-size: 0.75rem;
        color: #94a3b8;
        margin-top: 0.25rem;
    }
    .message.from-seller .message-meta {
        text-align: right;
    }
    .chat-detail-footer {
        padding: 1rem 1.5rem;
        background: white;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .date-separator {
        text-align: center;
        margin: 1rem 0;
    }
    .date-separator span {
        background: #e2e8f0;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.75rem;
        color: #64748b;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Chat Logs
    </a>
    <div class="d-flex gap-2">
        @if (Model.Status == "Active")
        {
            <form asp-action="Close" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-x-circle me-1"></i>Close Chat
                </button>
            </form>
        }
        <form asp-action="Delete" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this chat permanently?')">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        </form>
    </div>
</div>

<div class="chat-detail-card">
    <div class="chat-detail-header">
        <div class="participant-info">
            <div class="participant">
                <div class="participant-avatar">
                    @(Model.User?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                </div>
                <div>
                    <div style="font-weight: 600;">@(Model.User?.FullName ?? "Unknown User")</div>
                    <div style="font-size: 0.85rem; opacity: 0.8;">@(Model.User?.Email ?? "")</div>
                </div>
            </div>
            <i class="bi bi-arrow-right chat-arrow"></i>
            <div class="participant">
                <div class="participant-avatar">
                    @(Model.Seller?.ShopName?.Substring(0, 1).ToUpper() ?? "S")
                </div>
                <div>
                    <div style="font-weight: 600;">@(Model.Seller?.ShopName ?? "Unknown Seller")</div>
                    <div style="font-size: 0.85rem; opacity: 0.8;">Seller</div>
                </div>
            </div>
        </div>
        
        @if (Model.Product != null)
        {
            <div class="mt-3 p-2 rounded" style="background: rgba(255,255,255,0.1);">
                <small><i class="bi bi-box me-1"></i>Product: @Model.Product.Title</small>
            </div>
        }
    </div>
    
    <div class="messages-container">
        @{
            DateTime? lastDate = null;
        }
        @foreach (var msg in Model.Messages)
        {
            var msgDate = msg.SentAt.Date;
            if (lastDate != msgDate)
            {
                <div class="date-separator">
                    <span>@msgDate.ToString("MMMM d, yyyy")</span>
                </div>
                lastDate = msgDate;
            }
            
            <div class="message @(msg.IsSeller ? "from-seller" : "from-user")">
                <div class="message-avatar">
                    @if (msg.IsSeller)
                    {
                        @(Model.Seller?.ShopName?.Substring(0, 1).ToUpper() ?? "S")
                    }
                    else
                    {
                        @(Model.User?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                    }
                </div>
                <div class="message-content">
                    <div class="message-bubble">
                        @msg.Content
                    </div>
                    <div class="message-meta">
                        @msg.SentAt.ToString("h:mm tt")
                        @if (msg.IsRead)
                        {
                            <i class="bi bi-check2-all text-primary ms-1"></i>
                        }
                    </div>
                </div>
            </div>
        }
        
        @if (!Model.Messages.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-chat-square" style="font-size: 3rem;"></i>
                <p class="mt-2">No messages in this conversation</p>
            </div>
        }
    </div>
    
    <div class="chat-detail-footer">
        <div>
            <span class="badge bg-light text-dark me-2">
                <i class="bi bi-chat-dots me-1"></i>@Model.Messages.Count messages
            </span>
            <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">
                @Model.Status
            </span>
        </div>
        <div class="text-muted" style="font-size: 0.85rem;">
            Started @Model.StartedAt.ToString("MMM d, yyyy h:mm tt")
        </div>
    </div>
</div>
