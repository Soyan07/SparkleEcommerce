@model Sparkle.Domain.Marketing.Campaign
@{
    ViewData["Title"] = "Edit Campaign";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit Campaign</h2>
        <p class="text-muted">Manage campaign details, products, and categories.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <!-- Campaign Details -->
        <div class="content-card mb-4">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Campaign Settings</h5>
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label fw-bold">Name</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                         <label asp-for="CampaignType" class="form-label fw-bold">Type</label>
                         <select asp-for="CampaignType" class="form-select">
                            <option value="SeasonalSale">Seasonal Sale</option>
                            <option value="BrandDay">Brand Day</option>
                            <option value="CategorySale">Category Sale</option>
                            <option value="MegaSale">Mega Sale</option>
                            <option value="Custom">Custom</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold">End Date</label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" required />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="BackgroundColor" class="form-label fw-bold">Background</label>
                        <input asp-for="BackgroundColor" type="color" class="form-control form-control-color w-100" title="Choose background color">
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TextColor" class="form-label fw-bold">Text Color</label>
                        <input asp-for="TextColor" type="color" class="form-control form-control-color w-100" title="Choose text color">
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DisplayOrder" class="form-label fw-bold">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <div class="row">
                        <div class="col-md-6">
                             <div class="form-check form-switch">
                                 <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                 <label asp-for="IsActive" class="form-check-label">Active</label>
                             </div>
                        </div>
                        <div class="col-md-6">
                             <div class="form-check form-switch">
                                 <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                                 <label asp-for="IsFeatured" class="form-check-label">Featured on Homepage</label>
                             </div>
                        </div>
                    </div>
                </div>
                
                <div class="text-end border-top pt-3">
                    <button type="submit" class="btn btn-outline-primary px-4">
                        Save Settings
                    </button>
                </div>
            </form>
        </div>

        <!-- Campaign Products -->
        <div class="content-card mb-4">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Included Products (@Model.Products.Count)</h5>
            
            <form asp-action="AddProduct" method="post" class="card card-body bg-light border-0 mb-3">
                <input type="hidden" name="campaignId" value="@Model.Id" />
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Product ID</label>
                        <input type="number" name="productId" class="form-control form-control-sm" placeholder="ID" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Promo Price (৳)</label>
                        <input type="number" name="specialPrice" class="form-control form-control-sm" step="0.01" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Order</label>
                        <input type="number" name="displayOrder" class="form-control form-control-sm" value="0" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Add</button>
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-3">Product</th>
                            <th>Promo Price</th>
                            <th>Order</th>
                            <th class="text-end pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Products.OrderBy(p => p.DisplayOrder))
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold text-truncate" style="max-width: 200px;">
                                        @(item.Product?.Name ?? $"Product #{item.ProductId}")
                                    </div>
                                </td>
                                <td>
                                    @if(item.SpecialPrice.HasValue)
                                    {
                                        <span class="text-danger fw-bold">৳@item.SpecialPrice.Value.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Default</span>
                                    }
                                </td>
                                <td>@item.DisplayOrder</td>
                                <td class="text-end pe-3">
                                    <form asp-action="RemoveProduct" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Remove product?');">
                                            <i class="bi bi-x-circle fs-5"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if(!Model.Products.Any())
            {
               <div class="text-center py-3 text-muted small">No products added.</div>
            }
        </div>
        
        <!-- Campaign Categories -->
        <div class="content-card">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Included Categories (@Model.Categories.Count)</h5>
            
            <form asp-action="AddCategory" method="post" class="card card-body bg-light border-0 mb-3">
                <input type="hidden" name="campaignId" value="@Model.Id" />
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold">Category ID</label>
                        <input type="number" name="categoryId" class="form-control form-control-sm" placeholder="ID" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Discount %</label>
                        <input type="number" name="discountPercentage" class="form-control form-control-sm" step="0.1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Order</label>
                        <input type="number" name="displayOrder" class="form-control form-control-sm" value="0" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">Add</button>
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-3">Category</th>
                            <th>Discount</th>
                            <th>Order</th>
                            <th class="text-end pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Categories.OrderBy(p => p.DisplayOrder))
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold">
                                        @(item.Category?.Name ?? $"Category #{item.CategoryId}")
                                    </div>
                                </td>
                                <td>
                                    @if(item.DiscountPercentage.HasValue)
                                    {
                                        <span class="badge bg-success">@item.DiscountPercentage.Value.ToString("0")% OFF</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">None</span>
                                    }
                                </td>
                                <td>@item.DisplayOrder</td>
                                <td class="text-end pe-3">
                                    <form asp-action="RemoveCategory" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" onclick="return confirm('Remove category?');">
                                            <i class="bi bi-x-circle fs-5"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
             @if(!Model.Categories.Any())
            {
               <div class="text-center py-3 text-muted small">No categories added.</div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Quick Actions -->
        <div class="content-card mb-4">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Actions</h5>
            <div class="d-grid gap-2">
                <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn @(Model.IsActive ? "btn-warning" : "btn-success") w-100">
                        <i class="bi @(Model.IsActive ? "bi-pause-circle" : "bi-play-circle") me-2"></i>
                        @(Model.IsActive ? "Deactivate" : "Activate")
                    </button>
                </form>
                
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this campaign?');">
                    <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-trash me-2"></i>Delete Campaign
                    </button>
                </form>
            </div>
        </div>

        <!-- Info Card -->
        <div class="content-card bg-light">
             <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>About Campaigns</h5>
             <p class="small text-muted mb-2">
                 Campaigns group products and categories under a unified theme (e.g., "Summer Sale").
             </p>
             <p class="small text-muted mb-2">
                 <strong>Special Price:</strong> Overrides the product's base price for this campaign.
             </p>
             <p class="small text-muted mb-0">
                 <strong>Category Discount:</strong> Applies a percentage off to all items in that category (logic requires implementing price calculation service).
             </p>
        </div>
    </div>
</div>
