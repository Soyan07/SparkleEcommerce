@{
    ViewData["Title"] = "Delivery Tracking";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header mb-4">
    <div class="d-flex align-items-center">
        <i class="bi bi-send fs-3 me-3 text-primary"></i>
        <div>
            <h2 class="content-title mb-0">Delivery Tracking</h2>
            <p class="text-muted mb-0">Monitor package deliveries to customers</p>
        </div>
    </div>
</div>

<div class="content-card border-0 shadow-lg overflow-hidden position-relative" style="background: #fff; min-height: 500px; border-radius: 30px;">
    <!-- Abstract Background Pattern -->
    <div class="position-absolute top-0 end-0 opacity-10" style="width: 300px; height: 300px; background: radial-gradient(circle, #f59e0b 0%, transparent 70%); margin-right: -100px; margin-top: -100px;"></div>
    
    <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-center position-relative" style="z-index: 2;">
        <div class="mb-5 position-relative">
            <div class="pulse-container" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 140px; height: 140px; background: rgba(245, 158, 11, 0.1); border-radius: 50%; animation: pulse 2s infinite;"></div>
            <i class="bi bi-cone-striped text-warning display-1" style="font-size: 6rem; filter: drop-shadow(0 10px 15px rgba(245, 158, 11, 0.3));"></i>
        </div>
        
        <h2 class="fw-800 text-dark mb-3" style="letter-spacing: -0.5px;">Feature Under Development</h2>
        <p class="text-muted mb-4 fs-5" style="max-width: 600px; line-height: 1.6;">
            We're meticulously crafting the <strong>Delivery Tracking</strong> experience. 
            Our engineers are currently working on this module to ensure it meets our premium standards for Sparkle Marketplace.
        </p>
        
        <div class="d-flex gap-3 mt-2">
            <div class="badge bg-light text-dark border px-4 py-3 rounded-pill d-flex align-items-center gap-2" style="font-weight: 600;">
                <span class="spinner-grow spinner-grow-sm text-warning" role="status"></span>
                In Progress
            </div>
            <div class="badge bg-primary-subtle text-primary border border-primary-subtle px-4 py-3 rounded-pill d-flex align-items-center gap-2" style="font-weight: 600;">
                <i class="bi bi-rocket-takeoff"></i> Launching Soon
            </div>
        </div>
        
        <div class="mt-5 pt-4">
            <a href="/Admin/Logistics" class="btn btn-dark px-5 py-3 rounded-pill fw-bold shadow-sm transition-all hover-transform">
                <i class="bi bi-arrow-left me-2"></i> Back to Logistics
            </a>
        </div>
    </div>
</div>

<style>
    @@keyframes pulse {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        100% { transform: translate(-50%, -50%) scale(1.4); opacity: 0; }
    }
    .hover-transform:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>
