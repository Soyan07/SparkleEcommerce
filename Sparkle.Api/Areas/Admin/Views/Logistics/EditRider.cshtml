@using Sparkle.Domain.Logistics
@model Rider
@{
    ViewData["Title"] = "Edit Rider";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var hubs = ViewBag.Hubs as List<Hub> ?? new List<Hub>();
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit Rider</h2>
        <p class="text-muted">Update @Model.Name</p>
    </div>
    <a asp-action="RiderDetails" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back
    </a>
</div>

<div class="content-card">
    <form asp-action="EditRider" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id">
        
        <div class="row">
            <div class="col-lg-8">
                <h6 class="fw-bold mb-3 text-success"><i class="bi bi-person me-2"></i>Personal Information</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Rider Code <span class="text-danger">*</span></label>
                        <input asp-for="RiderCode" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone <span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">NID Number</label>
                        <input asp-for="NidNumber" class="form-control">
                    </div>
                </div>
                
                <h6 class="fw-bold mb-3 text-success"><i class="bi bi-truck me-2"></i>Vehicle Information</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Vehicle Type</label>
                        <select asp-for="VehicleType" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Bicycle">Bicycle</option>
                            <option value="Motorcycle">Motorcycle</option>
                            <option value="Van">Van</option>
                            <option value="Pickup Truck">Pickup Truck</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Vehicle Number</label>
                        <input asp-for="VehicleNumber" class="form-control">
                    </div>
                </div>
                
                <h6 class="fw-bold mb-3 text-success"><i class="bi bi-building me-2"></i>Assignment</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">Assigned Hub</label>
                        <select asp-for="AssignedHubId" class="form-select">
                            <option value="">-- No Hub --</option>
                            @foreach (var hub in hubs)
                            {
                                <option value="@hub.Id" selected="@(Model.AssignedHubId == hub.Id)">@hub.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Rider Type</label>
                        <select asp-for="Type" class="form-select">
                            <option value="@RiderType.Both">Both</option>
                            <option value="@RiderType.Pickup">Pickup Only</option>
                            <option value="@RiderType.Delivery">Delivery Only</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="@RiderStatus.Active">Active</option>
                            <option value="@RiderStatus.Inactive">Inactive</option>
                            <option value="@RiderStatus.OnBreak">On Break</option>
                            <option value="@RiderStatus.OnDelivery">On Delivery</option>
                        </select>
                    </div>
                </div>
                
                <hr class="my-4">
                
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="RiderDetails" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-2"></i>Save Changes
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
