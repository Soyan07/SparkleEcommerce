@model IEnumerable<Sparkle.Domain.Support.Dispute>
@{
    ViewData["Title"] = "Disputes";
    var currentStatus = ViewBag.CurrentStatus as string ?? "All";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Disputes & Complaints</h2>
        <p class="text-muted">Manage customer disputes requiring admin intervention.</p>
    </div>
</div>

<div class="content-card">
    <div class="d-flex justify-content-between mb-4">
        <ul class="nav nav-pills">
            <li class="nav-item">
                <a class="nav-link @(currentStatus == "All" ? "active" : "")" asp-action="Index" asp-route-status="All">All</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentStatus == "Opened" ? "active" : "")" asp-action="Index" asp-route-status="Opened">Opened</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentStatus == "UnderInvestigation" ? "active" : "")" asp-action="Index" asp-route-status="UnderInvestigation">Investigation</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentStatus == "Resolved" ? "active" : "")" asp-action="Index" asp-route-status="Resolved">Resolved</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentStatus == "Rejected" ? "active" : "")" asp-action="Index" asp-route-status="Rejected">Rejected</a>
            </li>
        </ul>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Dispute ID</th>
                    <th>Order & Item</th>
                    <th>Customer</th>
                    <th>Reason</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Opened</th>
                    <th class="text-end pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">#@item.DisputeNumber</td>
                        <td>
                            <div>Order #@item.Order?.OrderNumber</div> 
                            <!-- Assuming OrderItem loaded if needed, logic for null included -->
                        </td>
                        <td>
                            <div class="fw-bold">@item.User?.FullName</div>
                            <div class="small text-muted">@item.User?.Email</div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@item.Type</span>
                        </td>
                        <td>
                            ৳@((item.Order?.Total ?? 0).ToString("N0")) <!-- Just showing order total for context -->
                        </td>
                        <td>
                            @switch (item.Status)
                            {
                                case Sparkle.Domain.Support.DisputeStatus.Opened:
                                    <span class="badge bg-danger">Open</span>
                                    break;
                                case Sparkle.Domain.Support.DisputeStatus.Resolved:
                                    <span class="badge bg-success">Resolved</span>
                                    break;
                                case Sparkle.Domain.Support.DisputeStatus.Rejected:
                                    <span class="badge bg-secondary">Rejected</span>
                                    break;
                                default:
                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                    break;
                            }
                        </td>
                        <td>@item.OpenedAt.ToString("MMM dd")</td>
                        <td class="text-end pe-4">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="text-muted mb-3"><i class="bi bi-shield-check fs-1"></i></div>
            <p class="text-muted">No disputes found for this status.</p>
        </div>
    }
</div>
