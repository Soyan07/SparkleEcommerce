@model Sparkle.Domain.Marketing.Coupon
@{
    ViewData["Title"] = "Create Coupon";
    var categories = ViewBag.Categories as List<Sparkle.Domain.Catalog.Category> ?? new List<Sparkle.Domain.Catalog.Category>();
    var sellers = ViewBag.Sellers as List<Sparkle.Domain.Sellers.Seller> ?? new List<Sparkle.Domain.Sellers.Seller>();
}

<div class="content-header">
    <div>
        <h2 class="content-title">Create Coupon</h2>
        <p class="text-muted">Create a new discount coupon for customers.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to Coupons
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="content-card">
            <form asp-action="Create" method="post">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Code" class="form-label fw-bold">Coupon Code <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control font-monospace text-uppercase" required />
                        <span asp-validation-for="Code" class="text-danger"></span>
                        <div class="form-text">Customers will enter this code at checkout</div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Display Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Eid Sale 20% Off" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional description for internal use..."></textarea>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Discount Settings</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="DiscountType" class="form-label fw-bold">Discount Type</label>
                        <select asp-for="DiscountType" class="form-select">
                            <option value="Percentage">Percentage (%)</option>
                            <option value="FixedAmount">Fixed Amount (৳)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DiscountValue" class="form-label fw-bold">Value <span class="text-danger">*</span></label>
                        <input asp-for="DiscountValue" type="number" step="0.01" min="0" class="form-control" required />
                        <span asp-validation-for="DiscountValue" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="MaxDiscountAmount" class="form-label fw-bold">Max Discount (৳)</label>
                        <input asp-for="MaxDiscountAmount" type="number" step="0.01" min="0" class="form-control" />
                        <div class="form-text">Cap for percentage discounts</div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="MinimumPurchaseAmount" class="form-label fw-bold">Minimum Purchase (৳)</label>
                    <input asp-for="MinimumPurchaseAmount" type="number" step="0.01" min="0" class="form-control" style="max-width: 200px;" />
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Validity Period</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold">Start Date <span class="text-danger">*</span></label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold">End Date <span class="text-danger">*</span></label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" required />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Usage Limits</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="MaxUsageTotal" class="form-label fw-bold">Total Usage Limit</label>
                        <input asp-for="MaxUsageTotal" type="number" min="1" class="form-control" placeholder="Leave empty for unlimited" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaxUsagePerUser" class="form-label fw-bold">Per User Limit</label>
                        <input asp-for="MaxUsagePerUser" type="number" min="1" class="form-control" placeholder="Leave empty for unlimited" />
                    </div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Visibility</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">Active (customers can use)</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsPublic" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsPublic" class="form-check-label">Public (shown in promotions)</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Create Coupon
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="content-card bg-light">
            <h5 class="fw-bold mb-3"><i class="bi bi-lightbulb me-2"></i>Tips</h5>
            <ul class="text-muted small ps-3">
                <li class="mb-2">Use memorable codes like <code>EID2026</code> or <code>SUMMER20</code></li>
                <li class="mb-2">Set a max discount cap for percentage discounts to protect margins</li>
                <li class="mb-2">Per-user limits prevent abuse by same customer</li>
                <li class="mb-2">Schedule future coupons by setting a future start date</li>
            </ul>
        </div>
    </div>
</div>
