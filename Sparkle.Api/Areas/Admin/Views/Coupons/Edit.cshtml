@model Sparkle.Domain.Marketing.Coupon
@{
    ViewData["Title"] = "Edit Coupon";
    var categories = ViewBag.Categories as List<Sparkle.Domain.Catalog.Category> ?? new List<Sparkle.Domain.Catalog.Category>();
    var sellers = ViewBag.Sellers as List<Sparkle.Domain.Sellers.Seller> ?? new List<Sparkle.Domain.Sellers.Seller>();
    var usageCount = ViewBag.UsageCount as int? ?? 0;
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit Coupon</h2>
        <p class="text-muted">Update coupon "<strong>@Model.Code</strong>"</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to Coupons
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="content-card">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CurrentUsageCount" />
                
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Code" class="form-label fw-bold">Coupon Code <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control font-monospace text-uppercase" required />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Display Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Discount Settings</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="DiscountType" class="form-label fw-bold">Discount Type</label>
                        <select asp-for="DiscountType" class="form-select">
                            <option value="Percentage">Percentage (%)</option>
                            <option value="FixedAmount">Fixed Amount (৳)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DiscountValue" class="form-label fw-bold">Value <span class="text-danger">*</span></label>
                        <input asp-for="DiscountValue" type="number" step="0.01" min="0" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="MaxDiscountAmount" class="form-label fw-bold">Max Discount (৳)</label>
                        <input asp-for="MaxDiscountAmount" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="MinimumPurchaseAmount" class="form-label fw-bold">Minimum Purchase (৳)</label>
                    <input asp-for="MinimumPurchaseAmount" type="number" step="0.01" min="0" class="form-control" style="max-width: 200px;" />
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Validity Period</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold">End Date</label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Usage Limits</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="MaxUsageTotal" class="form-label fw-bold">Total Usage Limit</label>
                        <input asp-for="MaxUsageTotal" type="number" min="1" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaxUsagePerUser" class="form-label fw-bold">Per User Limit</label>
                        <input asp-for="MaxUsagePerUser" type="number" min="1" class="form-control" />
                    </div>
                </div>

                <h5 class="fw-bold border-bottom pb-2 mb-3">Visibility</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsPublic" class="form-check-input" type="checkbox" />
                            <label asp-for="IsPublic" class="form-check-label">Public</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Stats Card -->
        <div class="content-card mb-4">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Usage Statistics</h5>
            <div class="bg-light p-3 rounded mb-3">
                <div class="h4 mb-0 text-primary">@usageCount</div>
                <div class="small text-muted">Times Used</div>
            </div>
            <a asp-action="Usage" asp-route-id="@Model.Id" class="btn btn-outline-info w-100">
                <i class="bi bi-clock-history me-2"></i>View Usage History
            </a>
        </div>

        <!-- Quick Actions -->
        <div class="content-card">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Quick Actions</h5>
            <div class="d-grid gap-2">
                <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn @(Model.IsActive ? "btn-warning" : "btn-success") w-100">
                        <i class="bi @(Model.IsActive ? "bi-pause-circle" : "bi-play-circle") me-2"></i>
                        @(Model.IsActive ? "Disable Coupon" : "Enable Coupon")
                    </button>
                </form>
                
                @if (usageCount == 0)
                {
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this coupon?');">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash me-2"></i>Delete Coupon
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-info small mb-0">
                        <i class="bi bi-info-circle me-1"></i>Cannot delete - coupon has been used
                    </div>
                }
            </div>
        </div>
    </div>
</div>
