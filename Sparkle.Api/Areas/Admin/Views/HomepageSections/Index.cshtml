@model List<Sparkle.Domain.Content.HomepageSection>
@{
    ViewData["Title"] = "Homepage Sections";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@Html.AntiForgeryToken()

<div class="container-fluid p-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div class="mb-3 mb-md-0">
            <h2 class="h3 fw-bold mb-1">Homepage Sections</h2>
            <p class="text-muted mb-0">Design and manage your storefront structure</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary px-4 fw-medium shadow-sm" style="height: 45px; display: flex; align-items: center; gap: 8px;">
                <i class="bi bi-plus-circle"></i> Add New Section
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="row g-3" id="sortableSections">
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        var accentColor = item.SectionType switch {
                            "FlashSale" => "tw-from-orange-400 tw-to-pink-500",
                            "TrendingProducts" => "tw-from-yellow-400 tw-to-orange-500",
                            "CategoryShop" => "tw-from-blue-500 tw-to-indigo-500",
                            "RecommendedProducts" => "tw-from-purple-500 tw-to-indigo-500",
                            _ => "tw-from-slate-400 tw-to-slate-600"
                        };

                        <div class="col-xl-3 col-lg-4 col-md-6 mb-3 sortable-item" data-id="@item.Id">
                            <div class="tw-group tw-relative tw-bg-white tw-rounded-xl tw-shadow-sm tw-border tw-border-slate-200 tw-overflow-hidden hover:tw-shadow-md tw-transition-all h-100">
                                <div class="tw-absolute tw-top-0 tw-left-0 tw-w-full tw-h-1 tw-bg-gradient-to-r @accentColor"></div>
                                
                                <div class="tw-p-4">
                                    <div class="tw-flex tw-justify-between tw-items-start tw-mb-3">
                                        <div class="tw-flex tw-items-center tw-gap-2">
                                            <div class="sort-handle tw-cursor-move tw-text-slate-300 hover:tw-text-slate-500 tw-transition-colors">
                                                <i class="bi bi-grip-vertical tw-text-xl"></i>
                                            </div>
                                            <div>
                                                <div class="tw-flex tw-items-center tw-gap-1.5">
                                                    <h6 class="tw-font-bold tw-text-slate-900 tw-mb-0 tw-text-sm">@item.Name</h6>
                                                    <span class="tw-text-[10px] tw-font-bold tw-bg-slate-50 tw-text-slate-400 tw-px-1.5 tw-py-0.5 tw-rounded border border-slate-100">#@item.DisplayOrder</span>
                                                </div>
                                                <span class="tw-text-[10px] tw-font-bold tw-uppercase tw-tracking-wider tw-text-slate-400">@item.SectionType</span>
                                            </div>
                                        </div>
                                        <div class="tw-relative tw-inline-flex tw-items-center tw-cursor-pointer">
                                            <input type="checkbox" class="tw-sr-only tw-peer" @(item.IsActive ? "checked" : "") onchange="toggleSection(@item.Id, this.checked)">
                                            <div class="tw-w-7 tw-h-3.5 tw-bg-slate-200 peer-focus:tw-outline-none tw-rounded-full peer tw-transition-all peer-checked:after:tw-translate-x-full peer-checked:after:tw-border-white after:tw-content-[''] after:tw-absolute after:tw-top-[2px] after:tw-left-[2px] after:tw-bg-white after:tw-border-slate-200 after:tw-border after:tw-rounded-full after:tw-h-2.5 after:tw-w-2.5 after:tw-shadow-sm after:tw-transition-all peer-checked:tw-bg-emerald-500"></div>
                                        </div>
                                    </div>

                                    <div class="tw-grid tw-grid-cols-3 tw-gap-1 tw-mb-4 tw-p-2 tw-bg-slate-50/50 tw-rounded-lg tw-border tw-border-slate-100">
                                        <div class="tw-text-center">
                                            <span class="tw-block tw-text-[9px] tw-text-slate-400 tw-font-bold tw-uppercase">Items</span>
                                            <span class="tw-text-[11px] tw-font-bold tw-text-slate-700">@item.ManualProducts.Count<span class="tw-text-slate-400">/@item.MaxProductsToDisplay</span></span>
                                        </div>
                                        <div class="tw-text-center tw-border-x tw-border-slate-200">
                                            <span class="tw-block tw-text-[9px] tw-text-slate-400 tw-font-bold tw-uppercase">Card</span>
                                            <span class="tw-text-[11px] tw-font-bold tw-text-slate-700">@item.CardSize[0]</span>
                                        </div>
                                        <div class="tw-text-center">
                                            <span class="tw-block tw-text-[9px] tw-text-slate-400 tw-font-bold tw-uppercase">Style</span>
                                            <span class="tw-text-[11px] tw-font-bold tw-text-slate-700">@(item.LayoutType == "Carousel" ? "Slide" : item.LayoutType)</span>
                                        </div>
                                    </div>

                                    @if (item.UseAutomatedSelection)
                                    {
                                        <div class="tw-flex tw-items-center tw-gap-1.5 tw-mb-4 tw-px-2 tw-py-1.5 tw-bg-purple-50/50 tw-text-purple-600 tw-rounded-md tw-border tw-border-purple-100/50">
                                            <i class="bi bi-stars tw-text-[10px]"></i>
                                            <span class="tw-text-[10px] tw-font-bold">Smart Selection</span>
                                        </div>
                                    } else {
                                         <div class="tw-flex tw-items-center tw-gap-1.5 tw-mb-4 tw-px-2 tw-py-1.5 tw-bg-blue-50/50 tw-text-blue-600 tw-rounded-md tw-border tw-border-blue-100/50">
                                            <i class="bi bi-hand-index-thumb tw-text-[10px]"></i>
                                            <span class="tw-text-[10px] tw-font-bold">Manual Curation</span>
                                        </div>
                                    }

                                    <div class="tw-flex tw-gap-2">
                                        <a asp-action="ManageProducts" asp-route-id="@item.Id" class="tw-flex-1 tw-flex tw-items-center tw-justify-center tw-gap-1.5 tw-bg-slate-900 hover:tw-bg-black tw-text-white tw-py-2 tw-rounded-lg tw-text-[11px] tw-font-bold tw-transition-all">
                                            <i class="bi bi-box-seam"></i> Products
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="tw-flex tw-items-center tw-justify-center tw-w-9 tw-bg-slate-50 hover:tw-bg-slate-100 tw-text-slate-500 tw-rounded-lg tw-border tw-border-slate-200 tw-transition-all">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="tw-inline" onsubmit="return confirm('Delete this section?')">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="tw-flex tw-items-center tw-justify-center tw-w-9 tw-h-9 tw-bg-red-50 hover:tw-bg-red-100 tw-text-red-500 tw-rounded-lg tw-border tw-border-red-100 tw-transition-all">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <i class="bi bi-grid-3x3-gap display-1 text-muted opacity-25"></i>
                            <p class="mt-3 text-muted">No sections created yet. Create your first homepage section!</p>
                            <a asp-action="Create" class="btn btn-primary mt-2">
                                <i class="bi bi-plus-circle me-2"></i> Create Section
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const el = document.getElementById('sortableSections');
        if (el) {
            new Sortable(el, {
                animation: 150,
                handle: '.sort-handle',
                draggable: '.sortable-item',
                ghostClass: 'tw-opacity-50',
                onEnd: async function() {
                    const ids = Array.from(el.querySelectorAll('.sortable-item')).map(item => parseInt(item.dataset.id));
                    try {
                        const response = await fetch('/Admin/HomepageSections/UpdateOrder', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: JSON.stringify(ids)
                        });
                        const data = await response.json();
                        if (data.success) {
                            // Show minor toast or indicator if needed
                        }
                    } catch (error) {
                        console.error('Error updating order:', error);
                    }
                }
            });
        }
    });

    async function toggleSection(id, isActive) {
        try {
            const response = await fetch('/Admin/HomepageSections/ToggleActive?id=' + id, {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            });
            const data = await response.json();
            if (!data.success) {
                location.reload();
            }
        } catch (error) {
            alert('Error toggling section');
        }
    }
</script>
}

