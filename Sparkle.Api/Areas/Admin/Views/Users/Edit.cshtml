@model Sparkle.Domain.Identity.ApplicationUser

@{
    ViewData["Title"] = "Edit User";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit User</h2>
        <p class="text-muted">Update user profile information.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

<div class="content-card" style="max-width: 800px;">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label control-label">Full Name</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            
            <div class="col-md-6">
                <label asp-for="Email" class="form-label control-label"></label>
                <input asp-for="Email" class="form-control" readonly />
                <div class="form-text">Email cannot be changed.</div>
            </div>

            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label control-label">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-2"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
