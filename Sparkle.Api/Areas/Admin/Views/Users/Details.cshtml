@model Sparkle.Domain.Identity.ApplicationUser
@using Sparkle.Domain.Orders
@{
    ViewData["Title"] = "User Profile";
    var roles = ViewBag.UserRoles as IList<string>;
    var orders = ViewBag.Orders as List<Sparkle.Domain.Orders.Order>;
    var totalSpent = (decimal?)ViewBag.TotalSpent ?? 0m;
    var totalOrders = (int)ViewBag.TotalOrders;
    var reviews = (int)ViewBag.ReviewsWritten;
}

<div class="container-fluid p-0">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h3 fw-bold text-dark mb-1">User Profile</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small text-muted">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Users" asp-action="Index" class="text-decoration-none">Users</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.FullName</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm px-4">
                <i class="bi bi-pencil-square"></i> Edit Profile
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Profile Card -->
        <div class="col-lg-4">
            <!-- Main Profile Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body text-center p-5">
                    <div class="position-relative d-inline-block mb-3">
                         @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                        {
                            <img src="@Model.ProfilePhotoPath" class="rounded-circle border" style="width: 120px; height: 120px; object-fit: cover; border-color: #f3f4f6 !important;" alt="@Model.FullName">
                        }
                        else
                        {
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto border" style="width: 120px; height: 120px; font-size: 3.5rem; color: #9ca3af; border-color: #f3f4f6 !important;">
                                @(Model.FullName?.FirstOrDefault() ?? '?')
                            </div>
                        }
                        <span class="position-absolute bottom-0 end-0 p-2 border border-white rounded-circle @(Model.IsActive ? "bg-success" : "bg-danger")" style="width: 20px; height: 20px;"></span>
                    </div>

                    <h4 class="fw-bold text-dark mb-1">@(Model.FullName ?? "Guest User")</h4>
                    <p class="text-muted mb-3">@Model.Email</p>

                    <div class="mb-4">
                        @if (roles != null && roles.Any())
                        {
                            foreach (var role in roles)
                            {
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-1 fw-bold">@role</span>
                            }
                        }
                        else
                        {
                             <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-1">Customer</span>
                        }
                    </div>

                    <div class="d-grid gap-2">
                        <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post" class="d-grid" onsubmit="return confirm('Are you sure you want to change this user status?');">
                            @if (Model.IsActive)
                            {
                                <button type="submit" class="btn btn-outline-danger w-100 rounded-pill py-2">
                                    <i class="bi bi-slash-circle me-2"></i> Block User
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-outline-success w-100 rounded-pill py-2">
                                    <i class="bi bi-check-circle me-2"></i> Activate User
                                </button>
                            }
                        </form>
                        
                        <form asp-action="ResetPassword" asp-route-id="@Model.Id" method="post" class="d-grid" onsubmit="return confirm('Are you sure you want to reset the password?');">
                             <button type="submit" class="btn btn-light border w-100 rounded-pill py-2 text-muted fw-medium">
                                <i class="bi bi-key me-2"></i> Reset Password
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h6 class="fw-bold text-dark mb-0">Contact Information</h6>
                </div>
                <div class="card-body p-4">
                    <ul class="list-unstyled d-flex flex-column gap-3 mb-0">
                        <li class="d-flex align-items-center text-muted">
                            <i class="bi bi-telephone me-3 text-secondary"></i>
                            <span class="text-dark">@(Model.PhoneNumber ?? "Not provided")</span>
                        </li>
                        <li class="d-flex align-items-center text-muted">
                            <i class="bi bi-geo-alt me-3 text-secondary"></i>
                            <span class="text-dark">@(Model.Address ?? "Not provided")</span>
                        </li>
                         <li class="d-flex align-items-center text-muted">
                            <i class="bi bi-calendar3 me-3 text-secondary"></i>
                            <span class="text-dark">Joined @Model.RegisteredAt.ToString("MMM dd, yyyy")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Right Column: Stats & Data -->
        <div class="col-lg-8">
            <!-- Stats Row -->
            <div class="row g-4 mb-4">
                <!-- Total Orders -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="bi bi-bag fs-4"></i>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase fw-bold" style="font-size: 0.7rem;">Total Orders</div>
                                <h3 class="fw-bold mb-0">@totalOrders</h3>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Total Spent -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 d-flex align-items-center gap-3">
                            <div class="bg-success bg-opacity-10 text-success rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="bi bi-currency-dollar fs-4"></i>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase fw-bold" style="font-size: 0.7rem;">Total Spent</div>
                                <h3 class="fw-bold mb-0">৳@totalSpent.ToString("N0")</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reviews -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 d-flex align-items-center gap-3">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="bi bi-star fs-4"></i>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase fw-bold" style="font-size: 0.7rem;">Reviews</div>
                                <h3 class="fw-bold mb-0">@reviews</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Orders Table -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">Recent Orders</h5>
                     <a asp-controller="Orders" asp-action="Index" asp-route-userId="@Model.Id" class="btn btn-light border btn-sm px-3">View All</a>
                </div>
                <div class="card-body p-0 mt-3">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-secondary text-uppercase small">
                                <tr>
                                    <th class="ps-4 py-3 fw-bold border-0">Order</th>
                                    <th class="py-3 fw-bold border-0">Date</th>
                                    <th class="py-3 fw-bold border-0">Amount</th>
                                    <th class="py-3 fw-bold border-0">Status</th>
                                    <th class="pe-4 py-3 fw-bold border-0 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (orders != null && orders.Any())
                                {
                                    foreach (var order in orders)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="fw-bold text-dark">
                                                    @(order.OrderItems.FirstOrDefault()?.ProductName ?? "Order Item")
                                                    @if(order.OrderItems.Count > 1) {
                                                        <small class="text-muted fw-normal">(+@(order.OrderItems.Count - 1) more)</small>
                                                    }
                                                </div>
                                                <div class="small text-muted bg-light border px-2 rounded d-inline-block mt-1">
                                                    @order.OrderNumber
                                                </div>
                                            </td>
                                            <td class="text-secondary small">
                                                @order.OrderDate.ToString("MMM dd, yyyy") <br>
                                                <span class="text-muted">@order.OrderDate.ToString("h:mm tt")</span>
                                            </td>
                                            <td class="fw-bold text-success">৳@order.TotalAmount.ToString("N0")</td>
                                            <td>
                                                @{
                                                    var badgeClass = order.Status.ToString().ToLower() switch 
                                                    {
                                                        "delivered" => "bg-success-subtle text-success border-success-subtle",
                                                        "pending" => "bg-warning-subtle text-warning border-warning-subtle",
                                                        "cancelled" => "bg-danger-subtle text-danger border-danger-subtle",
                                                        "processing" => "bg-info-subtle text-info border-info-subtle",
                                                        "shipped" => "bg-primary-subtle text-primary border-primary-subtle",
                                                        _ => "bg-secondary-subtle text-secondary border-secondary-subtle"
                                                    };
                                                }
                                                <span class="badge @badgeClass border rounded-pill px-3 py-1 text-uppercase" style="font-size: 0.65rem;">@order.Status</span>
                                            </td>
                                            <td class="pe-4 text-end">
                                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-light border shadow-sm rounded-circle" style="width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center;">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <div class="mb-2"><i class="bi bi-cart-x fs-1 opacity-25"></i></div>
                                            No orders placed yet.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
