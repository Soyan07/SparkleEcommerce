@model List<Sparkle.Domain.Identity.ApplicationUser>
@using Sparkle.Domain.Identity
@{
    ViewData["Title"] = "User Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var searchQuery = ViewBag.SearchQuery as string;
    var currentStatus = ViewBag.CurrentStatus as string;
    var activeCount = ViewBag.ActiveCount;
    var blockedCount = ViewBag.BlockedCount;
}

<div class="container-fluid p-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div class="mb-3 mb-md-0">
            <h2 class="h3 fw-bold mb-1">User Management</h2>
            <p class="text-muted mb-0">Manage system users, view details, and monitoring.</p>
        </div>
        <div>
            <a href="/Admin/Users/Create" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm">
                <i class="bi bi-plus-lg"></i>
                <span>Add New User</span>
            </a>
        </div>
    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <!-- Toolbar -->
            <div class="p-4 border-bottom">
                <div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-center">
                    <!-- Status Tabs -->
                    <div class="d-flex gap-2">
                        <a href="?q=@searchQuery" class="btn btn-sm rounded-pill px-3 py-2 fw-medium @(string.IsNullOrEmpty(currentStatus) ? "bg-dark text-white" : "bg-light text-muted")">
                            All Users
                        </a>
                        <a href="?status=active&q=@searchQuery" class="btn btn-sm rounded-pill px-3 py-2 fw-medium @(currentStatus == "active" ? "bg-success-subtle text-success border border-success-subtle" : "bg-light text-muted")">
                            Active <span class="badge @(currentStatus == "active" ? "bg-success text-white" : "bg-secondary text-white") ms-1 rounded-pill">@activeCount</span>
                        </a>
                        <a href="?status=blocked&q=@searchQuery" class="btn btn-sm rounded-pill px-3 py-2 fw-medium @(currentStatus == "blocked" ? "bg-danger-subtle text-danger border border-danger-subtle" : "bg-light text-muted")">
                            Blocked <span class="badge @(currentStatus == "blocked" ? "bg-danger text-white" : "bg-secondary text-white") ms-1 rounded-pill">@blockedCount</span>
                        </a>
                    </div>

                    <!-- Search -->
                    <form method="get" class="d-flex align-items-center flex-grow-1" style="max-width: 400px;">
                        <input type="hidden" name="status" value="@currentStatus" />
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 ps-3">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="q" class="form-control bg-light border-start-0 ps-0" 
                                   placeholder="Search user by name, email..." 
                                   value="@searchQuery" style="height: 40px; font-size: 14px;">
                        </div>
                    </form>
                </div>
            </div>

            <!-- Table -->
            <div class="table-responsive">
                <table class="table align-middle mb-0 table-hover">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="ps-4 py-3 text-secondary text-uppercase small fw-bold" style="width: 30%;">User Profile</th>
                            <th class="py-3 text-secondary text-uppercase small fw-bold" style="width: 25%;">Contact Info</th>
                            <th class="py-3 text-secondary text-uppercase small fw-bold" style="width: 15%;">Role</th>
                            <th class="py-3 text-secondary text-uppercase small fw-bold" style="width: 15%;">Joined</th>
                            <th class="py-3 text-secondary text-uppercase small fw-bold" style="width: 10%;">Status</th>
                            <th class="pe-4 py-3 text-secondary text-uppercase small fw-bold text-end" style="width: 5%;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            foreach (var user in Model)
                            {
                                <tr>
                                    <!-- User Profile -->
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="position-relative me-3">
                                                 @if (!string.IsNullOrEmpty(user.ProfilePhotoPath))
                                                {
                                                    <img src="@user.ProfilePhotoPath" class="rounded-circle" width="45" height="45" style="object-fit: cover; border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                                }
                                                else
                                                {
                                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center text-primary fw-bold fs-5" style="width: 45px; height: 45px; border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                                                        @(user.FullName?.FirstOrDefault() ?? user.UserName?.FirstOrDefault() ?? '?')
                                                    </div>
                                                }
                                                <span class="position-absolute bottom-0 end-0 p-1 bg-@(user.IsActive ? "success" : "danger") border border-white rounded-circle"></span>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@(user.FullName ?? "Guest User")</div>
                                                <div class="text-muted small">@user.UserName</div>
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Contact Info -->
                                    <td class="py-3">
                                        <div class="d-flex flex-column gap-1">
                                            <div class="d-flex align-items-center text-dark" style="font-size: 13px;">
                                                <i class="bi bi-envelope text-muted me-2"></i> @user.Email
                                            </div>
                                            @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                            {
                                                <div class="d-flex align-items-center text-muted small">
                                                    <i class="bi bi-telephone me-2"></i> @user.PhoneNumber
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-muted small opacity-50 ps-4">No phone</div>
                                            }
                                        </div>
                                    </td>

                                    <!-- Role -->
                                    <td class="py-3">
                                        @if (user.IsSeller)
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3 py-1">
                                                <i class="bi bi-shop me-1"></i> Seller
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-1">Customer</span>
                                        }
                                    </td>

                                    <!-- Joined -->
                                    <td class="py-3">
                                        <div class="d-flex flex-column">
                                            <span class="fw-medium text-dark" style="font-size: 13px;">@user.RegisteredAt.ToString("MMM dd, yyyy • h:mm tt")</span>
                                            <span class="text-muted small" style="font-size: 11px;">@((DateTime.UtcNow - user.RegisteredAt).Days) days ago</span>
                                        </div>
                                    </td>

                                    <!-- Status -->
                                    <td class="py-3">
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2 py-1" style="font-size: 11px;">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2 py-1" style="font-size: 11px;">Blocked</span>
                                        }
                                    </td>

                                    <!-- Action -->
                                    <td class="pe-4 py-3 text-end">
                                        <div class="dropdown">
                                             <a href="/Admin/Users/Details/@user.Id" class="btn btn-sm btn-white border shadow-sm fw-medium d-inline-flex align-items-center gap-2 px-3">
                                                View Profile
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="d-flex flex-column align-items-center justify-content-center py-4">
                                        <div class="bg-light rounded-circle p-4 mb-3">
                                            <i class="bi bi-people text-secondary display-6"></i>
                                        </div>
                                        <h5 class="fw-bold text-dark mb-1">No Users Found</h5>
                                        <p class="text-muted mb-0">Try adjusting your search or filters.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center p-4 border-top">
                    <div class="text-muted small">
                        Showing page @currentPage of @totalPages
                    </div>
                    <nav>
                        <ul class="pagination mb-0 gap-1">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link border rounded-2 text-muted px-3" href="?page=@(currentPage - 1)&q=@searchQuery&status=@currentStatus">
                                    Previous
                                </a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item">
                                    <a class="page-link border rounded-2 d-flex align-items-center justify-content-center @(currentPage == i ? "bg-primary text-white border-primary" : "text-muted hover-bg-light")" 
                                       style="width: 32px; height: 32px; font-weight: 500;"
                                       href="?page=@i&q=@searchQuery&status=@currentStatus">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link border rounded-2 text-muted px-3" href="?page=@(currentPage + 1)&q=@searchQuery&status=@currentStatus">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>
