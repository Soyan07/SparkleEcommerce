@model Sparkle.Domain.Catalog.Product

@{
    ViewData["Title"] = "Create Product";
    var categories = ViewBag.Categories as List<Sparkle.Domain.Catalog.Category>;
}

<div class="content-header">
    <div>
        <h2 class="content-title">Create Official Product</h2>
        <p class="text-muted">Add a new product as an official Sparkle platform offering.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

<form asp-action="Create" method="post">
    <div class="row g-4">
        <!-- Main Form -->
        <div class="col-lg-8">
            <div class="content-card mb-4">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Basic Information</h5>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Product Title *</label>
                    <input asp-for="Title" class="form-control" placeholder="Enter product name" required />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ShortDescription" class="form-label">Short Description</label>
                    <textarea asp-for="ShortDescription" class="form-control" rows="2" placeholder="Brief product description"></textarea>
                    <span asp-validation-for="ShortDescription" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Full Description</label>
                    <textarea asp-for="Description" class="form-control" rows="6" placeholder="Detailed product description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="content-card mb-4">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Pricing & Inventory</h5>
                
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="BasePrice" class="form-label">Price *</label>
                        <div class="input-group">
                            <span class="input-group-text">৳</span>
                            <input asp-for="BasePrice" class="form-control" type="number" step="0.01" required />
                        </div>
                        <span asp-validation-for="BasePrice" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="DiscountPercent" class="form-label">Discount %</label>
                        <div class="input-group">
                            <input asp-for="DiscountPercent" class="form-control" type="number" step="0.1" value="0" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                    </div>

                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <small>Stock and SKU can be managed through product variants after creation.</small>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="content-card mb-4">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Product Settings</h5>
                
                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">Category *</label>
                    <select asp-for="CategoryId" class="form-select" required>
                        <option value="">Select a category</option>
                        @if (categories != null)
                        {
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="card bg-light border-0 p-3 mb-3">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" checked />
                        <label class="form-check-label" asp-for="IsActive">
                            <strong>Active</strong>
                            <small class="d-block text-muted">Product will be visible in store</small>
                        </label>
                    </div>
                </div>

                <div class="alert alert-info mb-0">
                    <i class="bi bi-star-fill me-2"></i>
                    <small>This product will be marked as an <strong>Official Sparkle Product</strong> with a verified badge.</small>
                </div>
            </div>

            <div class="content-card">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Additional Info</h5>
                
                <div class="mb-3">
                    <label class="form-label">Brand (Optional)</label>
                    <input type="text" class="form-control" placeholder="Brand name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Weight (Optional)</label>
                    <div class="input-group">
                        <input type="number" class="form-control" step="0.01" placeholder="0.00" />
                        <span class="input-group-text">kg</span>
                    </div>
                </div>

                <div class="alert alert-warning mb-0">
                    <small><i class="bi bi-info-circle me-1"></i> Images and variants can be added after creating the product.</small>
                </div>
            </div>
        </div>
    </div>

    <div class="content-card mt-4">
        <div class="d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-2"></i> Cancel
            </a>
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-check-lg me-2"></i> Create Product
            </button>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
