@model Sparkle.Domain.Catalog.Product

@{
    ViewData["Title"] = "Edit Product";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Edit Product</h2>
        <p class="text-muted">Moderate and update product details.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

<form asp-action="Edit">
    <div class="row g-4">
        <!-- Editable Fields -->
        <div class="col-lg-7">
            <div class="content-card mb-4 table-responsive">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Product Information</h5>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Title" class="form-label control-label">Product Title</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="BasePrice" class="form-label control-label">Price</label>
                        <div class="input-group">
                            <span class="input-group-text">৳</span>
                            <input asp-for="BasePrice" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="BasePrice" class="text-danger"></span>
                    </div>
                    
                    <div class="col-md-6 mb-3">
                        <label asp-for="DiscountPercent" class="form-label control-label">Discount %</label>
                        <div class="input-group">
                            <input asp-for="DiscountPercent" class="form-control" type="number" step="0.1" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="DiscountPercent" class="text-danger"></span>
                    </div>
                </div>

                <div class="card bg-light border-0 p-3 mb-3">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                        <label class="form-check-label" asp-for="IsActive">
                            Active (Visible in store)
                        </label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="IsAdminProduct" />
                        <label class="form-check-label" asp-for="IsAdminProduct">
                            Official Sparkle Product (Star Badge)
                        </label>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>

        <!-- Read-only Review Info -->
        <div class="col-lg-5">
            <div class="content-card mb-4">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Product Images</h5>
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.Images != null && Model.Images.Any())
                    {
                        @foreach (var img in Model.Images)
                        {
                            <a href="@img.Url" target="_blank" class="border rounded p-1 d-block">
                                <img src="@img.Url" style="width: 80px; height: 80px; object-fit: cover;" />
                            </a>
                        }
                    }
                    else
                    {
                        <div class="text-muted fst-italic">No images uploaded.</div>
                    }
                </div>
            </div>

            <div class="content-card mb-4">
                <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Details for Review</h5>
                
                <div class="mb-3">
                    <label class="text-muted small d-block">Category</label>
                    <div class="fw-bold">@(Model.Category?.Name ?? "Uncategorized")</div>
                </div>

                <div class="mb-3">
                    <label class="text-muted small d-block">Seller</label>
                    @if (Model.Seller != null)
                    {
                        <div><a href="/Admin/Sellers/Details/@Model.SellerId">@Model.Seller.ShopName</a></div>
                        <small class="text-muted">@Model.Seller.MobileNumber</small>
                    }
                    else
                    {
                        <div class="badge bg-secondary">System</div>
                    }
                </div>

                <div class="mb-3">
                    <label class="text-muted small d-block">Short Description</label>
                    <div>@(Model.ShortDescription ?? "-")</div>
                </div>
                
                <div class="mb-3">
                    <label class="text-muted small d-block">Full Description</label>
                    <div class="bg-light p-2 rounded small" style="max-height: 200px; overflow-y: auto;">
                        @Html.Raw(Model.Description ?? "No description.")
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
