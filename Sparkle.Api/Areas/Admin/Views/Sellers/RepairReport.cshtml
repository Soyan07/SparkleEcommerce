@model List<string>
@{
    ViewData["Title"] = "Repair Report";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div>
        <h2 class="content-title">Seller Repair Report</h2>
        <p class="text-muted">Results of the seller account repair operation.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

<div class="content-card">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i> @TempData["Success"]
        </div>
    }
    else if (TempData["Info"] != null)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i> @TempData["Info"]
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Repair Log</h5>
        <ul class="list-group list-group-flush">
            @foreach (var msg in Model)
            {
                <li class="list-group-item">
                    @if (msg.StartsWith("Fixed"))
                    {
                        <i class="bi bi-check-lg text-success me-2"></i>
                    }
                    else
                    {
                        <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                    }
                    @msg
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No actions were needed.</p>
    }
</div>
