@using Sparkle.Domain.Sellers
@using Sparkle.Domain.Catalog
@model Seller
@{
    ViewData["Title"] = $"{Model.ShopName} - Details";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var user = ViewBag.User as Sparkle.Domain.Identity.ApplicationUser;
}

@section Styles {
    <style>
        /* Hide sidebar for local page focus as per original design */
        .sidebar { display: none !important; }
        .main-content { margin-left: 0 !important; width: 100% !important; padding: 0 !important; }
        body {
            background-color: #f1f5f9;
        }

        .seller-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 1rem;
        }

        .card-custom {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            transition: all 0.2s ease;
        }

        .card-header-custom {
            padding: 1.5rem;
            border-bottom: 1px solid #f1f5f9;
            background: transparent;
        }
        
        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }
        
        .info-value {
            color: #1e293b;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .shop-avatar-lg {
            width: 80px;
            height: 80px;
            font-size: 2rem;
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .status-badge {
            padding: 0.35em 0.8em;
            font-size: 0.85em;
            font-weight: 600;
            border-radius: 9999px;
            text-transform: capitalize;
        }
        
        .status-approved { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .status-pending { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
        .status-isolated { background: #e0e7ff; color: #3730a3; border: 1px solid #c7d2fe; }
        .status-rejected { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

        .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .table-custom th {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            background: #f8fafc;
            padding: 1rem;
            border-bottom: 1px solid #e2e8f0;
        }

        .table-custom td {
            padding: 1rem;
            vertical-align: middle;
            color: #334155;
            border-bottom: 1px solid #f1f5f9;
        }
    </style>
}

<div class="seller-container animate__animated animate__fadeIn">
    
    <!-- Top Header Card -->
    <div class="card-custom mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-4">
                <div class="d-flex gap-4">
                    <div class="shop-avatar-lg">
                        @Model.ShopName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div class="d-flex align-items-center gap-3 mb-1">
                            <h1 class="h3 fw-bold mb-0 text-dark">@Model.ShopName</h1>
                            @if (Model.Status == SellerStatus.Approved)
                            {
                                <span class="status-badge status-approved"><i class="bi bi-check-circle-fill me-1"></i> Approved</span>
                            }
                            else if (Model.Status == SellerStatus.Pending)
                            {
                                <span class="status-badge status-pending"><i class="bi bi-clock-history me-1"></i> Pending Review</span>
                            }
                            else if (Model.Status == SellerStatus.Isolated)
                            {
                                <span class="status-badge status-isolated"><i class="bi bi-exclamation-triangle-fill me-1"></i> Isolated</span>
                            }
                            else
                            {
                                <span class="status-badge status-rejected"><i class="bi bi-x-circle-fill me-1"></i> Rejected</span>
                            }
                        </div>
                        
                        <div class="d-flex flex-wrap align-items-center gap-3 text-secondary mt-2">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar-event me-2 text-muted"></i>
                                <span>Joined @Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt me-2 text-muted"></i>
                                <span>@Model.City, @Model.District</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <!-- External link removed -->

                    @if (Model.Status != SellerStatus.Approved)
                    {
                        <form asp-action="Approve" method="post">
                            <input type="hidden" name="sellerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-success btn-action text-white">
                                <i class="bi bi-check-lg"></i> Approve
                            </button>
                        </form>
                    }
                    
                    @if (Model.Status != SellerStatus.Isolated && Model.Status != SellerStatus.Rejected)
                    {
                        <form asp-action="Isolate" method="post">
                            <input type="hidden" name="sellerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-warning btn-action">
                                <i class="bi bi-pause-fill"></i> Isolate
                            </button>
                        </form>
                    }

                    @if (Model.Status != SellerStatus.Rejected)
                    {
                        <form asp-action="Decline" method="post">
                            <input type="hidden" name="sellerId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-action" onclick="return confirm('Confirm decline? This will block user login.');">
                                <i class="bi bi-x-lg"></i> Decline
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="row g-4">
        
        <!-- Left Column: Shop Details & Inventory -->
        <div class="col-lg-8">
            <!-- About Card -->
            <div class="card-custom mb-4">
                <div class="card-header-custom">
                    <h5 class="fw-bold mb-0 text-dark">About Shop</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-secondary mb-0" style="line-height: 1.7;">
                        @(Model.ShopDescription ?? "No description provided.")
                    </p>
                </div>
            </div>

            <!-- Inventory Card -->
            <div class="card-custom">
                <div class="card-header-custom d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark">Inventory Overview</h5>
                    <span class="badge bg-light text-secondary rounded-pill px-3 py-2 border">@products.Count items</span>
                </div>
                <div class="table-responsive">
                    @if (products.Any())
                    {
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 py-3 ps-3">Product</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 py-3">Category</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 py-3 text-end">Price</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 py-3 text-center">Status</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 py-3 text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in products.Take(10)) 
                                {
                                    <tr class="border-bottom">
                                        <td class="ps-3 py-2">
                                            <div class="d-flex align-items-center">
                                                <div class="position-relative me-3">
                                                    @if (product.Images?.Any() == true)
                                                    {
                                                        <img src="@product.Images.First().Url" class="rounded border" width="40" height="40" style="object-fit: cover;" alt="" />
                                                    }
                                                    else
                                                    {
                                                        <div class="rounded bg-light border d-flex align-items-center justify-content-center text-muted" style="width: 40px; height: 40px;">
                                                            <i class="bi bi-image"></i>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="d-flex flex-column justify-content-center">
                                                    <h6 class="mb-0 text-sm fw-bold text-dark text-truncate" style="max-width: 200px;">@product.Title</h6>
                                                    <div class="text-xs text-secondary mt-0">
                                                        <span>@product.CreatedAt.ToString("MMM dd, yyyy • h:mm tt")</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-2">
                                            <span class="text-xs font-weight-bold text-secondary">
                                                @(product.Category?.Name ?? "Uncategorized")
                                            </span>
                                        </td>
                                        <td class="py-2 text-end">
                                            <span class="text-sm fw-bold text-dark">
                                                @if(product.Variants != null && product.Variants.Any())
                                                {
                                                    @:৳@product.Variants.Min(v => v.Price).ToString("N0")
                                                }
                                                else
                                                {
                                                    @:—
                                                }
                                            </span>
                                        </td>
                                        <td class="py-2 text-center">
                                            @if (product.IsActive)
                                            {
                                                <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1 text-xxs border border-success-subtle">Published</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-1 text-xxs border border-secondary-subtle">Draft</span>
                                            }
                                        </td>
                                        <td class="py-2 text-end pe-3">
                                            <div class="d-flex justify-content-end gap-1">
                                                @if (product.IsActive)
                                                {
                                                    <form asp-controller="Products" asp-action="Reject" method="post" onsubmit="return confirm('Reject and hide this product?');">
                                                        <input type="hidden" name="id" value="@product.Id" />
                                                        <input type="hidden" name="reason" value="Quick action from Seller Profile" />
                                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                        <button type="submit" class="btn btn-icon btn-sm btn-light text-danger border shadow-sm" data-bs-toggle="tooltip" title="Reject/Hide">
                                                            <i class="bi bi-eye-slash-fill"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form asp-controller="Products" asp-action="Approve" method="post">
                                                        <input type="hidden" name="id" value="@product.Id" />
                                                        <input type="hidden" name="notes" value="Quick action from Seller Profile" />
                                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                                        <button type="submit" class="btn btn-icon btn-sm btn-light text-success border shadow-sm" data-bs-toggle="tooltip" title="Show/Activate">
                                                            <i class="bi bi-eye-fill"></i>
                                                        </button>
                                                    </form>
                                                }
                                                
                                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-icon btn-sm btn-light text-primary border shadow-sm" data-bs-toggle="tooltip" title="View Details">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if(products.Count > 10)
                        {
                             <div class="p-3 text-center border-top">
                                 <a href="#" class="text-primary fw-medium text-decoration-none small">View all @products.Count products</a>
                             </div>
                        }
                    }
                    else
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-basket3 display-6 mb-3 d-block text-secondary opacity-25"></i>
                            <p class="mb-0">No products available in this shop.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Column: Sidebar Info -->
        <div class="col-lg-4">
            
            <!-- Contact Information -->
            <div class="card-custom mb-4">
                <div class="card-header-custom">
                    <h5 class="fw-bold mb-0 text-dark">Contact Information</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column gap-4">
                    
                    <div>
                        <div class="info-label">Mobile Number</div>
                        <div class="info-value d-flex align-items-center gap-2">
                            <i class="bi bi-phone text-primary"></i> 
                            @{
                                var phone = !string.IsNullOrEmpty(Model.MobileNumber) ? Model.MobileNumber : user?.PhoneNumber;
                            }
                            @(!string.IsNullOrEmpty(phone) ? phone : "Not provided")
                        </div>
                    </div>
                    
                    <div>
                        <div class="info-label">Email Address</div>
                        <div class="info-value d-flex align-items-center gap-2">
                            <i class="bi bi-envelope text-primary"></i> 
                            @{
                                var email = !string.IsNullOrEmpty(Model.Email) ? Model.Email : user?.Email;
                            }
                            @if (!string.IsNullOrEmpty(email))
                            {
                                <a href="mailto:@email" class="text-decoration-none text-dark">@email</a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not provided</span>
                            }
                        </div>
                    </div>

                    <div>
                        <div class="info-label">Business Address</div>
                        <div class="info-value d-flex align-items-start gap-2">
                            <i class="bi bi-building text-primary mt-1"></i> 
                            <span>
                                @if(!string.IsNullOrEmpty(Model.BusinessAddress))
                                {
                                    @Model.BusinessAddress<br/>
                                    @:@Model.City, @Model.District
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Address not provided</span>
                                }
                            </span>
                        </div>
                    </div>
                    
                </div>
            </div>

            <!-- Owner Profile -->
            @if(user != null)
            {
                <div class="card-custom">
                    <div class="card-header-custom">
                        <h5 class="fw-bold mb-0 text-dark">Shop Owner</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="rounded-circle bg-indigo-50 d-flex align-items-center justify-content-center text-indigo-600 me-3 fw-bold fs-5 shadow-sm" style="width: 56px; height: 56px; background-color: #e0e7ff; color: #4338ca;">
                                @(user.FullName?.FirstOrDefault())
                            </div>
                            <div>
                                <div class="fw-bold text-dark">@user.FullName</div>
                                <div class="small text-muted font-monospace">@user.Id.ToString().Substring(0, 8)...</div>
                            </div>
                        </div>
                        <a asp-area="Admin" asp-controller="Users" asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-light text-dark border w-100 fw-medium">
                            <i class="bi bi-person-badge me-2"></i> View Full Profile
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Ensure no sidebar interference in this specific view mode
            const sidebar = document.getElementById('sidebar');
            if(sidebar) sidebar.style.display = 'none';
        });
    </script>
}
