@model Sparkle.Domain.Catalog.Product
@{
    ViewData["Title"] = "Edit Product";
}

<!-- Include Cropper.js for image editing -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<div class="tw-max-w-5xl tw-mx-auto">
    <!-- Header -->
    <div class="tw-flex tw-items-center tw-justify-between tw-mb-8">
        <div>
            <h1 class="tw-text-3xl tw-font-bold tw-text-slate-800 tw-tracking-tight">Edit Product</h1>
            <p class="tw-text-sm tw-text-slate-500 tw-mt-1">Update details for <span class="tw-font-semibold tw-text-slate-700">@Model.Title</span></p>
        </div>
        <a href="/Seller/Dashboard/Products" class="tw-group tw-flex tw-items-center tw-gap-2 tw-px-5 tw-py-2.5 tw-bg-white tw-text-slate-500 tw-font-bold tw-rounded-full tw-shadow-sm hover:tw-shadow-md hover:tw-text-emerald-600 tw-transition-all">
            <i class="bi bi-arrow-left group-hover:-tw-translate-x-1 tw-transition-transform"></i> 
            <span>Back to Inventory</span>
        </a>
    </div>

    <!-- Form -->
    <form asp-action="EditProduct" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-8">
        <div asp-validation-summary="ModelOnly" class="tw-hidden"></div>

        <!-- Left Column: Main Info -->
        <div class="lg:tw-col-span-2 tw-space-y-6">
            <!-- Basic Details Card -->
            <div class="tw-bg-white tw-rounded-3xl tw-p-8 tw-shadow-soft">
                <h3 class="tw-text-lg tw-font-bold tw-text-slate-800 tw-mb-6">Basic Information</h3>
                
                <div class="tw-space-y-5">
                    <div>
                        <label asp-for="Title" class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Product Title</label>
                        <input asp-for="Title" class="tw-w-full tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all" />
                        <span asp-validation-for="Title" class="tw-text-rose-500 tw-text-xs tw-mt-1 tw-block"></span>
                    </div>

                    <div>
                        <label asp-for="ShortDescription" class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Short Description</label>
                        <input asp-for="ShortDescription" class="tw-w-full tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all" />
                        <span asp-validation-for="ShortDescription" class="tw-text-rose-500 tw-text-xs tw-mt-1 tw-block"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Full Description</label>
                        <textarea asp-for="Description" rows="6" class="tw-w-full tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all"></textarea>
                        <span asp-validation-for="Description" class="tw-text-rose-500 tw-text-xs tw-mt-1 tw-block"></span>
                    </div>
                </div>
            </div>

             <!-- Media Card -->
            <div class="tw-bg-white tw-rounded-3xl tw-p-8 tw-shadow-soft">
                 <h3 class="tw-text-lg tw-font-bold tw-text-slate-800 tw-mb-6">Media</h3>
                 <div>
                <div class="tw-space-y-6">
                    <!-- Existing Images -->
                    @if (Model.Images != null && Model.Images.Any())
                    {
                        <div>
                            <label class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Current Images (Drag to Reorder)</label>
                            <div id="imageGallery" class="tw-grid tw-grid-cols-4 tw-gap-3">
                                @foreach (var img in Model.Images)
                                {
                                    <div class="image-item tw-relative tw-aspect-square tw-rounded-lg tw-overflow-hidden tw-border tw-border-slate-200 tw-cursor-move hover:tw-shadow-md tw-transition-all tw-group" draggable="true" data-image-id="@img.Id" data-image-url="@img.Url">
                                        <img src="@img.Url" class="tw-w-full tw-h-full tw-object-cover" />
                                        
                                        <!-- Action Buttons -->
                                        <div class="tw-absolute tw-inset-0 tw-bg-black/50 tw-opacity-0 group-hover:tw-opacity-100 tw-transition-opacity tw-flex tw-items-center tw-justify-center tw-gap-2">
                                            <!-- View Button -->
                                            <button type="button" onclick="viewImage('@img.Url', '@img.Id')" class="tw-w-9 tw-h-9 tw-rounded-full tw-bg-blue-500 hover:tw-bg-blue-600 tw-text-white tw-flex tw-items-center tw-justify-center tw-transition-all hover:tw-scale-110 tw-shadow-md" title="View">
                                                <i class="bi bi-eye tw-text-sm"></i>
                                            </button>

                                            <!-- Edit/Crop Button -->
                                            <button type="button" onclick="editImage('@img.Url', '@img.Id')" class="tw-w-9 tw-h-9 tw-rounded-full tw-bg-amber-500 hover:tw-bg-amber-600 tw-text-white tw-flex tw-items-center tw-justify-center tw-transition-all hover:tw-scale-110 tw-shadow-md" title="Crop & Resize">
                                                <i class="bi bi-crop tw-text-sm"></i>
                                            </button>

                                            <!-- Delete Button -->
                                            <button type="button" onclick="deleteImage('@img.Id', this)" class="tw-w-9 tw-h-9 tw-rounded-full tw-bg-rose-500 hover:tw-bg-rose-600 tw-text-white tw-flex tw-items-center tw-justify-center tw-transition-all hover:tw-scale-110 tw-shadow-md" title="Delete">
                                                <i class="bi bi-x-lg tw-text-sm tw-font-bold"></i>
                                            </button>
                                        </div>

                                        <!-- Drag Handle -->
                                        <div class="tw-absolute tw-bottom-1 tw-right-1 tw-w-6 tw-h-6 tw-rounded tw-bg-slate-900/60 tw-text-white tw-flex tw-items-center tw-justify-center tw-opacity-0 group-hover:tw-opacity-100 tw-transition-opacity tw-text-xs">
                                            <i class="bi bi-arrows-move tw-text-xs"></i>
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="hidden" id="imageOrder" name="imageOrder" value="" />
                        </div>
                    }

                     <!-- File Upload -->
                     <div>
                        <label class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Upload New Photos</label>
                        <input name="ImageFiles" type="file" multiple accept="image/*" class="tw-w-full tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all file:tw-mr-4 file:tw-py-2 file:tw-px-4 file:tw-rounded-full file:tw-border-0 file:tw-text-sm file:tw-font-semibold file:tw-bg-emerald-50 file:tw-text-emerald-700 hover:file:tw-bg-emerald-100" />
                        <p class="tw-text-xs tw-text-slate-400 tw-mt-2">Select multiple files (JPG/PNG).</p>
                     </div>

                     <!-- Image Links -->
                     <div>
                        <label class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Add Image Links</label>
                        <div id="urlContainer" class="tw-space-y-3">
                            <input name="ImageUrls" type="url" class="tw-w-full tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all" placeholder="https://..." />
                        </div>
                        <button type="button" onclick="addUrlField()" class="tw-mt-3 tw-text-sm tw-font-bold tw-text-emerald-600 hover:tw-text-emerald-700 tw-flex tw-items-center tw-gap-1">
                            <i class="bi bi-plus-lg"></i> Add another link
                        </button>
                    </div>
                </div>

                <script>
                    function addUrlField() {
                        const container = document.getElementById('urlContainer');
                        const input = document.createElement('input');
                        input.name = 'ImageUrls';
                        input.type = 'url';
                        input.placeholder = 'https://...';
                        input.className = 'tw-w-full tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all';
                        container.appendChild(input);
                    }
                </script>
                </div>
            </div>
        </div>

        <!-- Right Column: Settings -->
        <div class="tw-space-y-6">
             <!-- Pricing Card -->
            <div class="tw-bg-white tw-rounded-3xl tw-p-8 tw-shadow-soft">
                <h3 class="tw-text-lg tw-font-bold tw-text-slate-800 tw-mb-6">Pricing & Inventory</h3>
                
                <div class="tw-space-y-5">
                     <div>
                        <label name="Price" class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Price (৳)</label>
                        <div class="tw-relative">
                             <span class="tw-absolute tw-left-4 tw-top-1/2 -tw-translate-y-1/2 tw-text-slate-400 tw-font-bold">৳</span>
                             <input name="Price" type="number" min="0.01" step="0.01" value="@ViewBag.Price" class="tw-w-full tw-pl-10 tw-pr-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all" />
                        </div>
                        <p class="tw-text-xs tw-text-slate-400 tw-mt-1">Must be greater than 0</p>
                    </div>

                    <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                        <div>
                            <label name="Stock" class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Stock</label>
                            <input name="Stock" type="number" min="0" value="@ViewBag.Stock" class="tw-w-full tw-px-4 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-bold tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all" />
                            <p class="tw-text-xs tw-text-slate-400 tw-mt-1">Cannot be negative</p>
                        </div>
                    </div>
                </div>
            </div>

             <!-- Organization Card -->
            <div class="tw-bg-white tw-rounded-3xl tw-p-8 tw-shadow-soft">
                <h3 class="tw-text-lg tw-font-bold tw-text-slate-800 tw-mb-6">Organization</h3>
                
                <div>
                     <label asp-for="CategoryId" class="tw-block tw-text-xs tw-font-bold tw-text-slate-500 tw-uppercase tw-mb-2">Category</label>
                    <div class="tw-relative">
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="tw-w-full tw-appearance-none tw-px-5 tw-py-3 tw-bg-slate-50 tw-border-none tw-rounded-xl tw-text-sm tw-font-medium tw-text-slate-800 focus:tw-ring-2 focus:tw-ring-emerald-500/20 focus:tw-bg-white tw-transition-all">
                            <option value="">Select Category</option>
                        </select>
                        <i class="bi bi-chevron-down tw-absolute tw-right-4 tw-top-1/2 -tw-translate-y-1/2 tw-text-slate-400 tw-text-xs tw-pointer-events-none"></i>
                    </div>
                    <span asp-validation-for="CategoryId" class="tw-text-rose-500 tw-text-xs tw-mt-1 tw-block"></span>
                </div>
            </div>

            <!-- Actions -->
            <div class="tw-grid tw-grid-cols-2 tw-gap-4">
                 <a href="/Seller/Dashboard/Products" class="tw-px-4 tw-py-3 tw-text-sm tw-font-bold tw-text-slate-600 tw-bg-white tw-rounded-xl hover:tw-bg-slate-50 tw-shadow-soft tw-text-center tw-transition-all">Discard</a>
                 <button type="submit" class="tw-px-4 tw-py-3 tw-text-sm tw-font-bold tw-text-white tw-bg-emerald-500 tw-rounded-xl hover:tw-bg-emerald-600 tw-shadow-lg tw-shadow-emerald-200 tw-transition-all hover:tw-transform hover:tw-scale-105">
                     Save Changes
                 </button>
            </div>
        </div>
    </form>
</div>

<script>
    // ============ IMAGE MANAGEMENT ============
    
    // Delete Image Function
    function deleteImage(imageId, button) {
        if (!confirm('❌ Delete this image? This action cannot be undone.')) return;
        
        const imageItem = button.closest('.image-item');
        
        // Show loading state
        button.disabled = true;
        button.innerHTML = '<i class="bi bi-hourglass-split tw-animate-spin"></i>';
        
        // Send delete request
        fetch(`/Seller/Dashboard/DeleteProductImage?imageId=${imageId}`, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    imageItem.style.opacity = '0';
                    imageItem.style.transform = 'scale(0.8)';
                    setTimeout(() => imageItem.remove(), 300);
                } else {
                    alert(data.message || '❌ Failed to delete image');
                    button.disabled = false;
                    button.innerHTML = '<i class="bi bi-x-lg tw-text-sm tw-font-bold"></i>';
                }
            })
            .catch(e => {
                console.error(e);
                alert('❌ Error deleting image');
                button.disabled = false;
                button.innerHTML = '<i class="bi bi-x-lg tw-text-sm tw-font-bold"></i>';
            });
    }

    // ============ DRAG & DROP REORDERING ============
    
    let draggedElement = null;
    
    const imageGallery = document.getElementById('imageGallery');
    if (imageGallery) {
        const imageItems = document.querySelectorAll('.image-item');
        
        imageItems.forEach(item => {
            item.addEventListener('dragstart', (e) => {
                draggedElement = item;
                item.style.opacity = '0.5';
                e.dataTransfer.effectAllowed = 'move';
            });
            
            item.addEventListener('dragend', (e) => {
                item.style.opacity = '1';
                draggedElement = null;
            });
            
            item.addEventListener('dragover', (e) => {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                
                if (draggedElement && draggedElement !== item) {
                    const container = imageGallery;
                    const allItems = [...container.querySelectorAll('.image-item')];
                    const draggedIndex = allItems.indexOf(draggedElement);
                    const targetIndex = allItems.indexOf(item);
                    
                    if (draggedIndex < targetIndex) {
                        item.parentNode.insertBefore(draggedElement, item.nextSibling);
                    } else {
                        item.parentNode.insertBefore(draggedElement, item);
                    }
                    updateImageOrder();
                }
            });
            
            item.addEventListener('drop', (e) => {
                e.preventDefault();
            });
        });
    }
    
    function updateImageOrder() {
        const imageItems = document.querySelectorAll('.image-item');
        const order = Array.from(imageItems).map(item => item.dataset.imageId).join(',');
        document.getElementById('imageOrder').value = order;
    }

    // ============ PRICE & STOCK VALIDATION ============
    
    const priceInput = document.querySelector('input[name="Price"]');
    const stockInput = document.querySelector('input[name="Stock"]');

    // Prevent negative price input in real-time
    priceInput.addEventListener('input', function() {
        let value = parseFloat(this.value) || 0;
        if (value < 0.01) {
            this.value = '';
        }
    });

    priceInput.addEventListener('blur', function() {
        if (!this.value || parseFloat(this.value) < 0.01) {
            this.value = '0.01';
        }
    });

    // Prevent negative price on paste
    priceInput.addEventListener('paste', function(e) {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text');
        const value = parseFloat(text);
        if (!isNaN(value) && value >= 0.01) {
            this.value = value.toFixed(2);
        } else {
            this.value = '0.01';
        }
    });

    // Prevent negative stock input in real-time
    stockInput.addEventListener('input', function() {
        let value = parseInt(this.value) || 0;
        if (value < 0) {
            this.value = '';
        }
    });

    stockInput.addEventListener('blur', function() {
        if (!this.value || parseInt(this.value) < 0) {
            this.value = '0';
        }
    });

    // Prevent negative stock on paste
    stockInput.addEventListener('paste', function(e) {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData('text');
        const value = parseInt(text);
        if (!isNaN(value) && value >= 0) {
            this.value = value;
        } else {
            this.value = '0';
        }
    });

    // Validate form on submit
    document.querySelector('form').addEventListener('submit', function(e) {
        const price = parseFloat(priceInput.value);
        const stock = parseInt(stockInput.value);

        if (!priceInput.value || isNaN(price) || price <= 0) {
            e.preventDefault();
            alert('❌ Price must be greater than 0!');
            priceInput.focus();
            return false;
        }

        if (!stockInput.value || isNaN(stock) || stock < 0) {
            e.preventDefault();
            alert('❌ Stock quantity cannot be negative!');
            stockInput.focus();
            return false;
        }
        
        // Update image order before submitting
        updateImageOrder();
        return true;
    });

    // ============ IMAGE VIEWING & EDITING ============
    
    let currentImageId = null;
    let cropper = null;
    
    function viewImage(imageUrl, imageId) {
        currentImageId = imageId;
        const modal = document.getElementById('viewImageModal');
        const img = modal.querySelector('#viewImagePreview');
        img.src = imageUrl;
        modal.classList.remove('tw-hidden');
    }
    
    function editImage(imageUrl, imageId) {
        currentImageId = imageId;
        const modal = document.getElementById('editImageModal');
        const img = modal.querySelector('#cropImage');
        img.src = imageUrl;
        modal.classList.remove('tw-hidden');
        
        // Initialize cropper
        if (cropper) {
            cropper.destroy();
        }
        
        setTimeout(() => {
            cropper = new Cropper(img, {
                aspectRatio: NaN,
                viewMode: 1,
                autoCropArea: 1,
                responsive: true,
                restore: true,
                guides: true,
                center: true,
                highlight: true,
                cropBoxMovable: true,
                cropBoxResizable: true,
                toggleDragModeOnDblclick: true,
                background: false,
                zoom: function(e) {
                    // Update zoom display when user scrolls
                    updateZoomDisplay();
                },
                crop: function(e) {
                    // Update zoom display when crop box is moved or resized
                    updateZoomDisplay();
                },
                ready: function() {
                    // Initialize zoom display
                    updateZoomDisplay();
                }
            });
            
            // Add zoom controls
            const zoomControls = document.getElementById('zoomControls');
            if (zoomControls) {
                document.getElementById('zoomInBtn').addEventListener('click', () => {
                    cropper.zoom(0.1);
                });
                document.getElementById('zoomOutBtn').addEventListener('click', () => {
                    cropper.zoom(-0.1);
                });
            }
        }, 100);
    }
    
    function updateZoomDisplay() {
        if (!cropper) return;
        const zoomLevel = Math.round(cropper.getCanvasData().width / cropper.getImageData().width * 100);
        const display = document.getElementById('zoomDisplay');
        if (display) {
            display.textContent = `Zoom: ${zoomLevel}%`;
        }
    }
    
    function closeViewModal() {
        document.getElementById('viewImageModal').classList.add('tw-hidden');
    }
    
    function closeEditModal() {
        document.getElementById('editImageModal').classList.add('tw-hidden');
        if (cropper) {
            cropper.destroy();
            cropper = null;
        }
    }
    
    function saveCroppedImage() {
        if (!cropper) return;
        
        const canvas = cropper.getCroppedCanvas({
            maxWidth: 1200,
            maxHeight: 1200,
            imageSmoothingEnabled: true,
            imageSmoothingQuality: 'high',
        });
        
        // Convert to blob and upload
        canvas.toBlob((blob) => {
            const formData = new FormData();
            formData.append('imageId', currentImageId);
            formData.append('file', blob, 'cropped-image.jpg');
            
            // Show loading
            const btn = document.getElementById('saveCropBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split tw-animate-spin"></i> Saving...';
            
            fetch('/Seller/Dashboard/SaveCroppedImage', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    alert('✅ Image updated successfully!');
                    location.reload();
                } else {
                    alert(data.message || '❌ Failed to save image');
                }
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check2"></i> Save Cropped Image';
            })
            .catch(e => {
                console.error(e);
                alert('❌ Error saving image');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check2"></i> Save Cropped Image';
            });
        }, 'image/jpeg', 0.95);
    }
</script>

<!-- Image View Modal -->
<div id="viewImageModal" class="tw-hidden tw-fixed tw-inset-0 tw-bg-black/50 tw-flex tw-items-center tw-justify-center tw-z-50 tw-p-4">
    <div class="tw-bg-white tw-rounded-2xl tw-max-w-2xl tw-w-full tw-shadow-2xl tw-overflow-hidden">
        <!-- Header -->
        <div class="tw-flex tw-items-center tw-justify-between tw-p-4 tw-bg-slate-100 tw-border-b tw-border-slate-200">
            <h3 class="tw-text-lg tw-font-bold tw-text-slate-800">View Image</h3>
            <button onclick="closeViewModal()" class="tw-text-slate-400 hover:tw-text-slate-600 tw-transition-colors">
                <i class="bi bi-x-lg tw-text-xl"></i>
            </button>
        </div>
        
        <!-- Content -->
        <div class="tw-p-6 tw-text-center tw-bg-slate-50">
            <img id="viewImagePreview" src="" class="tw-w-full tw-h-auto tw-max-h-96 tw-object-contain tw-rounded-lg" />
        </div>
        
        <!-- Footer -->
        <div class="tw-p-4 tw-bg-slate-100 tw-border-t tw-border-slate-200 tw-flex tw-justify-end">
            <button onclick="closeViewModal()" class="tw-px-4 tw-py-2 tw-bg-slate-500 hover:tw-bg-slate-600 tw-text-white tw-rounded-lg tw-font-medium tw-transition-all">
                Close
            </button>
        </div>
    </div>
</div>

<!-- Image Edit/Crop Modal -->
<div id="editImageModal" class="tw-hidden tw-fixed tw-inset-0 tw-bg-black/50 tw-flex tw-items-center tw-justify-center tw-z-50 tw-p-4">
    <div class="tw-bg-white tw-rounded-2xl tw-max-w-3xl tw-w-full tw-shadow-2xl tw-overflow-hidden tw-max-h-[90vh] tw-flex tw-flex-col">
        <!-- Header -->
        <div class="tw-flex tw-items-center tw-justify-between tw-p-4 tw-bg-gradient-to-r tw-from-amber-100 tw-to-orange-100 tw-border-b tw-border-amber-200">
            <div>
                <h3 class="tw-text-lg tw-font-bold tw-text-slate-800">Crop & Resize Image</h3>
                <p class="tw-text-xs tw-text-slate-600 tw-mt-1">Drag to crop, scroll to zoom • Move selection box to zoom view</p>
            </div>
            <button onclick="closeEditModal()" class="tw-text-slate-400 hover:tw-text-slate-600 tw-transition-colors">
                <i class="bi bi-x-lg tw-text-xl"></i>
            </button>
        </div>
        
        <!-- Zoom Controls & Info -->
        <div id="zoomControls" class="tw-flex tw-items-center tw-justify-between tw-px-6 tw-py-3 tw-bg-white tw-border-b tw-border-slate-200">
            <div class="tw-flex tw-items-center tw-gap-2">
                <button id="zoomOutBtn" class="tw-w-8 tw-h-8 tw-rounded tw-bg-slate-100 hover:tw-bg-slate-200 tw-flex tw-items-center tw-justify-center tw-transition-colors tw-text-slate-600">
                    <i class="bi bi-dash-lg tw-text-sm"></i>
                </button>
                <span id="zoomDisplay" class="tw-px-3 tw-py-1 tw-bg-slate-100 tw-rounded tw-text-xs tw-font-bold tw-text-slate-700 tw-min-w-[70px] tw-text-center">Zoom: 100%</span>
                <button id="zoomInBtn" class="tw-w-8 tw-h-8 tw-rounded tw-bg-slate-100 hover:tw-bg-slate-200 tw-flex tw-items-center tw-justify-center tw-transition-colors tw-text-slate-600">
                    <i class="bi bi-plus-lg tw-text-sm"></i>
                </button>
            </div>
            <div class="tw-text-xs tw-text-slate-500 tw-italic">
                💡 Tip: Use scroll wheel or +/- buttons to zoom. Drag the selection box to see zoomed view.
            </div>
        </div>
        
        <!-- Content -->
        <div class="tw-flex-1 tw-overflow-auto tw-p-6 tw-bg-slate-50">
            <div class="tw-bg-white tw-rounded-lg tw-overflow-hidden tw-border tw-border-slate-200">
                <img id="cropImage" src="" class="tw-w-full" style="max-height: 500px;" />
            </div>
        </div>
        
        <!-- Footer -->
        <div class="tw-p-4 tw-bg-slate-100 tw-border-t tw-border-slate-200 tw-flex tw-justify-between">
            <div class="tw-flex tw-gap-2">
                <button onclick="closeEditModal()" class="tw-px-4 tw-py-2 tw-bg-slate-400 hover:tw-bg-slate-500 tw-text-white tw-rounded-lg tw-font-medium tw-transition-all">
                    <i class="bi bi-x"></i> Cancel
                </button>
                <button onclick="if(cropper) cropper.reset()" class="tw-px-4 tw-py-2 tw-bg-slate-500 hover:tw-bg-slate-600 tw-text-white tw-rounded-lg tw-font-medium tw-transition-all">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
            </div>
            <button id="saveCropBtn" onclick="saveCroppedImage()" class="tw-px-6 tw-py-2 tw-bg-emerald-500 hover:tw-bg-emerald-600 tw-text-white tw-rounded-lg tw-font-bold tw-transition-all hover:tw-shadow-lg">
                <i class="bi bi-check2"></i> Save Cropped Image
            </button>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
