@model Sparkle.Api.Areas.Seller.Controllers.SellerDashboardStats
@{
    ViewData["Title"] = "Overview";
}

<div class="tw-w-full tw-px-2 tw-py-2 tw-overflow-x-hidden">

<!-- Main Grid Layout: Refactored to 2 Columns -->
<div class="tw-grid tw-grid-cols-12 tw-gap-6">
    
    <!-- LEFT COLUMN (Span 8) -->
    <div class="tw-col-span-12 lg:tw-col-span-8 tw-flex tw-flex-col tw-gap-8">
        
        <!-- Total Sales Chart (Moved from old grid) -->
        <div class="tw-bg-[#0d9488] tw-rounded-[2rem] tw-p-8 tw-shadow-xl tw-text-white tw-relative tw-overflow-hidden tw-min-h-[450px] tw-flex tw-flex-col">
            <!-- Header -->
            <div class="tw-flex tw-justify-between tw-items-center tw-mb-6">
                <h2 class="tw-text-2xl tw-font-bold tw-tracking-wide">Total Sales</h2>
            </div>
            <!-- Filters (Top Right) -->
            <div class="tw-absolute tw-top-6 tw-right-6 tw-z-10">
                <div class="tw-relative tw-group">
                    <button id="chartFilterBtn" class="tw-bg-white/10 tw-backdrop-blur-md tw-text-white tw-text-xs tw-font-bold tw-px-4 tw-py-2 tw-rounded-lg tw-border tw-border-white/20 hover:tw-bg-white/20 tw-transition-all tw-flex tw-items-center tw-gap-2">
                        <span id="chartFilterLabel">Monthly</span> <i class="bi bi-chevron-down"></i>
                    </button>
                    <!-- Dropdown -->
                    <div class="tw-absolute tw-top-full tw-right-0 tw-mt-2 tw-w-32 tw-bg-white tw-rounded-xl tw-shadow-xl tw-overflow-hidden tw-opacity-0 tw-invisible group-hover:tw-opacity-100 group-hover:tw-visible tw-transition-all tw-transform group-hover:tw-translate-y-0 tw-translate-y-2 tw-z-50">
                        <a href="javascript:void(0)" onclick="updateChart('Daily')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Daily</a>
                        <a href="javascript:void(0)" onclick="updateChart('Weekly')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Weekly</a>
                        <a href="javascript:void(0)" onclick="updateChart('Monthly')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Monthly</a>
                        <a href="javascript:void(0)" onclick="updateChart('Yearly')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Yearly</a>
                    </div>
                </div>
            </div>

            <!-- Chart Area -->
            <div class="tw-flex-1 tw-w-full tw-min-h-[200px] tw-mb-6">
                <canvas id="totalSalesChart"></canvas>
            </div>

            <!-- Bottom Stats -->
            <div class="tw-grid tw-grid-cols-2 tw-gap-6 tw-mt-auto">
                <!-- Earnings -->
                <div class="tw-bg-black/20 tw-backdrop-blur-sm tw-rounded-2xl tw-p-3 tw-border tw-border-white/5">
                    <h3 class="tw-text-white/70 tw-text-[10px] tw-font-bold tw-uppercase tw-tracking-wider tw-mb-1">EARNINGS</h3>
                    <div class="tw-flex tw-items-baseline tw-gap-1">
                        <span class="tw-text-3xl tw-font-bold">৳@Model.TotalRevenue.ToString("N0")</span>
                    </div>
                    <p class="tw-text-white/50 tw-text-[10px] tw-mt-1">@DateTime.Now.ToString("MMMM yyyy")</p>
                </div>

                <!-- Total Sales Count -->
                <div class="tw-bg-black/20 tw-backdrop-blur-sm tw-rounded-2xl tw-p-3 tw-border tw-border-white/5">
                    <h3 class="tw-text-white/70 tw-text-[10px] tw-font-bold tw-uppercase tw-tracking-wider tw-mb-1">TOTAL SALES</h3>
                    <div class="tw-flex tw-items-baseline tw-gap-1">
                        <span class="tw-text-3xl tw-font-bold">@Model.TotalOrders</span>
                        <span class="tw-text-lg tw-font-medium tw-opacity-80">pcs</span>
                    </div>
                    <p class="tw-text-white/50 tw-text-[10px] tw-mt-1">@DateTime.Now.ToString("MMMM yyyy")</p>
                </div>
            </div>
        </div>

        <!-- Recent Sold (Moved here from bottom) -->
        <div class="tw-bg-white tw-rounded-[2rem] tw-p-8 tw-shadow-soft tw-border tw-border-slate-100">
            <div class="tw-flex tw-justify-between tw-items-center tw-mb-6">
                <h3 class="tw-text-xl tw-font-bold tw-text-slate-800">Recent Sold</h3>
                <!-- Recent Orders Filter Dropdown -->
                <div class="tw-relative tw-group">
                    <button class="tw-text-xs tw-font-bold tw-text-slate-500 hover:tw-text-emerald-600 tw-flex tw-items-center tw-gap-1">
                        <span id="recentOrdersFilterLabel">Last 7 Days</span> <i class="bi bi-chevron-down"></i>
                    </button>
                    <!-- Dropdown -->
                     <div class="tw-absolute tw-top-full tw-right-0 tw-mt-2 tw-w-32 tw-bg-white tw-rounded-xl tw-shadow-xl tw-overflow-hidden tw-opacity-0 tw-invisible group-hover:tw-opacity-100 group-hover:tw-visible tw-transition-all tw-transform group-hover:tw-translate-y-0 tw-translate-y-2 tw-z-50 tw-border tw-border-slate-100">
                        <a href="javascript:void(0)" onclick="updateRecentOrders('Today')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Today</a>
                        <a href="javascript:void(0)" onclick="updateRecentOrders('Yesterday')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Yesterday</a>
                        <a href="javascript:void(0)" onclick="updateRecentOrders('Last 7 Days')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Last 7 Days</a>
                        <a href="javascript:void(0)" onclick="updateRecentOrders('Last 30 Days')" class="tw-block tw-px-4 tw-py-2 tw-text-xs tw-font-bold tw-text-slate-600 hover:tw-bg-emerald-50 hover:tw-text-emerald-600 tw-transition-colors">Last 30 Days</a>
                    </div>
                </div>
            </div>
            
            <div class="tw-overflow-x-auto">
                <table class="tw-w-full">
                    <thead>
                        <tr class="tw-text-left tw-text-xs tw-font-bold tw-text-slate-400">
                            <th class="tw-pb-4">Product</th>
                            <th class="tw-pb-4">Category</th>
                            <th class="tw-pb-4">Amount</th>
                            <th class="tw-pb-4">Date</th>
                            <th class="tw-pb-4">Customer</th>
                            <th class="tw-pb-4">Status</th>
                            <th class="tw-pb-4"></th>
                        </tr>
                    </thead>
                    <tbody id="recentOrdersTableBody" class="tw-divide-y tw-divide-slate-50">
                        @foreach(var order in Model.RecentOrders.Take(5))
                        {
                            var imgUrl = !string.IsNullOrEmpty(order.FirstImageUrl) ? order.FirstImageUrl : "https://via.placeholder.com/40?text=IMG";
                            <tr class="tw-group hover:tw-bg-slate-50/50 tw-transition-colors">
                                <td class="tw-py-4">
                                    <div class="tw-flex tw-items-center tw-gap-3">
                                        <div class="tw-w-10 tw-h-10 tw-rounded-lg tw-bg-slate-100 tw-flex-shrink-0 tw-overflow-hidden">
                                            <img src="@imgUrl" class="tw-w-full tw-h-full tw-object-cover" alt="Product" />
                                        </div>
                                        <span class="tw-font-bold tw-text-sm tw-text-slate-800 line-clamp-1">@order.FirstProductName</span>
                                    </div>
                                </td>
                                <td class="tw-py-4 tw-text-xs tw-font-bold tw-text-slate-500">@order.FirstCategoryName</td>
                                <td class="tw-py-4 tw-text-sm tw-font-bold tw-text-slate-800">@order.Total.ToString("N0") TK</td>
                                <td class="tw-py-4 tw-text-xs tw-font-bold tw-text-slate-500">@order.Date.ToString("dd/MM/yyyy")</td>
                                <td class="tw-py-4 tw-text-xs tw-font-bold tw-text-slate-800">@order.CustomerName</td>
                                <td class="tw-py-4">
                                    @{
                                        var statusClass = order.Status == "Completed" ? "tw-bg-emerald-100 tw-text-emerald-600" :
                                                          order.Status == "Shipped" ? "tw-bg-orange-100 tw-text-orange-600" :
                                                          "tw-bg-indigo-100 tw-text-indigo-600";
                                    }
                                    <span class="tw-px-3 tw-py-1 tw-rounded-full tw-text-[10px] tw-font-bold @statusClass">
                                        @order.Status
                                    </span>
                                </td>
                                <td class="tw-py-4 tw-text-right">
                                    <button class="tw-text-slate-400 hover:tw-text-slate-600">
                                        <i class="bi bi-three-dots"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!Model.RecentOrders.Any())
                        {
                             <tr>
                                <td colspan="7" class="tw-py-8 tw-text-center tw-text-slate-400 tw-text-sm tw-font-bold">No recent orders found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    <!-- RIGHT COLUMN (Span 4) -->
    <div class="tw-col-span-12 lg:tw-col-span-4 tw-flex tw-flex-col tw-gap-8">
        
        <!-- Balance & Quick Stats (Moved from old grid) -->
        <div class="tw-bg-white/60 tw-backdrop-blur-xl tw-border tw-border-white/40 tw-rounded-[2rem] tw-p-6 tw-shadow-xl tw-flex tw-flex-col tw-relative tw-overflow-hidden">
            <!-- Decorative gradient blur behind -->
            <div class="tw-absolute tw-top-0 tw-right-0 tw-w-24 tw-h-24 tw-bg-gradient-to-br tw-from-emerald-400/20 tw-to-transparent tw-rounded-full tw-blur-2xl -tw-mr-8 -tw-mt-8 tw-pointer-events-none"></div>

            <!-- Balance Section (Split Layout) -->
            <div class="tw-flex tw-items-stretch tw-mb-6 tw-border-b tw-border-slate-100 tw-pb-6">
                <!-- Left: Info -->
                <div class="tw-w-[70%] tw-pr-4 tw-border-r tw-border-slate-200 tw-flex tw-flex-col tw-justify-center">
                    <div class="tw-w-14 tw-h-14 tw-bg-emerald-50/80 tw-text-emerald-500 tw-rounded-2xl tw-flex tw-items-center tw-justify-center tw-mb-4 tw-shadow-sm tw-backdrop-blur-sm">
                        <i class="bi bi-wallet2 tw-text-2xl"></i>
                    </div>
                    
                    <h3 class="tw-text-slate-500 tw-text-xs tw-font-bold tw-uppercase tw-tracking-wider tw-mb-2">CURRENT BALANCE</h3>
                    <div class="tw-flex tw-items-baseline tw-gap-1 tw-mb-1">
                        <h2 class="tw-text-5xl tw-font-black tw-text-slate-800 tw-tracking-tight">
                            @Model.AvailableBalance.ToString("N2")
                        </h2>
                        <span class="tw-text-slate-400 tw-text-sm tw-font-bold">TK</span>
                    </div>
                    <p class="tw-text-slate-400 tw-text-[10px] tw-flex tw-items-center tw-gap-1.5 tw-mt-2">
                        <i class="bi bi-clock-history"></i> Updated ~10m
                    </p>
                </div>

                <!-- Right: Button (Centered) -->
                <div class="tw-w-[30%] tw-pl-4 tw-flex tw-flex-col tw-items-center tw-justify-center">
                    <button class="tw-w-full tw-mt-8 tw-bg-[#0d9488] hover:tw-bg-[#0f766e] tw-text-white tw-font-bold tw-py-4 tw-rounded-2xl tw-text-sm tw-shadow-lg tw-shadow-teal-500/20 tw-transition-all tw-flex tw-items-center tw-justify-center tw-gap-2 tw-group">
                        <span>Withdraw</span>
                        <span class="tw-bg-white/20 tw-rounded-lg tw-p-1 tw-flex tw-items-center tw-justify-center group-hover:tw-rotate-45 tw-transition-transform">
                            <i class="bi bi-arrow-up-right-short tw-text-lg"></i>
                        </span>
                    </button>
                    <!-- Timestamp moved to left -->
                </div>
            </div>

            <!-- Quick Stats Row (Integrated) -->
            <div class="tw-grid tw-grid-cols-3 tw-gap-3 tw-pb-2 tw-mt-6">
                <!-- All Product -->
                <div class="tw-bg-white/50 hover:tw-bg-white/80 tw-transition-colors tw-rounded-xl tw-p-5 tw-text-center tw-border tw-border-slate-200 tw-cursor-default">
                    <div class="tw-text-emerald-500 tw-mb-1"><i class="bi bi-box-seam tw-text-2xl"></i></div>
                    <div class="tw-text-lg tw-font-bold tw-text-slate-800 tw-leading-none tw-mb-1">@Model.TotalProducts</div>
                    <div class="tw-text-[9px] tw-font-bold tw-text-slate-400 tw-uppercase">Products</div>
                </div>

                <!-- Sales Product -->
                <div class="tw-bg-white/50 hover:tw-bg-white/80 tw-transition-colors tw-rounded-xl tw-p-5 tw-text-center tw-border tw-border-slate-200 tw-cursor-default">
                    <div class="tw-text-cyan-500 tw-mb-1"><i class="bi bi-receipt tw-text-2xl"></i></div>
                    <div class="tw-text-lg tw-font-bold tw-text-slate-800 tw-leading-none tw-mb-1">@Model.TotalOrders</div>
                    <div class="tw-text-[9px] tw-font-bold tw-text-slate-400 tw-uppercase">Sales</div>
                </div>

                <!-- New Order -->
                <div class="tw-bg-white/50 hover:tw-bg-white/80 tw-transition-colors tw-rounded-xl tw-p-5 tw-text-center tw-border tw-border-slate-200 tw-cursor-default">
                    <div class="tw-text-emerald-600 tw-mb-1"><i class="bi bi-bag-plus tw-text-2xl"></i></div>
                    <div class="tw-text-lg tw-font-bold tw-text-slate-800 tw-leading-none tw-mb-1">@Model.NewProductsCount</div>
                    <div class="tw-text-[9px] tw-font-bold tw-text-slate-400 tw-uppercase">New</div>
                </div>
            </div>
        </div>

        <!-- Top Products (Side Widget) - Now stacks directly under Balance Card -->
        <div class="tw-bg-white tw-rounded-[2rem] tw-p-8 tw-shadow-soft tw-border tw-border-slate-100 tw-flex-1">
            <h3 class="tw-text-xl tw-font-bold tw-text-slate-800 tw-mb-6">Top Products</h3>
            
            <div class="tw-space-y-4">
                @foreach(var product in Model.TopProducts.Take(5))
                {
                    <div class="tw-flex tw-items-center tw-justify-between tw-group tw-cursor-pointer tw-p-2 tw-rounded-xl hover:tw-bg-emerald-50 tw-transition-colors">
                        <div class="tw-flex tw-items-center tw-gap-3">
                             <div class="tw-w-10 tw-h-10 tw-rounded-full tw-bg-emerald-50 tw-flex tw-items-center tw-justify-center tw-text-emerald-500 tw-overflow-hidden">
                                 @if(!string.IsNullOrEmpty(product.ImageUrl)) {
                                    <img src="@product.ImageUrl" class="tw-w-full tw-h-full tw-object-cover" />
                                 } else {
                                    <i class="bi bi-box-seam"></i>
                                 }
                             </div>
                             <div class="tw-flex tw-flex-col">
                                 <span class="tw-font-bold tw-text-sm tw-text-slate-600 group-hover:tw-text-emerald-600 tw-transition-colors line-clamp-1">@product.ProductName</span>
                                 <span class="tw-text-[10px] tw-font-bold tw-text-slate-400">@product.Revenue.ToString("N0") TK</span>
                             </div>
                        </div>
                        <span class="tw-font-bold tw-text-sm tw-text-emerald-500">@product.OrderCount</span>
                    </div>
                }
                 @if (!Model.TopProducts.Any())
                {
                    <div class="tw-text-center tw-py-8 tw-text-slate-400 tw-text-sm tw-font-bold">No top products yet.</div>
                }
            </div>
        </div>
    </div>

</div>

<script>
    let myChart;

    document.addEventListener('DOMContentLoaded', function() {
        const ctx = document.getElementById('totalSalesChart');
        if (!ctx) return; // Exit if canvas not found
        
        const chartData = @Json.Serialize(Model.SalesChartData);
        
        // Validate data exists
        if (!chartData || chartData.length === 0) {
            console.warn('No chart data available');
            return;
        }
        
        // Create gradient
        let gradient = ctx.getContext('2d').createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(255, 255, 255, 0.4)');
        gradient.addColorStop(1, 'rgba(255, 255, 255, 0.0)');

        // Map data with correct property names (C# serializes with PascalCase by default)
        const labels = chartData.map(d => d.date || d.Date || '');
        const dataPoints = chartData.map(d => d.sales !== undefined ? d.sales : (d.Sales || 0));

        // Create chart
        myChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Sales',
                    data: dataPoints,
                    backgroundColor: '#ffffff',
                    hoverBackgroundColor: 'rgba(255, 255, 255, 0.8)',
                    borderRadius: 4,
                    barPercentage: 0.6,
                    categoryPercentage: 0.8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#0f766e',
                        bodyColor: '#115e59',
                        padding: 10,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return '৳ ' + context.parsed.y.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false, drawBorder: true },
                        ticks: { 
                            color: '#ffffff', 
                            font: { size: 12, family: "'Inter', sans-serif", weight: '500' },
                            padding: 10
                        },
                        border: { display: true, color: 'rgba(255,255,255,0.2)' }
                    },
                    y: {
                        grid: { color: 'rgba(255,255,255,0.1)', drawBorder: true },
                        ticks: { 
                            display: true,
                            color: '#ffffff', 
                            font: { size: 10, family: "'Inter', sans-serif", weight: '500' },
                            callback: function(value) { 
                                if (value >= 1000) return '৳' + (value/1000).toFixed(0) + 'k';
                                return '৳' + value;
                            },
                            padding: 10,
                            maxTicksLimit: 6
                        },
                        beginAtZero: true,
                        border: { display: true, color: 'rgba(255,255,255,0.2)' }
                    }
                }
            }
        });
    });

    async function updateChart(filter) {
        // Update Button Text
        document.getElementById('chartFilterLabel').innerText = filter;
        
        // Fetch new data
        try {
            // Add timestamp to prevent caching
            const response = await fetch(`/Seller/Dashboard/GetSalesChartData?filter=${filter}&t=${new Date().getTime()}`);
            if (!response.ok) throw new Error('Network response was not ok');
            
            const data = await response.json();
            
            // Update Chart Data (Handle mixed casing)
            const newLabels = data.map(d => d.date || d.Date);
            const newData = data.map(d => d.sales || d.Sales);
            
            myChart.data.labels = newLabels;
            myChart.data.datasets[0].data = newData;
            myChart.update();
            
        } catch (error) {
            console.error('Error fetching chart data:', error);
        }
    }

    async function updateRecentOrders(filter) {
        // Update Button Text
        document.getElementById('recentOrdersFilterLabel').innerText = filter;
        
        // Fetch new data
        try {
            const response = await fetch(`/Seller/Dashboard/GetRecentOrders?filter=${filter}`);
            if (!response.ok) throw new Error('Network response was not ok');
            
            const data = await response.json();
            const tbody = document.getElementById('recentOrdersTableBody');
            
            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="tw-py-8 tw-text-center tw-text-slate-400 tw-text-sm tw-font-bold">No recent orders found.</td></tr>`;
                return;
            }

            tbody.innerHTML = data.map(order => {
                // Handle potentially null/undefined properties safely
                const imgUrl = order.firstImageUrl || order.FirstImageUrl || "https://via.placeholder.com/40?text=IMG";
                const dateVal = order.date || order.Date;
                const totalVal = order.total || order.Total || 0;
                const statusVal = order.status || order.Status || "Pending";
                const productName = order.firstProductName || order.FirstProductName || "Unknown";
                const categoryName = order.firstCategoryName || order.FirstCategoryName || "General";
                const customerName = order.customerName || order.CustomerName || "Guest";

                const date = new Date(dateVal).toLocaleDateString("en-GB"); // dd/MM/yyyy
                const total = totalVal.toLocaleString("en-US", {minimumFractionDigits: 0, maximumFractionDigits: 0});
                
                let statusClass = "tw-bg-indigo-100 tw-text-indigo-600";
                if (statusVal === "Completed" || statusVal === "Delivered") statusClass = "tw-bg-emerald-100 tw-text-emerald-600";
                else if (statusVal === "Shipped") statusClass = "tw-bg-orange-100 tw-text-orange-600";

                return `
                    <tr class="tw-group hover:tw-bg-slate-50/50 tw-transition-colors">
                        <td class="tw-py-4">
                            <div class="tw-flex tw-items-center tw-gap-3">
                                <div class="tw-w-10 tw-h-10 tw-rounded-lg tw-bg-slate-100 tw-flex-shrink-0 tw-overflow-hidden">
                                    <img src="${imgUrl}" class="tw-w-full tw-h-full tw-object-cover" alt="Product" />
                                </div>
                                <span class="tw-font-bold tw-text-sm tw-text-slate-800 line-clamp-1">${productName}</span>
                            </div>
                        </td>
                        <td class="tw-py-4 tw-text-xs tw-font-bold tw-text-slate-500">${categoryName}</td>
                        <td class="tw-py-4 tw-text-sm tw-font-bold tw-text-slate-800">${total} TK</td>
                        <td class="tw-py-4 tw-text-xs tw-font-bold tw-text-slate-500">${date}</td>
                        <td class="tw-py-4 tw-text-xs tw-font-bold tw-text-slate-800">${customerName}</td>
                        <td class="tw-py-4">
                            <span class="tw-px-3 tw-py-1 tw-rounded-full tw-text-[10px] tw-font-bold ${statusClass}">
                                ${statusVal}
                            </span>
                        </td>
                        <td class="tw-py-4 tw-text-right">
                            <button class="tw-text-slate-400 hover:tw-text-slate-600">
                                <i class="bi bi-three-dots"></i>
                            </button>
                        </td>
                    </tr>
                `;
            }).join('');
            
        } catch (error) {
            console.error('Error fetching recent orders:', error);
        }
    }
</script>
</div>
