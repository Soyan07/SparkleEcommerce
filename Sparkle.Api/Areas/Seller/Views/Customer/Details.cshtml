@model Sparkle.Api.Areas.Seller.Models.CustomerViewModel

@{
    ViewData["Title"] = "Customer Details";
}

<div class="tw-mb-6 tw-flex tw-items-center tw-justify-between">
    <div>
        <h1 class="tw-text-2xl tw-font-bold tw-text-slate-800">Customer Details</h1>
        <p class="tw-text-slate-500 tw-text-sm">View customer purchase history and communication</p>
    </div>
    <a asp-action="Index" class="tw-px-4 tw-py-2 tw-border tw-border-slate-200 tw-rounded-lg tw-text-sm hover:tw-bg-slate-50 tw-transition-colors">
        <i class="bi bi-arrow-left tw-mr-2"></i> Back to List
    </a>
</div>

<div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-6">
    <!-- Customer Profile -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
       <div class="tw-flex tw-flex-col tw-items-center tw-text-center tw-mb-6">
            <div class="tw-w-20 tw-h-20 tw-bg-blue-100 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-mb-3">
                <span class="tw-text-blue-600 tw-font-bold tw-text-2xl">@Model.Name.Substring(0, Math.Min(2, Model.Name.Length)).ToUpper()</span>
            </div>
            <h3 class="tw-font-bold tw-text-xl tw-text-slate-900">@Model.Name</h3>
            <p class="tw-text-sm tw-text-slate-500">Customer since @Model.LastOrderDate.ToString("MMM yyyy")</p>
        </div>

        <div class="tw-space-y-3 tw-mb-6">
            <div class="tw-flex tw-items-center tw-gap-3 tw-text-sm">
                <i class="bi bi-envelope tw-text-slate-400"></i>
                <span class="tw-text-slate-600">@Model.Email</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.Phone))
            {
                <div class="tw-flex tw-items-center tw-gap-3 tw-text-sm">
                    <i class="bi bi-telephone tw-text-slate-400"></i>
                    <span class="tw-text-slate-600">@Model.Phone</span>
                </div>
            }
        </div>

        <!-- Statistics -->
        <div class="tw-grid tw-grid-cols-2 tw-gap-3">
            <div class="tw-bg-blue-50 tw-border tw-border-blue-200 tw-rounded-lg tw-p-3 tw-text-center">
                <div class="tw-text-2xl tw-font-bold tw-text-blue-900">@Model.TotalOrders</div>
                <div class="tw-text-xs tw-text-blue-600 tw-mt-1">Total Orders</div>
            </div>
            <div class="tw-bg-green-50 tw-border tw-border-green-200 tw-rounded-lg tw-p-3 tw-text-center">
                <div class="tw-text-2xl tw-font-bold tw-text-green-900">৳@Model.TotalSpent.ToString("N0")</div>
                <div class="tw-text-xs tw-text-green-600 tw-mt-1">Total Spent</div>
            </div>
        </div>

        <!-- Actions -->
        <div class="tw-mt-6 tw-pt-6 tw-border-t tw-border-slate-100">
            <button class="tw-w-full tw-px-4 tw-py-2 tw-bg-blue-600 tw-text-white tw-rounded-lg tw-text-sm hover:tw-bg-blue-700 tw-transition-colors tw-mb-2">
                <i class="bi bi-chat-dots tw-mr-2"></i> Send Message
            </button>
            <button class="tw-w-full tw-px-4 tw-py-2 tw-border tw-border-slate-200 tw-rounded-lg tw-text-sm hover:tw-bg-slate-50 tw-transition-colors">
                <i class="bi bi-tag tw-mr-2"></i> Add Note
            </button>
        </div>
    </div>

    <!-- Order History & Activity -->
    <div class="lg:tw-col-span-2 tw-space-y-6">
        <!-- Recent Orders -->
        <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
            <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Order History</h3>
            <div class="tw-space-y-4">
                <div class="tw-text-muted tw-text-center tw-py-8">
                    <i class="bi bi-box tw-text-4xl tw-text-slate-300 tw-mb-2 tw-block"></i>
                    <p class="tw-text-slate-500">Order details would be displayed here</p>
                    <p class="tw-text-sm tw-text-slate-400 tw-mt-1">Showing orders from this customer</p>
                </div>
            </div>
        </div>

        <!-- Communication Timeline -->
        <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
            <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Communication Timeline</h3>
            <div class="tw-space-y-4">
                <div class="tw-text-center tw-py-8">
                    <i class="bi bi-chat-left-text tw-text-4xl tw-text-slate-300 tw-mb-2 tw-block"></i>
                    <p class="tw-text-slate-500">No messages yet</p>
                    <p class="tw-text-sm tw-text-slate-400 tw-mt-1">Start a conversation with this customer</p>
                </div>
            </div>
        </div>

        <!-- Notes -->
        <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
            <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Notes & Tags</h3>
            <div class="tw-space-y-3">
                <textarea class="tw-w-full tw-px-4 tw-py-2 tw-border tw-border-slate-200 tw-rounded-lg tw-outline-none focus:tw-border-blue-500" rows="3" placeholder="Add private notes about this customer..."></textarea>
                <div class="tw-flex tw-gap-2">
                    <input type="text" class="tw-flex-1 tw-px-4 tw-py-2 tw-border tw-border-slate-200 tw-rounded-lg tw-outline-none focus:tw-border-blue-500 tw-text-sm" placeholder="Add tag..." />
                    <button class="tw-px-4 tw-py-2 tw-bg-blue-600 tw-text-white tw-rounded-lg tw-text-sm hover:tw-bg-blue-700 tw-transition-colors">
                        Add
                    </button>
                </div>
                <div class="tw-flex tw-flex-wrap tw-gap-2 tw-mt-3">
                    <span class="tw-px-3 tw-py-1 tw-bg-blue-100 tw-text-blue-800 tw-rounded-full tw-text-sm">
                        VIP <button class="tw-ml-1">×</button>
                    </span>
                    <span class="tw-px-3 tw-py-1 tw-bg-green-100 tw-text-green-800 tw-rounded-full tw-text-sm">
                        Repeat Customer <button class="tw-ml-1">×</button>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
