@{
    ViewData["Title"] = "Help & Support";
}

<div class="tw-mb-6">
    <h1 class="tw-text-2xl tw-font-bold tw-text-slate-800">Help & Support</h1>
    <p class="tw-text-slate-500 tw-text-sm">Get help with your seller account.</p>
</div>

<div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-6">
    <!-- FAQs -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Common Questions</h3>
        <ul class="tw-space-y-4">
            <li class="tw-pb-4 tw-border-b tw-border-slate-50 last:tw-border-0">
                <p class="tw-font-medium tw-text-slate-800 tw-mb-1">How do I get paid?</p>
                <p class="tw-text-sm tw-text-slate-500">Payments are processed weekly directly to your linked bank account or mobile wallet.</p>
            </li>
            <li class="tw-pb-4 tw-border-b tw-border-slate-50 last:tw-border-0">
                <p class="tw-font-medium tw-text-slate-800 tw-mb-1">How to handle returns?</p>
                <p class="tw-text-sm tw-text-slate-500">Go to the Orders page and select the order usage to approve return requests.</p>
            </li>
        </ul>
    </div>

    <!-- Contact Support -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Contact Support</h3>
        <p class="tw-text-sm tw-text-slate-500 tw-mb-6">Need urgent help? Our team is available 24/7.</p>
        
        <div class="tw-space-y-3">
            <a href="#" class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-rounded-lg tw-bg-blue-50 tw-text-blue-700 hover:tw-bg-blue-100 tw-transition-colors tw-no-underline">
                <i class="bi bi-envelope-fill"></i>
                <span class="tw-font-medium tw-text-sm">Email Support</span>
            </a>
            <a href="#" class="tw-flex tw-items-center tw-gap-3 tw-p-3 tw-rounded-lg tw-bg-green-50 tw-text-green-700 hover:tw-bg-green-100 tw-transition-colors tw-no-underline">
                <i class="bi bi-whatsapp"></i>
                <span class="tw-font-medium tw-text-sm">WhatsApp Chat</span>
            </a>
        </div>
    </div>
</div>
