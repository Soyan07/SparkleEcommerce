@model List<Sparkle.Domain.Support.Chat>
@{
    ViewData["Title"] = "Customer Messages";
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
    var unreadCount = ViewBag.UnreadCount ?? 0;
}

<div class="tw-bg-white tw-rounded-2xl tw-shadow-sm tw-border tw-border-slate-100 tw-overflow-hidden">
    <div class="tw-px-6 tw-py-4 tw-border-b tw-border-slate-100 tw-flex tw-justify-between tw-items-center">
        <h5 class="tw-font-bold tw-text-slate-800 tw-mb-0 tw-text-lg">
            <i class="bi bi-chat-text-fill tw-mr-2 tw-text-orange-500"></i> Customer Messages
        </h5>
        @if (unreadCount > 0)
        {
            <span class="tw-bg-red-500 tw-text-white tw-text-xs tw-font-bold tw-px-2.5 tw-py-1 tw-rounded-full">
                @unreadCount unread
            </span>
        }
    </div>

    @if (Model.Any())
    {
        <div class="tw-divide-y tw-divide-slate-50">
            @foreach (var chat in Model)
            {
                var lastMessage = chat.Messages.FirstOrDefault();
                var isUnread = chat.SellerUnreadCount > 0;
                var customerName = chat.User?.FullName ?? "Customer";

                <a href="@Url.Action("Conversation", new { id = chat.Id })" 
                   class="tw-block tw-p-5 hover:tw-bg-slate-50 tw-transition-colors tw-group @(isUnread ? "tw-bg-orange-50/30" : "")"
                   style="text-decoration: none; color: inherit;">
                    
                    <div class="tw-flex tw-gap-4">
                        <!-- Avatar -->
                        <div class="tw-relative tw-flex-shrink-0">
                            <div class="tw-w-12 tw-h-12 tw-rounded-xl tw-bg-gradient-to-br tw-from-orange-400 tw-to-orange-600 tw-flex tw-items-center tw-justify-center tw-text-white tw-font-bold tw-text-xl tw-shadow-md tw-shadow-orange-500/20">
                                @customerName.Substring(0, 1).ToUpper()
                            </div>
                            @if (isUnread)
                            {
                                <span class="tw-absolute -tw-top-1 -tw-right-1 tw-w-4 tw-h-4 tw-bg-red-500 tw-border-2 tw-border-white tw-rounded-full"></span>
                            }
                        </div>

                        <!-- Content -->
                        <div class="tw-flex-1 tw-min-w-0">
                            <div class="tw-flex tw-justify-between tw-items-start tw-mb-1">
                                <h6 class="tw-font-bold tw-text-slate-800 tw-truncate tw-mb-0 group-hover:tw-text-orange-600 tw-transition-colors">
                                    @customerName
                                </h6>
                                <span class="tw-text-xs tw-text-slate-400 tw-whitespace-nowrap tw-ml-2">
                                    @FormatTime(chat.LastMessageAt)
                                </span>
                            </div>

                            <div class="tw-flex tw-justify-between tw-items-center">
                                <p class="tw-text-sm tw-truncate tw-mb-0 tw-pr-4 @(isUnread ? "tw-font-bold tw-text-slate-800" : "tw-text-slate-500")">
                                    @if (lastMessage != null)
                                    {
                                        if (lastMessage.IsDeleted)
                                        {
                                            <span class="tw-italic tw-text-slate-400">
                                                <i class="bi bi-slash-circle tw-mr-1"></i>This message was unsent
                                            </span>
                                        }
                                        else
                                        {
                                            <span>
                                                @(lastMessage.IsSeller ? "You: " : "")@(lastMessage.Content.Length>50?lastMessage.Content[..50]+"…":lastMessage.Content)
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="tw-italic tw-text-slate-400">No messages yet</span>
                                    }
                                </p>
                                @if (isUnread)
                                {
                                    <span class="tw-bg-orange-500 tw-text-white tw-text-xs tw-font-bold tw-px-2 tw-py-0.5 tw-rounded-full tw-shadow-sm tw-shadow-orange-500/30">
                                        @chat.SellerUnreadCount
                                    </span>
                                }
                            </div>

                            @if (chat.Product != null)
                            {
                                <div class="tw-mt-2 tw-inline-flex tw-items-center tw-bg-slate-100 tw-px-2 tw-py-1 tw-rounded-lg tw-text-xs tw-font-medium tw-text-slate-600">
                                    <i class="bi bi-box tw-mr-1.5 tw-text-slate-400"></i>
                                    <span class="tw-truncate tw-max-w-[200px]">@chat.Product.Title</span>
                                </div>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="tw-text-center tw-py-16 tw-px-6">
            <div class="tw-w-20 tw-h-20 tw-mx-auto tw-mb-6 tw-bg-orange-50 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-text-orange-500">
                <i class="bi bi-chat-heart-fill tw-text-4xl"></i>
            </div>
            <h4 class="tw-font-bold tw-text-slate-800 tw-mb-2">No conversations yet</h4>
            <p class="tw-text-slate-500 tw-mb-0 tw-max-w-sm tw-mx-auto">
                When customers message you about your products, they'll appear here.
            </p>
        </div>
    }
</div>

@functions {
    string FormatTime(DateTime dt)
    {
        var now = DateTime.UtcNow;
        var diff = now - dt;
        
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM d");
    }
}
