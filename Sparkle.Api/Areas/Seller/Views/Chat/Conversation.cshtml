@model Sparkle.Domain.Support.Chat
@{
    ViewData["Title"] = $"Chat with {Model.User?.FullName ?? "Customer"}";
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
    var uid = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var customerName = Model.User?.FullName ?? "Customer";
    var customerEmail = Model.User?.Email ?? "";
    var CI = customerName.Substring(0, 1).ToUpper();
}

<style>
/* Scoped resets */
.cht, .cht * { min-height:unset; }
.cht .bi { font-size:inherit !important; }
.cht h5,.cht h6 { font-size:inherit !important; margin:0; }
.cht input,.cht textarea,.cht button { min-height:unset; font-size:inherit; }

:root {
    --c-brand:#10b981; --c-brand-d:#059669;
    --c-bg:#fff; --c-bg2:#f8fafc; --c-bg3:#f1f5f9;
    --c-bdr:#e2e8f0; --c-bdr2:#f1f5f9;
    --c-tx:#0f172a; --c-tx2:#334155; --c-tx3:#64748b; --c-mt:#94a3b8;
    --c-red:#ef4444;
    --r:8px; --r2:16px; --r-full:9999px;
}

/* SHELL */
.cht {
    display:flex; flex-direction:column;
    height:calc(100vh - 160px); min-height:480px;
    border-radius:var(--r2); overflow:hidden;
    border:1px solid var(--c-bdr);
    box-shadow:0 1px 3px rgba(0,0,0,.04),0 4px 12px rgba(0,0,0,.06);
    background:var(--c-bg);
}

/* HEADER */
.ch-hd {
    display:flex; align-items:center; gap:12px;
    padding:14px 18px; border-bottom:1px solid var(--c-bdr);
    flex-shrink:0; background:var(--c-bg);
}
.ch-back {
    width:36px; height:36px; border-radius:var(--r);
    background:var(--c-bg2); color:var(--c-tx3);
    display:flex; align-items:center; justify-content:center;
    text-decoration:none; border:none; font-size:16px; flex-shrink:0;
    transition:background .12s;
}
.ch-back:hover { background:var(--c-bg3); color:var(--c-tx); }
.ch-av {
    width:42px; height:42px; border-radius:50%;
    background:linear-gradient(135deg,var(--c-brand),var(--c-brand-d));
    color:#fff; font-weight:700; font-size:16px;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.ch-info { flex:1; min-width:0; }
.ch-info h5 { font-weight:600; font-size:15px !important; color:var(--c-tx); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.ch-info p { margin:0; font-size:12px; color:var(--c-tx3); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.ch-acts { display:flex; gap:8px; flex-shrink:0; }
.ch-acts a,.ch-acts button {
    display:inline-flex; align-items:center; gap:5px;
    padding:6px 14px; border-radius:var(--r); font-size:13px; font-weight:500;
    text-decoration:none; border:1.5px solid transparent; cursor:pointer; transition:all .12s;
}
.btn-vp { background:transparent; color:var(--c-brand); border-color:var(--c-brand); }
.btn-vp:hover { background:var(--c-brand); color:#fff; }
.btn-cl { background:transparent; color:var(--c-red); border-color:var(--c-red); }
.btn-cl:hover { background:var(--c-red); color:#fff; }

/* PRODUCT BANNER */
.ch-prod {
    display:flex; align-items:center; gap:12px;
    padding:10px 18px; background:#f0fdf4; border-bottom:1px solid #bbf7d0; flex-shrink:0;
}
.ch-prod img { width:40px; height:40px; object-fit:cover; border-radius:6px; flex-shrink:0; }
.ch-prod-ic { width:40px; height:40px; background:var(--c-bg3); border-radius:6px; display:flex; align-items:center; justify-content:center; flex-shrink:0; color:var(--c-mt); }
.ch-prod-nm { font-weight:500; font-size:14px; color:var(--c-tx); }
.ch-prod-pr { color:var(--c-brand); font-weight:600; font-size:13px; }

/* MESSAGES FEED */
.ch-fd {
    flex:1; overflow-y:auto; padding:16px 18px 8px;
    display:flex; flex-direction:column; gap:8px; scroll-behavior:smooth;
}
.ch-fd::-webkit-scrollbar { width:4px; }
.ch-fd::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:3px; }

/* Date separator */
.dt-sep {
    text-align:center; color:var(--c-mt); font-size:11px; padding:4px 0;
    display:flex; align-items:center; gap:8px;
}
.dt-sep::before,.dt-sep::after { content:''; flex:1; height:1px; background:var(--c-bdr); }
.dt-sep span { background:var(--c-bg2); padding:2px 10px; border-radius:var(--r-full); border:1px solid var(--c-bdr); white-space:nowrap; }

/* Message row */
.m { display:flex; }
.m.out { justify-content:flex-end; }
.m.in { justify-content:flex-start; }
.m-av {
    width:28px; height:28px; border-radius:50%; background:var(--c-bg3);
    color:var(--c-tx3); font-size:11px; font-weight:700;
    display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-right:6px; margin-top:2px;
}
.m-w { display:flex; align-items:flex-start; gap:3px; max-width:65%; position:relative; }
.m.out .m-w { flex-direction:row-reverse; }
.m-b { display:flex; flex-direction:column; gap:1px; min-width:0; }
.m.out .m-b { align-items:flex-end; }
.m.in .m-b { align-items:flex-start; }
.bbl { padding:8px 13px; border-radius:16px; font-size:13.5px; line-height:1.45; word-break:break-word; }
.m.out .bbl { background:linear-gradient(135deg,var(--c-brand),var(--c-brand-d)); color:#fff; border-bottom-right-radius:4px; }
.m.in .bbl { background:var(--c-bg); color:var(--c-tx); border:1px solid var(--c-bdr); border-bottom-left-radius:4px; }

/* Image in bubble */
.bbl-img { border-radius:12px; max-width:220px; max-height:200px; object-fit:cover; cursor:pointer; display:block; margin:2px 0; }
/* File in bubble */
.bbl-file { display:flex; align-items:center; gap:8px; padding:6px 10px; background:rgba(255,255,255,.15); border-radius:8px; margin:3px 0; text-decoration:none; color:inherit; font-size:12px; }
.m.in .bbl-file { background:var(--c-bg2); }
.bbl-file i { font-size:16px; flex-shrink:0; }
.bbl-file-nm { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:150px; font-weight:500; }
/* Unsent */
.bbl-unsent { padding:8px 13px; border-radius:16px; font-size:13px; line-height:1.4; font-style:italic; color:var(--c-mt); background:var(--c-bg2); border:1px dashed var(--c-bdr); }
.bbl-unsent i { font-size:12px; margin-right:4px; }

/* Timestamp */
.m-t { font-size:10px; color:var(--c-mt); display:flex; align-items:center; gap:3px; padding:0 5px; }
.m.out .m-t { justify-content:flex-end; }
.m-ed { font-style:italic; }

/* Dots trigger */
.m-d { flex-shrink:0; opacity:0; pointer-events:none; transition:opacity .12s; margin-top:5px; }
.m:hover .m-d,.m-w:hover .m-d { opacity:1; pointer-events:auto; }
.m-d-b { width:20px; height:20px; border-radius:50%; background:var(--c-bg); border:1px solid var(--c-bdr); color:var(--c-mt); font-size:10px; display:flex; align-items:center; justify-content:center; cursor:pointer; padding:0; box-shadow:0 1px 3px rgba(0,0,0,.05); }
.m-d-b:hover { background:var(--c-bg2); color:var(--c-tx2); }

/* Context menu */
.m-c { position:absolute; bottom:100%; margin-bottom:4px; background:var(--c-bg); border:1px solid var(--c-bdr); border-radius:var(--r); box-shadow:0 -4px 20px rgba(0,0,0,.1); padding:4px 0; min-width:160px; z-index:50; display:none; }
.m.out .m-c { right:0; left:auto; }
.m.in .m-c { left:0; right:auto; }
.m-c.op { display:block; }
.cb { display:flex; align-items:center; gap:8px; padding:8px 14px; font-size:13px; font-weight:500; color:var(--c-tx2); background:none; border:none; width:100%; text-align:left; cursor:pointer; transition:background .1s; white-space:nowrap; }
.cb i { font-size:13px; color:var(--c-mt); width:16px; display:inline-flex; align-items:center; justify-content:center; }
.cb:hover { background:var(--c-bg2); }
.cb:hover i { color:var(--c-brand); }
.cb.dl { color:var(--c-red); }
.cb.dl i { color:#fca5a5; }
.cb.dl:hover { background:#fef2f2; }
.cb.dl:hover i { color:var(--c-red); }
.cs { height:1px; background:var(--c-bdr2); margin:2px 0; }

/* Inline edit */
.m-e { display:flex; flex-direction:column; gap:3px; width:100%; }
.m-e-ta { width:100%; padding:7px 10px; border:1.5px solid var(--c-brand); border-radius:var(--r); font-size:13px; color:var(--c-tx); background:var(--c-bg); outline:none; font-family:inherit; line-height:1.45; resize:none; min-height:30px; max-height:80px; overflow-y:auto; }
.m-e-a { display:flex; gap:3px; justify-content:flex-end; }
.m-e-b { padding:4px 10px; border-radius:6px; font-size:11px; font-weight:600; border:none; cursor:pointer; transition:background .1s; }
.m-e-b.sv { background:var(--c-brand); color:#fff; }
.m-e-b.sv:hover { background:var(--c-brand-d); }
.m-e-b.cn { background:var(--c-bg2); color:var(--c-tx3); }
.m-e-b.cn:hover { background:var(--c-bg3); }

/* INPUT BAR */
.ch-in { padding:10px 18px 14px; border-top:1px solid var(--c-bdr); background:var(--c-bg); flex-shrink:0; position:relative; z-index:10; }
.up-prog { display:none; padding:4px 0 8px; }
.up-bar { height:3px; background:var(--c-bg3); border-radius:3px; overflow:hidden; }
.up-fill { height:100%; width:0; background:var(--c-brand); transition:width .2s; border-radius:3px; }
.up-txt { font-size:10px; color:var(--c-mt); margin-top:2px; }
.fp-strip { display:none; padding:4px 0 8px; overflow-x:auto; white-space:nowrap; }
.fp-item { display:inline-block; position:relative; width:56px; height:56px; margin-right:6px; border-radius:var(--r); overflow:hidden; border:1px solid var(--c-bdr); background:var(--c-bg2); vertical-align:top; }
.fp-item img { width:100%; height:100%; object-fit:cover; }
.fp-item i { font-size:22px; display:flex; width:100%; height:100%; align-items:center; justify-content:center; color:var(--c-mt); }
.fp-rm { position:absolute; top:2px; right:2px; width:16px; height:16px; border-radius:50%; background:rgba(0,0,0,.5); color:#fff; font-size:9px; display:flex; align-items:center; justify-content:center; cursor:pointer; border:none; }
.inp-frm { display:flex; align-items:center; gap:8px; }
.inp-pl { flex:1; display:flex; align-items:center; border:1.5px solid var(--c-bdr); border-radius:26px; padding:3px 10px 3px 5px; background:var(--c-bg2); transition:border-color .15s; min-width:0; }
.inp-pl:focus-within { border-color:var(--c-brand); background:var(--c-bg); }
.bt-a { width:30px; height:30px; border-radius:50%; background:none; border:none; color:var(--c-tx3); font-size:15px; display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0; }
.bt-a:hover { background:var(--c-bg3); color:var(--c-brand); }
.cmp { flex:1; border:none; background:transparent; padding:6px 4px; font-size:14px; color:var(--c-tx); outline:none; min-width:0; resize:none; overflow-y:hidden; line-height:1.4; min-height:34px; max-height:120px; font-family:inherit; }
.cmp::placeholder { color:var(--c-mt); }
.cmp.scr { overflow-y:auto; }
.bt-s { width:38px; height:38px; border-radius:50%; background:linear-gradient(135deg,var(--c-brand),var(--c-brand-d)); color:#fff; border:none; cursor:pointer; flex-shrink:0; font-size:14px; display:flex; align-items:center; justify-content:center; transition:transform .12s,box-shadow .12s; }
.bt-s:hover { transform:scale(1.06); box-shadow:0 4px 14px rgba(16,185,129,.3); }
.at-pop { position:absolute; bottom:calc(100% + 10px); left:80px; background:var(--c-bg); border:1px solid var(--c-bdr); border-radius:12px; padding:6px; box-shadow:0 10px 25px rgba(0,0,0,.1); display:none; z-index:100; min-width:180px; animation:pIn .2s cubic-bezier(.16,1,.3,1); }
@@keyframes pIn { from{opacity:0;transform:translateY(10px) scale(.95)} to{opacity:1;transform:translateY(0) scale(1)} }
.at-o { display:flex; align-items:center; gap:10px; width:100%; padding:10px 12px; background:none; border:none; text-align:left; font-size:14px; font-weight:500; color:var(--c-tx2); border-radius:8px; cursor:pointer; transition:background .15s; }
.at-o i { color:var(--c-mt); font-size:16px; transition:color .15s; width:20px; text-align:center; }
.at-o:hover { background:var(--c-bg2); color:var(--c-brand); }
.at-o:hover i { color:var(--c-brand); }

/* CUSTOM MODAL */
.sp-overlay { position:fixed; inset:0; background:rgba(15,23,42,.4); backdrop-filter:blur(3px); z-index:9998; display:none; align-items:center; justify-content:center; }
.sp-overlay.show { display:flex; }
.sp-modal { background:var(--c-bg); border-radius:var(--r2); box-shadow:0 20px 60px rgba(0,0,0,.15); padding:28px 24px 20px; max-width:380px; width:90%; text-align:center; animation:spIn .2s ease; }
@@keyframes spIn { from{opacity:0;transform:scale(.95)} to{opacity:1;transform:scale(1)} }
.sp-modal-icon { width:52px; height:52px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:24px; margin:0 auto 14px; }
.sp-modal-icon.warn { background:#fef3c7; color:#f59e0b; }
.sp-modal-icon.danger { background:#fee2e2; color:#ef4444; }
.sp-modal-icon.info { background:#ecfdf5; color:var(--c-brand); }
.sp-modal-icon.success { background:#ecfdf5; color:var(--c-brand); }
.sp-modal h6 { font-weight:700; font-size:16px !important; color:var(--c-tx); margin-bottom:6px; }
.sp-modal p { font-size:13px; color:var(--c-tx3); line-height:1.5; margin:0 0 18px; }
.sp-modal-btns { display:flex; gap:8px; justify-content:center; }
.sp-btn { padding:8px 20px; border-radius:var(--r); font-size:13px; font-weight:600; border:none; cursor:pointer; transition:all .12s; }
.sp-btn-cancel { background:var(--c-bg2); color:var(--c-tx3); }
.sp-btn-cancel:hover { background:var(--c-bg3); }
.sp-btn-danger { background:var(--c-red); color:#fff; }
.sp-btn-danger:hover { background:#dc2626; }
.sp-btn-primary { background:var(--c-brand); color:#fff; }
.sp-btn-primary:hover { background:var(--c-brand-d); }

/* Drag over */
.ch-fd.drag-over { outline:2px dashed var(--c-brand); outline-offset:-4px; background:#f0fdf4; }
</style>

<div class="cht">
    <!-- HEADER -->
    <div class="ch-hd">
        <a href="@Url.Action("Index")" class="ch-back" title="Back"><i class="bi bi-arrow-left"></i></a>
        <div class="ch-av">@CI</div>
        <div class="ch-info">
            <h5>@customerName</h5>
            <p>@customerEmail</p>
        </div>
        <div class="ch-acts">
            @if (Model.Product != null)
            {
                <a href="@Url.Action("Product","Home",new{area="",id=Model.ProductId})" class="btn-vp"><i class="bi bi-box"></i> View Product</a>
            }
        </div>
    </div>

    <!-- PRODUCT BANNER -->
    @if (Model.Product != null)
    {
        <div class="ch-prod">
            @if (Model.Product.Images?.Any() == true)
            {
                <img src="@Model.Product.Images.First().Url" alt="@Model.Product.Title"/>
            }
            else
            {
                <div class="ch-prod-ic"><i class="bi bi-box"></i></div>
            }
            <div>
                <div class="ch-prod-nm">@Model.Product.Title</div>
                <div class="ch-prod-pr">৳@Model.Product.Price.ToString("N0")</div>
            </div>
        </div>
    }

    <!-- MESSAGES -->
    <div class="ch-fd" id="feed">
        @{DateTime? lastDate = null;}
        @foreach (var msg in Model.Messages)
        {
            var d = msg.SentAt.Date;
            if (lastDate != d)
            {
                <div class="dt-sep"><span>@FmtDate(d)</span></div>
                lastDate = d;
            }
            var mine = msg.IsSeller;
            <div class="m @(mine?"out":"in")" id="r-@msg.Id" data-id="@msg.Id">
                @if(!mine){<div class="m-av">@CI</div>}
                <div class="m-w">
                    <div class="m-b">
                        <div class="@(msg.IsDeleted ? "bbl-unsent" : "bbl")" id="bbl-@msg.Id">
                            @if(msg.IsDeleted){
                                <text><i class="bi bi-slash-circle"></i> This message was unsent</text>
                            }
                            else if(!string.IsNullOrEmpty(msg.AttachmentUrl)){
                                var isImg = System.Text.RegularExpressions.Regex.IsMatch(msg.AttachmentUrl, @"\.(jpg|jpeg|png|gif|webp|bmp)$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                                if(isImg){<img src="@msg.AttachmentUrl" class="bbl-img" onclick="window.open(this.src)"/>}
                                else{<a href="@msg.AttachmentUrl" target="_blank" class="bbl-file" download><i class="bi bi-file-earmark-arrow-down"></i><div><div class="bbl-file-nm">@msg.AttachmentUrl.Split('/').Last()</div></div></a>}
                                if(!string.IsNullOrEmpty(msg.Content)){<div style="margin-top:3px">@msg.Content</div>}
                            }else{
                                @msg.Content
                            }
                        </div>
                        <div class="m-t" id="ts-@msg.Id">
                            @msg.SentAt.ToLocalTime().ToString("h:mm tt")
                            @if(mine){<i class="bi bi-check2" style="color:var(--c-mt);font-size:10px;"></i>}
                            @if(msg.IsEdited){<span class="m-ed">&nbsp;· edited</span>}
                        </div>
                    </div>
                    @if(mine && !msg.IsDeleted){
                        <div class="m-d"><button class="m-d-b" onclick="openC(@msg.Id,event)"><i class="bi bi-three-dots"></i></button></div>
                        <div class="m-c" id="cx-@msg.Id">
                            <button class="cb" onclick="sEdit(@msg.Id)"><i class="bi bi-pencil"></i> Edit</button>
                            <div class="cs"></div>
                            <button class="cb dl" onclick="sDel(@msg.Id,'forMe')"><i class="bi bi-eye-slash"></i> Delete for me</button>
                            <button class="cb dl" onclick="sDel(@msg.Id,'forEveryone')"><i class="bi bi-trash"></i> Delete for everyone</button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- INPUT BAR -->
    <div class="ch-in">
        <div class="up-prog" id="uProg"><div class="up-bar"><div class="up-fill" id="uFill"></div></div><div class="up-txt" id="uTxt">Uploading…</div></div>
        <div class="fp-strip" id="fpS"></div>
        <form class="inp-frm" id="cF" enctype="multipart/form-data">
            <input type="file" id="fInp" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip,.rar" style="display:none"/>
            <div class="inp-pl">
                <button type="button" class="bt-a" id="emjBtn" title="Emoji"><i class="bi bi-emoji-smile"></i></button>
                <button type="button" class="bt-a" onclick="togAt()" title="Attach"><i class="bi bi-plus-lg"></i></button>
                <button type="button" class="bt-a" onclick="document.getElementById('fInp').click()" title="Photo / File"><i class="bi bi-image"></i></button>
                <textarea id="cmp" class="cmp" placeholder="Type a message…" rows="1"></textarea>
            </div>
            <button type="submit" class="bt-s" id="bS" title="Send"><i class="bi bi-send-fill"></i></button>
        </form>
        <div class="at-pop" id="aP">
            @if(Model.Product!=null){<button type="button" class="at-o" onclick="shareProd(@Model.Product.Id)"><i class="bi bi-box"></i> Share This Product</button>}
            <button type="button" class="at-o" onclick="document.getElementById('fInp').click();togAt()"><i class="bi bi-image"></i> Photo / File</button>
        </div>
    </div>
</div>

<!-- CUSTOM MODAL -->
<div class="sp-overlay" id="spModal">
    <div class="sp-modal">
        <div class="sp-modal-icon warn" id="spIcon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <h6 id="spTitle">Are you sure?</h6>
        <p id="spMsg">This action cannot be undone.</p>
        <div class="sp-modal-btns">
            <button class="sp-btn sp-btn-cancel" onclick="spClose()">Cancel</button>
            <button class="sp-btn sp-btn-danger" id="spConfirm" onclick="spClose()">Confirm</button>
        </div>
    </div>
</div>

@functions {
    string FmtDate(DateTime d){var t=DateTime.UtcNow.Date;if(d==t)return"Today";if(d==t.AddDays(-1))return"Yesterday";return d.ToString("MMM d, yyyy");}
}

@section Scripts{
<script src="https://cdn.jsdelivr.net/npm/@Html.Raw("@")emoji-mart/data"></script>
<script src="https://cdn.jsdelivr.net/npm/emoji-mart@latest/dist/browser.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>

const FD=document.getElementById('feed'), CM=document.getElementById('cmp'),
      FM=document.getElementById('cF'), BS=document.getElementById('bS'),
      FI=document.getElementById('fInp'), FPS=document.getElementById('fpS');
const CID=@Model.Id, ME='@uid', CI='@CI';
function esc(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML;}

/* scroll to bottom */
FD.scrollTop=FD.scrollHeight;

/* auto-resize textarea */
CM.addEventListener('input',()=>{
    CM.style.height='34px';
    const sh=CM.scrollHeight;
    if(sh>120){CM.style.height='120px';CM.classList.add('scr');}
    else{CM.style.height=sh+'px';CM.classList.remove('scr');}
});

/* emoji picker */
let _picker=null;
const emjBtn=document.getElementById('emjBtn');
if(emjBtn){
    emjBtn.addEventListener('click',e=>{
        e.preventDefault(); e.stopPropagation();
        if(_picker){_picker.remove();_picker=null;return;}
        _picker=new EmojiMart.Picker({
            onEmojiSelect:(em)=>{
                const start = CM.selectionStart;
                const end = CM.selectionEnd;
                CM.value = CM.value.substring(0, start) + em.native + CM.value.substring(end);
                CM.selectionStart = CM.selectionEnd = start + em.native.length;
                CM.dispatchEvent(new Event('input'));
                CM.focus();
            },
            theme:'light', previewPosition:'none', skinTonePosition:'none'
        });
        Object.assign(_picker.style,{position:'absolute',bottom:'100%',left:'0',zIndex:'1000',marginBottom:'10px'});
        document.querySelector('.inp-pl').style.position='relative';
        document.querySelector('.inp-pl').appendChild(_picker);
    });
}
document.addEventListener('click',e=>{
    if(_picker && !e.target.closest('em-emoji-picker') && !e.target.closest('#emjBtn')){
        _picker.remove();
        _picker=null;
    }
});

/* ── Custom Modal ── */
let spCallback=null;
function spShow(icon,title,msg,btnText,btnClass,cb){
    const ov=document.getElementById('spModal');
    document.getElementById('spIcon').className='sp-modal-icon '+icon;
    document.getElementById('spTitle').textContent=title;
    document.getElementById('spMsg').textContent=msg;
    const btn=document.getElementById('spConfirm');
    btn.textContent=btnText;
    btn.className='sp-btn '+btnClass;
    spCallback=cb;
    btn.onclick=()=>{const cb=spCallback; spClose(); if(cb)cb();};
    ov.classList.add('show');
}
function spClose(){document.getElementById('spModal').classList.remove('show');spCallback=null;}
function spAlert(title,msg,icon){
    const ov=document.getElementById('spModal');
    document.getElementById('spIcon').className='sp-modal-icon '+(icon||'info');
    document.getElementById('spTitle').textContent=title;
    document.getElementById('spMsg').textContent=msg;
    const btn=document.getElementById('spConfirm');
    btn.textContent='OK';btn.className='sp-btn sp-btn-primary';
    btn.onclick=()=>spClose();
    document.querySelector('.sp-btn-cancel').style.display='none';
    ov.classList.add('show');
    setTimeout(()=>document.querySelector('.sp-btn-cancel').style.display='',100);
}

/* ── SignalR ── */
const hub=new signalR.HubConnectionBuilder().withUrl('/hubs/chat').withAutomaticReconnect().build();
hub.on('ReceiveMessage',m=>{
    console.log('[SignalR] ReceiveMessage:', m);
    if((m.chatId||m.ChatId)===CID) appMsg(m);
    else console.warn('[SignalR] Ignored message for different ChatId', m);
});
hub.on('MessageEdited',(id,txt)=>{
    const b=document.getElementById('bbl-'+id);if(!b)return;
    b.textContent=txt;
    const t=document.getElementById('ts-'+id);
    if(t&&!t.querySelector('.m-ed')){const s=document.createElement('span');s.className='m-ed';s.innerHTML='&nbsp;· edited';t.appendChild(s);}
});
hub.on('MessageDeleted',id=>{
    const r=document.getElementById('r-'+id);
    if(r){
        const bbl=r.querySelector('.bbl');
        const dots=r.querySelector('.m-d');
        const ctx=r.querySelector('.m-c');
        if(bbl){bbl.className='bbl-unsent';bbl.innerHTML='<i class="bi bi-slash-circle"></i> This message was unsent';}
        if(dots)dots.remove();
        if(ctx)ctx.remove();
    }
});
hub.start().catch(e=>console.error(e));

/* ── File handling ── */
let pendingFiles=[];
FI.addEventListener('change',()=>{addFiles(FI.files);FI.value='';});

function addFiles(fl){
    const allowed=['.jpg','.jpeg','.png','.gif','.webp','.bmp','.pdf','.doc','.docx','.xls','.xlsx','.txt','.zip','.rar'];
    for(const f of fl){
        if(pendingFiles.length>=5){spAlert('Limit Reached','Maximum 5 files at once.','warn');break;}
        if(f.size>20*1024*1024){spAlert('File Too Large',`"${f.name}" exceeds the 20MB limit.`,'warn');continue;}
        const ext='.'+f.name.split('.').pop().toLowerCase();
        if(!allowed.includes(ext)){spAlert('Invalid File',`File type "${ext}" is not allowed.`,'warn');continue;}
        pendingFiles.push(f);
    }
    renderPreviews();
}

function renderPreviews(){
    FPS.innerHTML='';
    if(!pendingFiles.length){FPS.style.display='none';return;}
    FPS.style.display='block';
    pendingFiles.forEach((f,i)=>{
        const isImg=f.type.startsWith('image/');
        const el=document.createElement('div');el.className='fp-item';
        if(isImg){const img=document.createElement('img');img.src=URL.createObjectURL(f);el.appendChild(img);}
        else{const ic=document.createElement('i');ic.className='bi bi-file-earmark';el.appendChild(ic);}
        const rm=document.createElement('button');rm.className='fp-rm';rm.innerHTML='×';
        rm.onclick=()=>{pendingFiles.splice(i,1);renderPreviews();};
        el.appendChild(rm);FPS.appendChild(el);
    });
}

/* Drag-and-drop */
FD.addEventListener('dragover',e=>{e.preventDefault();FD.classList.add('drag-over');});
FD.addEventListener('dragleave',()=>FD.classList.remove('drag-over'));
FD.addEventListener('drop',e=>{e.preventDefault();FD.classList.remove('drag-over');if(e.dataTransfer.files.length)addFiles(e.dataTransfer.files);});

/* ── Upload files ── */
async function uploadFiles(){
    if(!pendingFiles.length)return[];
    const fd=new FormData();
    pendingFiles.forEach(f=>fd.append('files',f));
    const prog=document.getElementById('uProg'),fill=document.getElementById('uFill'),txt=document.getElementById('uTxt');
    prog.style.display='block';fill.style.width='0%';txt.textContent='Uploading…';
    return new Promise((resolve,reject)=>{
        const xhr=new XMLHttpRequest();
        xhr.open('POST','/Chat/UploadChatFiles');
        xhr.upload.onprogress=e=>{if(e.lengthComputable){const p=Math.round(e.loaded/e.total*100);fill.style.width=p+'%';txt.textContent=`Uploading… ${p}%`;}};
        xhr.onload=()=>{
            prog.style.display='none';
            if(xhr.status===200){const r=JSON.parse(xhr.responseText);pendingFiles=[];renderPreviews();resolve(r.files);}
            else{try{const e=JSON.parse(xhr.responseText);spAlert('Upload Failed',e.error||'Could not upload files.','danger');}catch(x){spAlert('Upload Failed','An error occurred.','danger');}reject();}
        };
        xhr.onerror=()=>{prog.style.display='none';spAlert('Upload Failed','Network error.','danger');reject();};
        xhr.send(fd);
    });
}

/* ── Append message ── */
function appMsg(m){
    try {
        console.log('[appMsg] Rendering message onto DOM:', m);
        const id=m.id||m.Id;
        const senderId=m.senderId||m.SenderId;
        const content=m.content||m.Content||'';
        const sentAt=m.sentAt||m.SentAt;
        const attachUrl=m.attachmentUrl||m.AttachmentUrl||null;
        const isSeller=m.isSeller||m.IsSeller||false;
        const mine=senderId===ME;
        const row=document.createElement('div');
        row.className='m '+(mine?'out':'in');
        row.dataset.id=id;row.id='r-'+id;
        const t=new Date(sentAt).toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});

        let h='';
        if(!mine) h+=`<div class="m-av">${esc(CI)}</div>`;
        h+='<div class="m-w"><div class="m-b"><div class="bbl" id="bbl-'+id+'">';

        if(attachUrl){
            const isImg=attachUrl.match(/\.(jpg|jpeg|png|gif|webp|bmp)$/i);
            if(isImg) h+=`<img src="${attachUrl}" class="bbl-img" onclick="window.open(this.src)"/>`;
            else h+=`<a href="${attachUrl}" target="_blank" class="bbl-file" download><i class="bi bi-file-earmark-arrow-down"></i><div><div class="bbl-file-nm">${esc(attachUrl.split('/').pop())}</div></div></a>`;
            if(content) h+=`<div style="margin-top:3px">${esc(content)}</div>`;
        } else {
            h+=esc(content);
        }

        h+=`</div><div class="m-t" id="ts-${id}">${t} <i class="bi bi-check2" style="color:var(--c-mt);font-size:10px;"></i></div></div>`;
        if(mine){
            h+=`<div class="m-d"><button class="m-d-b" onclick="openC(${id},event)"><i class="bi bi-three-dots"></i></button></div>`;
            h+=`<div class="m-c" id="cx-${id}"><button class="cb" onclick="sEdit(${id})"><i class="bi bi-pencil"></i> Edit</button><div class="cs"></div><button class="cb dl" onclick="sDel(${id},'forMe')"><i class="bi bi-eye-slash"></i> Delete for me</button><button class="cb dl" onclick="sDel(${id},'forEveryone')"><i class="bi bi-trash"></i> Delete for everyone</button></div>`;
        }
        h+='</div>';
        row.innerHTML=h;
        FD.appendChild(row);
        FD.scrollTop=FD.scrollHeight;
    } catch(err) {
        console.error('[appMsg] CRITICAL ERROR rendering message element:', err);
    }
}

/* ── Context menu ── */
function openC(id,ev){ev.stopPropagation();closeC();const c=document.getElementById('cx-'+id);if(c)c.classList.add('op');}
function closeC(){document.querySelectorAll('.m-c.op').forEach(c=>c.classList.remove('op'));}
document.addEventListener('click',e=>{if(!e.target.closest('.m-c')&&!e.target.closest('.m-d-b'))closeC();});

/* ── Edit ── */
function sEdit(id){
    closeC();const bbl=document.getElementById('bbl-'+id);if(!bbl)return;
    const o=bbl.textContent.trim();
    bbl.innerHTML=`<div class="m-e"><textarea class="m-e-ta" id="eta-${id}">${esc(o)}</textarea><div class="m-e-a"><button class="m-e-b cn" onclick="cEdit(${id},'${esc(o).replace(/'/g,"\\'")}')">Cancel</button><button class="m-e-b sv" onclick="svEdit(${id})">Save</button></div></div>`;
    const ta=document.getElementById('eta-'+id);ta.focus();ta.selectionStart=ta.value.length;
}
function cEdit(id,orig){const bbl=document.getElementById('bbl-'+id);if(bbl)bbl.textContent=orig;}
function svEdit(id){
    const ta=document.getElementById('eta-'+id);if(!ta)return;
    const nv=ta.value.trim();if(!nv)return;
    const bbl=document.getElementById('bbl-'+id);
    const o=bbl?bbl.textContent:'';
    if(bbl)bbl.textContent=nv;
    fetch('/Chat/EditMessage',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({messageId:id,content:nv})})
    .then(r=>{if(!r.ok)throw r;const t=document.getElementById('ts-'+id);if(t&&!t.querySelector('.m-ed')){const s=document.createElement('span');s.className='m-ed';s.innerHTML='&nbsp;· edited';t.appendChild(s);}})
    .catch(()=>{const b=document.getElementById('bbl-'+id);if(b)b.textContent=o;});
}

/* ── Delete ── */
function sDel(id,mode){
    closeC();
    if(mode==='forEveryone'){
        spShow('danger','Unsend this message?','This will remove the message for everyone in this conversation.','Unsend','sp-btn-danger',()=>doDelete(id,'forEveryone'));
        return;
    }
    const row=document.getElementById('r-'+id);if(!row)return;
    row.style.transition='opacity .2s';row.style.opacity='0';
    setTimeout(()=>{
        fetch('/Chat/DeleteMessage',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({messageId:id,mode:'forMe'})})
        .then(r=>{if(r.ok)row.remove();else row.style.opacity='1';})
        .catch(()=>{row.style.opacity='1';});
    },220);
}
function doDelete(id,mode){
    fetch('/Chat/DeleteMessage',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({messageId:id,mode:mode})})
    .then(r=>{
        if(r.ok){
            const row=document.getElementById('r-'+id);
            if(row){
                const bbl=row.querySelector('.bbl');
                const dots=row.querySelector('.m-d');
                const ctx=row.querySelector('.m-c');
                if(bbl){bbl.className='bbl-unsent';bbl.innerHTML='<i class="bi bi-slash-circle"></i> This message was unsent';}
                if(dots)dots.remove();
                if(ctx)ctx.remove();
            }
        }
    });
}

/* ── Attach popup ── */
function togAt(){const p=document.getElementById('aP');p.style.display=p.style.display==='block'?'none':'block';}
document.addEventListener('click',e=>{
    const p=document.getElementById('aP');
    if(p && p.style.display==='block'&&!p.contains(e.target)&&!e.target.closest('.bt-a'))p.style.display='none';
});

/* ── Send ── */
async function doSend(){
    const msg=CM.value.trim();
    if(!msg&&!pendingFiles.length) return;
    BS.disabled=true;
    try{
        let attachUrl=null, attachName=null;
        if(pendingFiles.length){
            const uploaded=await uploadFiles();
            if(uploaded&&uploaded.length){
                attachUrl=uploaded[0].url;
                attachName=uploaded[0].name;
                for(let i=1;i<uploaded.length;i++){
                    await hub.invoke('SendMessage',CID, '', uploaded[i].url, uploaded[i].name || null);
                }
            }
        }
        if(msg||attachUrl){
            await hub.invoke('SendMessage',CID, msg||'', attachUrl||null, attachName||null);
        }
        CM.value='';CM.style.height='34px';CM.classList.remove('scr');
    }catch(err){
        console.error('[Send Error]', err);
    }
    BS.disabled=false;
}

FM.addEventListener('submit',async e=>{
    e.preventDefault();
    await doSend();
});

CM.addEventListener('keydown',e=>{
    if(e.key==='Enter'&&!e.shiftKey){
        e.preventDefault();
        doSend();
    }
});

/* ── Paste support ── */
CM.addEventListener('paste',e=>{
    const items=e.clipboardData?.items;
    if(!items)return;
    const imageFiles=[];
    for(const item of items){
        if(item.type.startsWith('image/')){
            const f=item.getAsFile();
            if(f)imageFiles.push(f);
        }
    }
    if(imageFiles.length){
        e.preventDefault();
        addFiles(imageFiles);
    }
});
</script>
