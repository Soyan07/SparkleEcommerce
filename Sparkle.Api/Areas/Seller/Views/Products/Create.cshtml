@model Sparkle.Domain.Catalog.Product

@{
    ViewData["Title"] = "Add Product";
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
}

<style>
    :root {
        --primary: #f97316;
        --primary-dark: #ea580c;
        --success: #22c55e;
        --slate-50: #f8fafc;
        --slate-100: #f1f5f9;
        --slate-200: #e2e8f0;
        --slate-500: #64748b;
        --slate-700: #334155;
        --slate-800: #1e293b;
    }

    .page-wrapper {
        width: 100%;
        max-width: 100%;
        padding: 0;
        box-sizing: border-box;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--slate-800);
        margin: 0;
    }

    .page-subtitle {
        font-size: 0.9rem;
        color: var(--slate-500);
        margin: 4px 0 0;
    }

    .back-link {
        display: flex;
        align-items: center;
        gap: 6px;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .back-link:hover {
        color: var(--primary-dark);
    }

    .form-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 24px;
        width: 100%;
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid var(--slate-100);
        padding: 24px;
        margin-bottom: 20px;
    }

    .form-section-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--slate-800);
        margin: 0 0 20px;
    }

    .form-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--slate-500);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .form-label .required {
        color: var(--primary);
    }

    .form-control {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid var(--slate-200);
        border-radius: 8px;
        font-size: 0.9rem;
        color: var(--slate-700);
        background: var(--slate-50);
        transition: all 0.15s ease;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        background: #fff;
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }

    .form-control::placeholder {
        color: var(--slate-500);
    }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .form-select {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid var(--slate-200);
        border-radius: 8px;
        font-size: 0.9rem;
        color: var(--slate-700);
        background: var(--slate-50);
        cursor: pointer;
    }

    .form-select:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }

    .price-input-group {
        display: flex;
        align-items: center;
        border: 1px solid var(--slate-200);
        border-radius: 8px;
        overflow: hidden;
        background: var(--slate-50);
    }

    .price-input-group:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }

    .price-prefix {
        padding: 12px 14px;
        background: var(--slate-100);
        color: var(--slate-600);
        font-weight: 600;
        font-size: 0.9rem;
        border-right: 1px solid var(--slate-200);
    }

    .price-input-group input {
        flex: 1;
        border: none;
        padding: 12px 14px;
        font-size: 0.9rem;
        background: transparent;
    }

    .price-input-group input:focus {
        outline: none;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .upload-area {
        border: 2px dashed var(--slate-200);
        border-radius: 8px;
        padding: 16px;
        background: var(--slate-50);
        text-align: center;
    }

    .upload-area:hover {
        border-color: var(--primary);
        background: rgba(249, 115, 22, 0.05);
    }

    .upload-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: #fff;
        border: 1px solid var(--primary);
        border-radius: 8px;
        color: var(--primary);
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .upload-btn:hover {
        background: var(--primary);
        color: #fff;
    }

    .upload-hint {
        font-size: 0.8rem;
        color: var(--slate-500);
        margin-top: 8px;
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn-discard {
        padding: 12px 24px;
        background: #fff;
        border: 1px solid var(--slate-200);
        border-radius: 8px;
        color: var(--slate-600);
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s ease;
    }

    .btn-discard:hover {
        background: var(--slate-50);
        color: var(--slate-700);
    }

    .btn-publish {
        padding: 12px 24px;
        background: var(--success);
        border: none;
        border-radius: 8px;
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .btn-publish:hover {
        background: #16a34a;
    }

    .mb-20 { margin-bottom: 20px; }
    .mb-16 { margin-bottom: 16px; }
</style>

<!-- Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Add New Product</h1>
        <p class="page-subtitle">Create a new listing for your store catalog</p>
    </div>
    <a asp-action="Index" class="back-link">
        <i class="bi bi-arrow-left"></i> Back to Inventory
    </a>
</div>

    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

        <div class="form-grid">
            <!-- Left Column -->
            <div class="left-column">
                <!-- Basic Information -->
                <div class="form-card">
                    <h2 class="form-section-title">Basic Information</h2>
                    
                    <div class="mb-20">
                        <label asp-for="Title" class="form-label">Product Title <span class="required">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Premium Cotton T-Shirt" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-20">
                        <label asp-for="ShortDescription" class="form-label">Short Description</label>
                        <textarea asp-for="ShortDescription" class="form-control" rows="2" placeholder="Brief summary for list views..."></textarea>
                        <span asp-validation-for="ShortDescription" class="text-danger small"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="form-label">Full Description</label>
                        <textarea asp-for="Description" class="form-control" rows="6" placeholder="Complete product details, features, specifications..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Media -->
                <div class="form-card">
                    <h2 class="form-section-title">Media</h2>
                    
                    <div class="mb-16">
                        <label class="form-label">Upload Photos</label>
                        <div class="upload-area">
                            <label class="upload-btn">
                                <i class="bi bi-cloud-upload"></i> Choose files
                                <input type="file" name="images" multiple accept="image/*" style="display: none;" id="imageInput" />
                            </label>
                            <span id="fileCount" style="margin-left: 12px; color: var(--slate-500);">No file chosen</span>
                        </div>
                        <p class="upload-hint">You can select multiple files. Supported: JPG, PNG, WEBP</p>
                    </div>

                    <div>
                        <label class="form-label">Image Links</label>
                        <textarea id="imageUrls" name="imageUrls" class="form-control" rows="3" placeholder="Paste image URLs here (one per line)..."></textarea>
                        <p class="upload-hint">Optional: Add external image URLs if you don't want to upload files</p>
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="right-column">
                <!-- Pricing & Inventory -->
                <div class="form-card">
                    <h2 class="form-section-title">Pricing & Inventory</h2>
                    
                    <div class="mb-20">
                        <label asp-for="BasePrice" class="form-label">Price (৳) <span class="required">*</span></label>
                        <div class="price-input-group">
                            <span class="price-prefix">৳</span>
                            <input asp-for="BasePrice" type="number" step="0.01" min="0" placeholder="0" />
                        </div>
                        <span asp-validation-for="BasePrice" class="text-danger small"></span>
                    </div>

                    <div class="mb-20">
                        <label asp-for="DiscountPercent" class="form-label">Discount %</label>
                        <input asp-for="DiscountPercent" type="number" step="1" min="0" max="100" class="form-control" placeholder="0" />
                        <span asp-validation-for="DiscountPercent" class="text-danger small"></span>
                    </div>

                    <div>
                        <label class="form-label">Stock <span class="required">*</span></label>
                        <input name="initialStock" type="number" min="0" class="form-control" value="10" placeholder="10" />
                        <p class="upload-hint">Initial inventory quantity</p>
                    </div>
                </div>

                <!-- Organization -->
                <div class="form-card">
                    <h2 class="form-section-title">Organization</h2>
                    
                    <div>
                        <label asp-for="CategoryId" class="form-label">Category <span class="required">*</span></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">Select Category</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="action-buttons">
                    <a asp-action="Index" class="btn-discard">Discard</a>
                    <button type="submit" class="btn-publish">Publish Product</button>
                </div>
            </div>
        </div>
    </form>

<script>
    // Update file count display
    document.getElementById('imageInput')?.addEventListener('change', function() {
        const count = this.files.length;
        document.getElementById('fileCount').textContent = count > 0 
            ? count + ' file(s) selected' 
            : 'No file chosen';
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
