@{
    ViewData["Title"] = "Analytics";
    var period = ViewBag.Period ?? "30d";
    var totalRevenue = ViewBag.TotalRevenue ?? 0m;
    var totalOrders = ViewBag.TotalOrders ?? 0;
    var totalItems = ViewBag.TotalItemsSold ?? 0;
    var avgOrderValue = ViewBag.AverageOrderValue ?? 0m;
    var totalReviews = ViewBag.TotalReviews ?? 0;
    var avgRating = ViewBag.AverageRating ?? 0.0;
    var dailyLabels = ViewBag.DailySalesLabels as List<string> ?? new List<string>();
    var dailyData = ViewBag.DailySalesData as List<decimal> ?? new List<decimal>();
    var topProducts = ViewBag.TopProducts ?? new List<dynamic>();
}

<div class="tw-mb-6 tw-flex tw-justify-between tw-items-center">
    <div>
        <h1 class="tw-text-2xl tw-font-bold tw-text-slate-800">Analytics Dashboard</h1>
        <p class="tw-text-slate-500 tw-text-sm">Track your sales, orders, and performance</p>
    </div>
    <div class="tw-flex tw-gap-2">
        <a href="?period=7d" class="tw-px-4 tw-py-2 tw-rounded-lg @(period == "7d" ? "tw-bg-blue-600 tw-text-white" : "tw-bg-white tw-text-slate-600 tw-border")">7 Days</a>
        <a href="?period=30d" class="tw-px-4 tw-py-2 tw-rounded-lg @(period == "30d" ? "tw-bg-blue-600 tw-text-white" : "tw-bg-white tw-text-slate-600 tw-border")">30 Days</a>
        <a href="?period=90d" class="tw-px-4 tw-py-2 tw-rounded-lg @(period == "90d" ? "tw-bg-blue-600 tw-text-white" : "tw-bg-white tw-text-slate-600 tw-border")">90 Days</a>
        <a href="?period=1y" class="tw-px-4 tw-py-2 tw-rounded-lg @(period == "1y" ? "tw-bg-blue-600 tw-text-white" : "tw-bg-white tw-text-slate-600 tw-border")">1 Year</a>
    </div>
</div>

<!-- Key Metrics -->
<div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-4 tw-gap-6 tw-mb-6">
    <div class="tw-bg-gradient-to-br tw-from-blue-50 tw-to-blue-100 tw-border tw-border-blue-200 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
            <span class="tw-text-sm tw-text-blue-600 tw-font-medium">Total Revenue</span>
            <i class="bi bi-graph-up-arrow tw-text-blue-600 tw-text-xl"></i>
        </div>
        <div class="tw-text-3xl tw-font-bold tw-text-blue-900">৳@totalRevenue.ToString("N0")</div>
    </div>

    <div class="tw-bg-gradient-to-br tw-from-green-50 tw-to-green-100 tw-border tw-border-green-200 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
            <span class="tw-text-sm tw-text-green-600 tw-font-medium">Total Orders</span>
            <i class="bi bi-cart-check tw-text-green-600 tw-text-xl"></i>
        </div>
        <div class="tw-text-3xl tw-font-bold tw-text-green-900">@totalOrders</div>
    </div>

    <div class="tw-bg-gradient-to-br tw-from-purple-50 tw-to-purple-100 tw-border tw-border-purple-200 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
            <span class="tw-text-sm tw-text-purple-600 tw-font-medium">Items Sold</span>
            <i class="bi bi-box-seam tw-text-purple-600 tw-text-xl"></i>
        </div>
        <div class="tw-text-3xl tw-font-bold tw-text-purple-900">@totalItems</div>
    </div>

    <div class="tw-bg-gradient-to-br tw-from-orange-50 tw-to-orange-100 tw-border tw-border-orange-200 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
            <span class="tw-text-sm tw-text-orange-600 tw-font-medium">Avg Order Value</span>
            <i class="bi bi-currency-exchange tw-text-orange-600 tw-text-xl"></i>
        </div>
        <div class="tw-text-3xl tw-font-bold tw-text-orange-900">৳@avgOrderValue.ToString("N0")</div>
    </div>
</div>

<div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-2 tw-gap-6">
    <!-- Sales Chart -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Sales Overview</h3>
        <canvas id="salesChart" height="250"></canvas>
    </div>

    <!-- Order Status -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Order Status</h3>
        <canvas id="statusChart" height="250"></canvas>
    </div>

    <!-- Top Products -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Top Performing Products</h3>
        <div class="tw-space-y-4">
            @{ var topProductList = topProducts as IEnumerable<dynamic>; }
            @if (topProductList != null && topProductList.Any())
            {
                foreach (var item in topProductList)
                {
                    <div class="tw-flex tw-items-center tw-justify-between tw-pb-4 tw-border-b tw-border-slate-100 last:tw-border-0">
                        <div class="tw-flex tw-items-center tw-gap-3">
                            <div class="tw-w-12 tw-h-12 tw-bg-slate-100 tw-rounded-lg tw-flex tw-items-center tw-justify-center">
                                <i class="bi bi-box tw-text-slate-400"></i>
                            </div>
                            <div>
                                <div class="tw-font-medium tw-text-slate-800">@item.Product.Title</div>
                                <div class="tw-text-sm tw-text-slate-500">@item.TotalSold sold</div>
                            </div>
                        </div>
                        <div class="tw-text-right">
                            <div class="tw-font-bold tw-text-slate-900">৳@((decimal)item.Revenue).ToString("N0")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="tw-text-center tw-text-slate-500 tw-py-8">
                    <i class="bi bi-inbox tw-text-4xl"></i>
                    <p class="tw-mt-2">No sales data for this period</p>
                </div>
            }
        </div>
    </div>

    <!-- Reviews Stats -->
    <div class="tw-bg-white tw-border tw-border-slate-100 tw-rounded-2xl tw-shadow-sm tw-p-6">
        <h3 class="tw-font-bold tw-text-lg tw-text-slate-800 tw-mb-4">Customer Reviews</h3>
        <div class="tw-flex tw-items-center tw-gap-4 tw-mb-4">
            <div class="tw-text-5xl tw-font-bold tw-text-amber-500">@avgRating</div>
            <div>
                <div class="tw-flex tw-gap-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star-fill @(i <= Math.Round((double)avgRating) ? "tw-text-amber-400" : "tw-text-slate-200")"></i>
                    }
                </div>
                <div class="tw-text-sm tw-text-slate-500">@totalReviews reviews this period</div>
            </div>
        </div>
        <div class="tw-space-y-2">
            <div class="tw-flex tw-items-center tw-gap-2">
                <span class="tw-text-sm tw-w-8">5★</span>
                <div class="tw-flex-1 tw-bg-slate-100 tw-rounded-full tw-h-2">
                    <div class="tw-bg-green-500 tw-h-2 tw-rounded-full" style="width: 60%"></div>
                </div>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2">
                <span class="tw-text-sm tw-w-8">4★</span>
                <div class="tw-flex-1 tw-bg-slate-100 tw-rounded-full tw-h-2">
                    <div class="tw-bg-green-400 tw-h-2 tw-rounded-full" style="width: 25%"></div>
                </div>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2">
                <span class="tw-text-sm tw-w-8">3★</span>
                <div class="tw-flex-1 tw-bg-slate-100 tw-rounded-full tw-h-2">
                    <div class="tw-bg-yellow-400 tw-h-2 tw-rounded-full" style="width: 10%"></div>
                </div>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2">
                <span class="tw-text-sm tw-w-8">2★</span>
                <div class="tw-flex-1 tw-bg-slate-100 tw-rounded-full tw-h-2">
                    <div class="tw-bg-orange-400 tw-h-2 tw-rounded-full" style="width: 3%"></div>
                </div>
            </div>
            <div class="tw-flex tw-items-center tw-gap-2">
                <span class="tw-text-sm tw-w-8">1★</span>
                <div class="tw-flex-1 tw-bg-slate-100 tw-rounded-full tw-h-2">
                    <div class="tw-bg-red-400 tw-h-2 tw-rounded-full" style="width: 2%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Sales Chart
    const salesCtx = document.getElementById('salesChart').getContext('2d');
    new Chart(salesCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyLabels)),
            datasets: [{
                label: 'Revenue',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyData)),
                borderColor: 'rgb(59, 130, 246)',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });

    // Status Chart
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
        type: 'doughnut',
        data: {
            labels: ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'],
            datasets: [{
                data: [@ViewBag.PendingOrders, @ViewBag.ProcessingOrders, @ViewBag.ShippedOrders, @ViewBag.DeliveredOrders, @ViewBag.CancelledOrders],
                backgroundColor: ['#fbbf24', '#3b82f6', '#8b5cf6', '#22c55e', '#ef4444']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });
</script>
}
