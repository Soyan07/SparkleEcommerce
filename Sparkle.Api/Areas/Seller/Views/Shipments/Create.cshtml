@{
    ViewData["Title"] = "Create Shipment";
    var order = ViewBag.Order as Sparkle.Domain.Orders.Order;
    var unshippedItems = ViewBag.UnshippedItems as List<Sparkle.Domain.Orders.OrderItem> ?? new List<Sparkle.Domain.Orders.OrderItem>();
    var couriers = ViewBag.Couriers as string[] ?? Array.Empty<string>();

    if (order == null)
    {
         <div class="alert alert-danger">Order not found.</div>
         return;
    }
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h3 fw-bold mb-1">Create Shipment</h2>
                <div class="text-muted">
                    Fulfilling Order <span class="fw-bold text-dark">#@order.OrderNumber</span>
                </div>
            </div>
            <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-secondary">
                Cancel
            </a>
        </div>

        <form asp-action="Create" method="post">
            <input type="hidden" name="orderId" value="@order.Id" />
            
            @if(TempData["Error"] != null)
            {
                <div class="alert alert-danger mb-4">@TempData["Error"]</div>
            }

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h5 class="card-title fw-bold mb-0">1. Select Items to Ship</h5>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4" style="width: 50px;">
                                    <input type="checkbox" class="form-check-input" id="checkAll" checked>
                                </th>
                                <th>Product</th>
                                <th class="text-center">Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in unshippedItems)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <input type="checkbox" name="itemIds" value="@item.Id" class="form-check-input item-check" checked>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (item.Product?.Images != null && item.Product.Images.Any())
                                            {
                                                <img src="@item.Product.Images.First().Url" class="rounded me-3 border" width="48" height="48" />
                                            }
                                            else
                                            {
                                                <div class="bg-light rounded d-flex align-items-center justify-content-center me-3 border" style="width: 48px; height: 48px;">
                                                    <i class="bi bi-box text-muted"></i>
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-bold">@item.ProductName</div>
                                                <small class="text-muted">@item.Product?.Slug</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center fw-bold">@item.Quantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h5 class="card-title fw-bold mb-0">2. Courier Options</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Courier Service <span class="text-danger">*</span></label>
                            <select name="courierName" class="form-select" required>
                                <option value="">-- Select Courier --</option>
                                @foreach(var c in couriers)
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tracking Number</label>
                            <input type="text" name="trackingNumber" class="form-control" placeholder="e.g. TRK123456789" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Internal Notes</label>
                            <textarea name="notes" class="form-control" rows="2" placeholder="Private notes for your reference (optional)"></textarea>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Shipping Address Summary -->
            <div class="card border-0 shadow-sm mb-4 bg-light">
                <div class="card-body p-4">
                     <h6 class="fw-bold mb-3 text-muted text-uppercase small">Ship To</h6>
                     <div class="d-flex align-items-start">
                         <i class="bi bi-geo-alt fs-4 text-primary me-3"></i>
                         <div>
                            <div class="fw-bold text-dark">@order.ShippingAddress?.FullName</div>
                            <div class="text-secondary small">
                                @order.ShippingAddress?.Line1, @order.ShippingAddress?.City<br>
                                @order.ShippingAddress?.Country, @order.ShippingAddress?.PostalCode<br>
                                Phone: @order.ShippingAddress?.Phone
                            </div>
                         </div>
                     </div>
                </div>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg fw-bold">
                    Confirm Shipment
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('checkAll').addEventListener('change', function() {
        var checkboxes = document.querySelectorAll('.item-check');
        for (var checkbox of checkboxes) {
            checkbox.checked = this.checked;
        }
    });
</script>
