@{
    ViewData["Title"] = "Store Profile";
}

<div class="glass-panel tw-p-8">
    <div class="tw-border-b tw-border-gray-200 tw-pb-4 tw-mb-6">
        <h1 class="tw-text-2xl tw-font-bold tw-text-gray-900">Store Profile</h1>
        <p class="tw-text-gray-500">Preview how your store appears to customers</p>
    </div>

    <!-- Store Header -->
    <div class="tw-relative tw-rounded-2xl tw-overflow-hidden tw-mb-8">
        <!-- Cover Image -->
        <div class="tw-h-48 tw-bg-gradient-to-r tw-from-blue-500 tw-to-purple-600"></div>
        
        <!-- Store Logo -->
        <div class="tw-absolute tw-left-8 -tw-bottom-16">
            <div class="tw-w-32 tw-h-32 tw-bg-white tw-rounded-2xl tw-shadow-lg tw-flex tw-items-center tw-justify-center tw-border-4 tw-border-white">
                <i class="bi bi-shop tw-text-gray-400 tw-text-5xl"></i>
            </div>
        </div>
    </div>

    <!-- Store Info -->
    <div class="tw-mt-20 tw-mb-8">
        <div class="tw-flex tw-items-center tw-justify-between tw-mb-4">
            <div>
                <h2 class="tw-text-2xl tw-font-bold tw-text-gray-900">Daily Essentials BD</h2>
                <div class="tw-flex tw-items-center tw-gap-4 tw-mt-2">
                    <div class="tw-flex tw-items-center tw-gap-1 tw-text-yellow-500">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-half"></i>
                        <span class="tw-text-gray-600 tw-ml-2">4.5 (234 reviews)</span>
                    </div>
                    <span class="tw-text-gray-400">•</span>
                    <div class="tw-flex tw-items-center tw-gap-2 tw-text-gray-600">
                        <i class="bi bi-box-seam"></i>
                        <span>142 Products</span>
                    </div>
                </div>
            </div>
            <a href="/Seller/Store/Settings" class="tw-px-6 tw-py-2 tw-bg-blue-600 tw-text-white tw-rounded-lg tw-font-medium hover:tw-bg-blue-700 tw-transition-colors tw-no-underline">
                <i class="bi bi-pencil-square tw-mr-2"></i>Edit Profile
            </a>
        </div>

        <!-- Store Description -->
        <p class="tw-text-gray-600 tw-leading-relaxed tw-max-w-3xl">
            Your one-stop shop for daily household needs. We offer quality products at competitive prices with fast delivery across Bangladesh.
        </p>

        <!-- Store Stats -->
        <div class="tw-grid tw-grid-cols-4 tw-gap-6 tw-mt-6">
            <div class="tw-bg-gradient-to-br tw-from-blue-50 tw-to-blue-100 tw-rounded-xl tw-p-4 tw-text-center">
                <div class="tw-text-3xl tw-font-bold tw-text-blue-600">98%</div>
                <div class="tw-text-sm tw-text-gray-600 tw-mt-1">Positive Ratings</div>
            </div>
            <div class="tw-bg-gradient-to-br tw-from-green-50 tw-to-green-100 tw-rounded-xl tw-p-4 tw-text-center">
                <div class="tw-text-3xl tw-font-bold tw-text-green-600">1.2k</div>
                <div class="tw-text-sm tw-text-gray-600 tw-mt-1">Total Sales</div>
            </div>
            <div class="tw-bg-gradient-to-br tw-from-purple-50 tw-to-purple-100 tw-rounded-xl tw-p-4 tw-text-center">
                <div class="tw-text-3xl tw-font-bold tw-text-purple-600">2.5k</div>
                <div class="tw-text-sm tw-text-gray-600 tw-mt-1">Followers</div>
            </div>
            <div class="tw-bg-gradient-to-br tw-from-orange-50 tw-to-orange-100 tw-rounded-xl tw-p-4 tw-text-center">
                <div class="tw-text-3xl tw-font-bold tw-text-orange-600">24h</div>
                <div class="tw-text-sm tw-text-gray-600 tw-mt-1">Avg Response</div>
            </div>
        </div>
    </div>

    <!-- Contact Information -->
    <div class="tw-grid tw-grid-cols-2 tw-gap-6 tw-mb-8">
        <div class="tw-bg-gray-50 tw-rounded-xl tw-p-6">
            <h3 class="tw-font-bold tw-text-lg tw-text-gray-900 tw-mb-4">Contact Information</h3>
            <div class="tw-space-y-3">
                <div class="tw-flex tw-items-center tw-gap-3">
                    <i class="bi bi-telephone-fill tw-text-blue-600"></i>
                    <span class="tw-text-gray-600">+880 1711-223344</span>
                </div>
                <div class="tw-flex tw-items-center tw-gap-3">
                    <i class="bi bi-envelope-fill tw-text-blue-600"></i>
                    <span class="tw-text-gray-600">support@dailyessentialsbd.com</span>
                </div>
                <div class="tw-flex tw-items-center tw-gap-3">
                    <i class="bi bi-geo-alt-fill tw-text-blue-600"></i>
                    <span class="tw-text-gray-600">Dhaka, Bangladesh</span>
                </div>
            </div>
        </div>

        <div class="tw-bg-gray-50 tw-rounded-xl tw-p-6">
            <h3 class="tw-font-bold tw-text-lg tw-text-gray-900 tw-mb-4">Business Hours</h3>
            <div class="tw-space-y-2">
                <div class="tw-flex tw-justify-between">
                    <span class="tw-text-gray-600">Monday - Friday</span>
                    <span class="tw-font-medium tw-text-gray-900">9:00 AM - 9:00 PM</span>
                </div>
                <div class="tw-flex tw-justify-between">
                    <span class="tw-text-gray-600">Saturday</span>
                    <span class="tw-font-medium tw-text-gray-900">10:00 AM - 8:00 PM</span>
                </div>
                <div class="tw-flex tw-justify-between">
                    <span class="tw-text-gray-600">Sunday</span>
                    <span class="tw-font-medium tw-text-gray-900">Closed</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Products Preview -->
    <div>
        <h3 class="tw-font-bold tw-text-xl tw-text-gray-900 tw-mb-4">Top Products</h3>
        <div class="tw-grid tw-grid-cols-4 tw-gap-6">
            @for (int i = 0; i < 4; i++)
            {
                <div class="tw-bg-white tw-border tw-border-gray-200 tw-rounded-xl tw-overflow-hidden hover:tw-shadow-lg tw-transition-shadow">
                    <div class="tw-h-48 tw-bg-gray-100 tw-flex tw-items-center tw-justify-center">
                        <i class="bi bi-image tw-text-gray-400 tw-text-4xl"></i>
                    </div>
                    <div class="tw-p-4">
                        <h4 class="tw-font-medium tw-text-gray-900 tw-mb-1">Product Name</h4>
                        <div class="tw-flex tw-items-center tw-justify-between">
                            <span class="tw-text-blue-600 tw-font-bold">৳999</span>
                            <div class="tw-flex tw-items-center tw-gap-1 tw-text-yellow-500 tw-text-sm">
                                <i class="bi bi-star-fill"></i>
                                <span class="tw-text-gray-600">4.5</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Recent Reviews -->
    <div class="tw-mt-8">
        <h3 class="tw-font-bold tw-text-xl tw-text-gray-900 tw-mb-4">Recent Reviews</h3>
        <div class="tw-space-y-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="tw-bg-white tw-border tw-border-gray-200 tw-rounded-xl tw-p-6">
                    <div class="tw-flex tw-items-start tw-gap-4">
                        <div class="tw-w-12 tw-h-12 tw-bg-blue-100 tw-rounded-full tw-flex tw-items-center tw-justify-center">
                            <span class="tw-text-blue-600 tw-font-bold">JD</span>
                        </div>
                        <div class="tw-flex-1">
                            <div class="tw-flex tw-items-center tw-justify-between tw-mb-2">
                                <div>
                                    <h4 class="tw-font-medium tw-text-gray-900">John Doe</h4>
                                    <div class="tw-flex tw-items-center tw-gap-1 tw-text-yellow-500 tw-text-sm">
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i>
                                    </div>
                                </div>
                                <span class="tw-text-sm tw-text-gray-500">2 days ago</span>
                            </div>
                            <p class="tw-text-gray-600">Great product and excellent service! Highly recommended.</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
