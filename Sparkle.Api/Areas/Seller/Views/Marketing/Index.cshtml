@{
    ViewData["Title"] = "Marketing & Promotions";
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
    var products = ViewBag.Products ?? new List<dynamic>();
    var productsOnSale = ViewBag.ProductsOnSale ?? 0;
    var totalProducts = ViewBag.TotalProducts ?? 0;
}

<style>
    .marketing-header {
        background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
        color: white;
        padding: 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 25px rgba(139, 92, 246, 0.3);
    }
    
    .stat-card {
        background: white;
        padding: 1.25rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        text-align: center;
    }
    
    .product-table {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }
    
    .discount-badge {
        background: #dcfce7;
        color: #065f46;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        font-weight: 600;
    }
    
    .no-discount {
        background: #f1f5f9;
        color: #64748b;
    }
</style>

<div class="marketing-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-2"><i class="bi bi-megaphone me-2"></i>Marketing & Discounts</h3>
            <p class="mb-0 opacity-90">Manage product discounts to boost sales</p>
        </div>
        <form method="post" asp-action="ClearAllDiscounts" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-light" onclick="return confirm('Clear all discounts?')">
                <i class="bi bi-x-circle me-1"></i>Clear All Discounts
            </button>
        </form>
    </div>
</div>

<!-- Stats -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="text-muted small">Total Products</div>
            <div class="fs-3 fw-bold text-primary">@totalProducts</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="text-muted small">On Sale</div>
            <div class="fs-3 fw-bold text-success">@productsOnSale</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="text-muted small">Full Price</div>
            <div class="fs-3 fw-bold text-secondary">@(totalProducts - productsOnSale)</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="mb-4">
    <h5 class="mb-3">Quick Bulk Actions</h5>
    <div class="row g-3">
        <div class="col-auto">
            <form method="post" asp-action="BulkSetDiscount" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="discountPercent" value="10">
                <button type="submit" class="btn btn-outline-success">
                    <i class="bi bi-percent me-1"></i>Set 10% on All
                </button>
            </form>
        </div>
        <div class="col-auto">
            <form method="post" asp-action="BulkSetDiscount" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="discountPercent" value="20">
                <button type="submit" class="btn btn-outline-warning">
                    <i class="bi bi-lightning me-1"></i>Set 20% Flash Sale
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Products Table -->
<div class="product-table">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Product</th>
                <th>Base Price</th>
                <th>Discount</th>
                <th>Final Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @{ var productList = products as IEnumerable<dynamic>; }
            @if (productList != null && productList.Any())
            {
                foreach (var product in productList)
                {
                    var discount = (decimal?)product.DiscountPercent ?? 0;
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty((string)product.Thumbnail))
                                {
                                    <img src="@product.Thumbnail" class="rounded" style="width: 40px; height: 40px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                                <strong>@product.Title</strong>
                            </div>
                        </td>
                        <td>৳@((decimal)product.BasePrice).ToString("N0")</td>
                        <td>
                            @if (discount > 0)
                            {
                                <span class="discount-badge">@discount%</span>
                            }
                            else
                            {
                                <span class="discount-badge no-discount">No Discount</span>
                            }
                        </td>
                        <td class="fw-bold text-success">৳@((decimal)product.DiscountedPrice).ToString("N0")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" onclick="setDiscount(@product.Id, @discount)">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            @if (discount > 0)
                            {
                                <form method="post" asp-action="SetDiscount" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id">
                                    <input type="hidden" name="discountPercent" value="0">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1"></i>
                        <p class="mt-2">No products found</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script>
    function setDiscount(productId, currentDiscount) {
        const newDiscount = prompt('Enter discount percentage (0-90):', currentDiscount);
        if (newDiscount !== null && !isNaN(newDiscount)) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("SetDiscount")';
            form.innerHTML = `
                <input type="hidden" name="productId" value="${productId}">
                <input type="hidden" name="discountPercent" value="${newDiscount}">
                @Html.AntiForgeryToken()
            `;
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>
}
