@model Sparkle.Api.Areas.Seller.Models.SellerProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="tw-max-w-4xl tw-mx-auto">
    <div class="tw-mb-6">
        <h1 class="tw-text-2xl tw-font-bold tw-text-slate-800">My Profile</h1>
        <p class="tw-text-slate-500 tw-text-sm">Manage your personal and shop information.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="tw-bg-green-50 tw-text-green-700 tw-px-4 tw-py-3 tw-rounded-lg tw-mb-6 tw-flex tw-items-center tw-gap-2">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    <form asp-action="Index" enctype="multipart/form-data" method="post">
        @Html.AntiForgeryToken()
        
        <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-3 tw-gap-8">
            <!-- Left Column: Profile Card & Quick Info -->
            <div class="tw-space-y-6">
                <!-- User Profile Card -->
                <div class="tw-bg-white tw-rounded-2xl tw-p-6 tw-shadow-[0_2px_8px_rgba(0,0,0,0.04)] tw-border tw-border-slate-100">
                    <div class="tw-flex tw-items-center tw-gap-6">
                        <!-- Profile Image -->
                        <div class="tw-relative tw-group tw-flex-shrink-0">
                            <div class="tw-w-24 tw-h-24 tw-rounded-full tw-overflow-hidden tw-border-4 tw-border-white tw-shadow-sm tw-ring-1 tw-ring-slate-100">
                                 @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                                 {
                                     <img src="@Model.ProfilePhotoPath" alt="Profile" class="tw-w-full tw-h-full tw-object-cover" id="profilePreview" />
                                 }
                                 else
                                 {
                                     <img src="https://via.placeholder.com/150" alt="Profile" class="tw-w-full tw-h-full tw-object-cover" id="profilePreview" />
                                 }
                            </div>
                            <label for="ProfilePhoto" class="tw-absolute tw-bottom-0 tw-right-0 tw-bg-slate-900 tw-text-white tw-w-7 tw-h-7 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-cursor-pointer tw-shadow-md hover:tw-scale-110 tw-transition-transform">
                                <i class="bi bi-camera-fill tw-text-[10px]"></i>
                            </label>
                            <input asp-for="ProfilePhoto" type="file" class="tw-hidden" accept="image/*" onchange="previewImage(this)" />
                        </div>
                        
                        <!-- Profile Info -->
                        <div class="tw-text-left">
                            <h2 class="tw-text-xl tw-font-bold tw-text-slate-900">@Model.FullName</h2>
                            <p class="tw-text-sm tw-text-slate-500 tw-mb-2">@Model.Email</p>
                            
                            <div class="tw-inline-flex tw-items-center tw-gap-1.5 tw-px-2.5 tw-py-1 tw-bg-emerald-50 tw-text-emerald-700 tw-rounded-md tw-text-xs tw-font-bold tw-border tw-border-emerald-100">
                                <span class="tw-w-1.5 tw-h-1.5 tw-rounded-full tw-bg-emerald-500"></span>
                                Active Seller
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Save Button (Sticky on Mobile, Standard on Desktop) -->
                <div class="tw-bg-white tw-rounded-xl tw-p-4 tw-shadow-[0_2px_8px_rgba(0,0,0,0.04)] tw-border tw-border-slate-100">
                     <button type="submit" class="tw-w-full tw-py-2.5 tw-bg-slate-900 hover:tw-bg-slate-800 tw-text-white tw-rounded-lg tw-font-medium tw-transition-colors tw-shadow-lg tw-shadow-slate-900/20">
                        Save Changes
                     </button>
                </div>
            </div>

            <!-- Right Column: Forms -->
            <div class="lg:tw-col-span-2 tw-space-y-6">
                <!-- Personal Info -->
                <div class="tw-bg-white tw-rounded-2xl tw-p-8 tw-shadow-[0_2px_8px_rgba(0,0,0,0.04)] tw-border tw-border-slate-100">
                    <h3 class="tw-text-base tw-font-bold tw-text-slate-900 tw-mb-6 tw-flex tw-items-center tw-gap-2">
                        <i class="bi bi-person tw-text-slate-400"></i> Personal Information
                    </h3>
                    
                    <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-6">
                        <div class="tw-group">
                            <label asp-for="FullName" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Full Name</label>
                            <input asp-for="FullName" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" placeholder="Enter your full name" />
                            <span asp-validation-for="FullName" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>

                        <div class="tw-group">
                            <label asp-for="Gender" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Gender</label>
                            <div class="tw-relative">
                                <select asp-for="Gender" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm tw-appearance-none">
                                    <option value="">Select Gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <i class="bi bi-chevron-down tw-absolute tw-right-4 tw-top-1/2 -tw-translate-y-1/2 tw-text-slate-400 tw-pointer-events-none tw-text-xs"></i>
                            </div>
                            <span asp-validation-for="Gender" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>

                         <div class="tw-group">
                            <label asp-for="PhoneNumber" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Phone Number</label>
                            <input asp-for="PhoneNumber" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" placeholder="Contact number" />
                            <span asp-validation-for="PhoneNumber" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>

                        <div class="tw-group">
                            <label asp-for="Email" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-400 tw-uppercase tw-tracking-wide tw-mb-2">Email Address</label>
                            <input asp-for="Email" readonly class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50/50 tw-border tw-border-slate-100 tw-rounded-lg tw-text-slate-400 tw-text-sm tw-cursor-not-allowed" />
                        </div>
                    </div>
                </div>

                <!-- Shop & Address Info -->
                <div class="tw-bg-white tw-rounded-2xl tw-p-8 tw-shadow-[0_2px_8px_rgba(0,0,0,0.04)] tw-border tw-border-slate-100">
                    <h3 class="tw-text-base tw-font-bold tw-text-slate-900 tw-mb-6 tw-flex tw-items-center tw-gap-2">
                        <i class="bi bi-shop-window tw-text-slate-400"></i> Shop & Address
                    </h3>

                    <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-6">
                        <div class="md:tw-col-span-2 tw-group">
                            <label asp-for="ShopName" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Shop Name</label>
                            <input asp-for="ShopName" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" placeholder="Your shop's public name" />
                            <span asp-validation-for="ShopName" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>

                        <div class="md:tw-col-span-2 tw-group">
                             <label asp-for="ShopDescription" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Description</label>
                            <textarea asp-for="ShopDescription" rows="3" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm tw-resize-none" placeholder="Tell customers about your shop..."></textarea>
                            <span asp-validation-for="ShopDescription" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>

                         <div class="tw-group">
                            <label asp-for="MobileNumber" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Business Phone</label>
                            <input asp-for="MobileNumber" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" />
                            <span asp-validation-for="MobileNumber" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>
                        
                        <div class="tw-group">
                            <label asp-for="BusinessAddress" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">Address</label>
                            <input asp-for="BusinessAddress" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" />
                            <span asp-validation-for="BusinessAddress" class="tw-text-red-500 tw-text-xs tw-mt-1 tw-block"></span>
                        </div>

                        <div class="tw-group">
                            <label asp-for="City" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">City</label>
                            <input asp-for="City" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" />
                        </div>

                        <div class="tw-group">
                            <label asp-for="District" class="tw-block tw-text-xs tw-font-semibold tw-text-slate-500 tw-uppercase tw-tracking-wide tw-mb-2">District</label>
                            <input asp-for="District" class="tw-w-full tw-px-4 tw-py-2.5 tw-bg-slate-50 tw-border tw-border-slate-200 tw-rounded-lg focus:tw-bg-white focus:tw-border-slate-400 focus:tw-ring-4 focus:tw-ring-slate-100 tw-transition-all tw-outline-none tw-text-slate-800 tw-text-sm" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tw-mt-6 tw-flex tw-justify-end">
            <button type="submit" class="tw-bg-yellow-400 tw-text-slate-900 tw-font-bold tw-px-8 tw-py-3 tw-rounded-xl tw-shadow-sm hover:tw-bg-yellow-500 tw-transition-colors">
                Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('profilePreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
