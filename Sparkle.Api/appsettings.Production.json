{
  "App": {
    "BaseUrl": "https://sparkleecommerce.onrender.com"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=${POSTGRES_HOST};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Port=5432"
  },
  "Jwt": {
    "Issuer": "Sparkle",
    "Audience": "SparkleClient",
    "Key": "${JWT__KEY}",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Google": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@sparkle.com",
    "FromName": "Sparkle",
    "EnableSsl": "true"
  },
  "LogLevel": {
    "Default": "Information",
    "Microsoft.AspNetCore": "Warning",
    "Microsoft.EntityFrameworkCore": "Warning"
  },
  "AllowedHosts": "*"
}
