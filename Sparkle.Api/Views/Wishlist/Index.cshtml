@model IEnumerable<Sparkle.Domain.Users.UserWishlistItem>
@{
    ViewData["Title"] = "My Wishlist";
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
}

<div class="tw-bg-white tw-rounded-2xl tw-shadow-sm tw-border tw-border-slate-100 tw-overflow-hidden">
    <!-- Header -->
    <div class="tw-px-6 tw-py-4 tw-border-b tw-border-slate-100 tw-flex tw-justify-between tw-items-center">
        <h5 class="tw-font-bold tw-text-slate-800 tw-mb-0 tw-text-lg">
            <i class="bi bi-heart-fill tw-mr-2 tw-text-orange-500"></i> My Wishlist
        </h5>
        <span class="tw-bg-orange-50 tw-text-orange-600 tw-px-3 tw-py-1 tw-rounded-full tw-text-xs tw-font-bold tw-border tw-border-orange-100">
            @Model.Count() Items
        </span>
    </div>

    @if (!Model.Any())
    {
        <div class="tw-text-center tw-py-16 tw-px-6">
            <div class="tw-w-20 tw-h-20 tw-mx-auto tw-mb-6 tw-bg-slate-50 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-text-slate-400">
                <i class="bi bi-heart tw-text-4xl"></i>
            </div>
            <h4 class="tw-font-bold tw-text-slate-800 tw-mb-2">Your wishlist is empty</h4>
            <p class="tw-text-slate-500 tw-mb-6 tw-max-w-xs tw-mx-auto">
                Save items you love for later here.
            </p>
            <a href="/" class="tw-inline-flex tw-items-center tw-gap-2 tw-bg-orange-500 tw-text-white tw-font-bold tw-px-6 tw-py-3 tw-rounded-xl hover:tw-bg-orange-600 tw-transition-colors tw-shadow-lg tw-shadow-orange-500/20">
                <i class="bi bi-shop"></i>
                Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="tw-p-6">
            <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-6">
                @foreach (var item in Model)
                {
                    var imagePath = item.Product.Images.FirstOrDefault()?.ImagePath ?? "/images/placeholder.jpg";
                    var isPriceDrop = item.Product.Price < item.PriceWhenAdded;

                    <div class="tw-group tw-border tw-border-slate-200 tw-rounded-xl tw-p-3 tw-transition-all hover:tw-shadow-md hover:tw-border-orange-200 hover:tw-bg-orange-50/10">
                        <div class="tw-flex tw-gap-4">
                            <!-- Image -->
                            <div class="tw-relative tw-w-28 tw-h-28 tw-flex-shrink-0 tw-rounded-lg tw-overflow-hidden tw-bg-slate-100">
                                <img src="@imagePath" class="tw-w-full tw-h-full tw-object-cover tw-transition-transform group-hover:tw-scale-105" alt="@item.Product.Name">
                                @if (isPriceDrop)
                                {
                                    <span class="tw-absolute tw-top-1 tw-left-1 tw-bg-green-500 tw-text-white tw-text-[10px] tw-font-bold tw-px-1.5 tw-py-0.5 tw-rounded">
                                        Price Drop
                                    </span>
                                }
                            </div>
                            
                            <!-- Content -->
                            <div class="tw-flex-1 tw-flex tw-flex-col tw-justify-between">
                                <div>
                                    <h6 class="tw-font-bold tw-text-slate-800 tw-mb-1 tw-line-clamp-2" title="@item.Product.Name">
                                        @item.Product.Name
                                    </h6>
                                    <div class="tw-flex tw-items-center tw-gap-2 tw-mb-1">
                                        <span class="tw-font-bold tw-text-orange-500 tw-text-lg tw-font-solaimanlipi">৳@item.Product.Price</span>
                                        @if (item.Product.OldPrice > item.Product.Price)
                                        {
                                            <span class="tw-text-xs tw-text-slate-400 tw-line-through tw-font-solaimanlipi">৳@item.Product.OldPrice</span>
                                        }
                                    </div>
                                    <p class="tw-text-[11px] tw-text-slate-400">
                                        Added on @item.AddedAt.ToString("MMM dd, yyyy")
                                    </p>
                                </div>
                                
                                <div class="tw-flex tw-gap-2 tw-mt-2">
                                    <button class="tw-flex-1 tw-bg-slate-800 tw-text-white tw-text-xs tw-font-bold tw-py-2 tw-rounded-lg hover:tw-bg-slate-700 tw-transition-colors tw-flex tw-items-center tw-justify-center tw-gap-1">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                    <form method="post" asp-action="Remove" asp-route-id="@item.Id">
                                        <button type="submit" class="tw-w-8 tw-h-8 tw-flex tw-items-center tw-justify-center tw-rounded-lg tw-border tw-border-red-200 tw-text-red-500 hover:tw-bg-red-50 tw-transition-colors" title="Remove">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
