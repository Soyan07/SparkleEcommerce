@using Sparkle.Domain.Sellers
@using Sparkle.Domain.Catalog
@model Seller
@{
    ViewData["Title"] = Model.ShopName + " - Sparkle Shop";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
}

<style>
    body {
        background: #f8f9fa;
    }

    .shop-banner {
        height: 120px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        margin-bottom: 50px;
    }

    .shop-profile-header {
        position: absolute;
        bottom: -35px;
        left: 50%;
        transform: translateX(-50%);
        max-width: 1200px;
        width: calc(100% - 40px);
        z-index: 10;
    }

    .shop-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px 28px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .shop-logo-container {
        width: 70px;
        height: 70px;
        background: #f1f3f9;
        border-radius: 10px;
        padding: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 24px;
        font-weight: 700;
        color: #667eea;
    }

    .shop-logo-container img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 6px;
    }

    .shop-info {
        flex: 1;
        min-width: 0;
    }

    .shop-name {
        font-size: 19px;
        font-weight: 700;
        margin-bottom: 3px;
        color: #1a1a1a;
    }

    .shop-location {
        font-size: 12px;
        color: #6b7280;
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .shop-stats {
        display: flex;
        gap: 28px;
        padding-left: 28px;
        border-left: 1px solid #e5e7eb;
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        font-weight: 700;
        color: #667eea;
        font-size: 17px;
        line-height: 1.2;
        margin-bottom: 3px;
    }

    .stat-label {
        font-size: 10px;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .content-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .sidebar-card {
        background: #fff;
        border-radius: 10px;
        padding: 18px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.04);
        border: 1px solid #f3f4f6;
        margin-bottom: 16px;
    }

    .sidebar-title {
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #1f2937;
    }

    .sidebar-text {
        font-size: 12px;
        color: #6b7280;
        line-height: 1.5;
        margin-bottom: 0;
    }

    .info-item {
        margin-bottom: 8px;
        font-size: 12px;
    }

    .info-item:last-child {
        margin-bottom: 0;
    }

    .info-label {
        font-weight: 600;
        color: #4b5563;
        margin-right: 4px;
    }

    .info-value {
        color: #6b7280;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .section-title {
        font-size: 17px;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
    }

    .sort-btn {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 7px;
        padding: 7px 14px;
        font-size: 12px;
        color: #4b5563;
        cursor: pointer;
        transition: all 0.2s;
    }

    .sort-btn:hover {
        border-color: #667eea;
        color: #667eea;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 16px;
    }

    .product-card {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.25s;
        border: 1px solid #f3f4f6;
        text-decoration: none;
        color: inherit;
    }

    .product-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        border-color: #e5e7eb;
    }

    .product-img {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        background: #f9fafb;
    }

    .product-info {
        padding: 14px;
    }

    .product-title {
        font-size: 13px;
        font-weight: 500;
        color: #1f2937;
        margin-bottom: 6px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        height: 36px;
    }

    .product-price {
        color: #667eea;
        font-weight: 700;
        font-size: 16px;
        margin-bottom: 6px;
    }

    .product-rating {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #9ca3af;
    }

    .empty-icon {
        font-size: 56px;
        margin-bottom: 12px;
    }
</style>

<div class="shop-banner">
    <div class="shop-profile-header">
        <div class="shop-card">
            <div class="shop-logo-container">
                @if (!string.IsNullOrEmpty(Model.StoreLogo))
                {
                    <img src="@Model.StoreLogo" alt="@Model.ShopName">
                }
                else
                {
                    @Model.ShopName.Substring(0, Math.Min(2, Model.ShopName.Length)).ToUpper()
                }
            </div>
            <div class="shop-info">
                <h1 class="shop-name">@Model.ShopName</h1>
                <div class="shop-location">
                    <i class="bi bi-geo-alt"></i>
                    <span>@Model.City, Bangladesh</span>
                </div>
            </div>
            <div class="shop-stats">
                <div class="stat-item">
                    <div class="stat-value">@Model.Rating.ToString("F1")</div>
                    <div class="stat-label">Rating</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">@products.Count</div>
                    <div class="stat-label">Products</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">98%</div>
                    <div class="stat-label">Positive</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="content-wrapper mb-4">
    <div class="row">
        <div class="col-lg-3">
            <div class="sidebar-card">
                <h5 class="sidebar-title">About the Shop</h5>
                <p class="sidebar-text">@(Model.ShopDescription ?? "Laptops, desktops, accessories, and IT solutions. Trusted by 5000+ customers across Bangladesh.")</p>
                <hr class="my-2" style="opacity: 0.1;">
                <div class="info-item">
                    <span class="info-label">Joined:</span>
                    <span class="info-value">@Model.CreatedAt.ToString("MMM yyyy")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Location:</span>
                    <span class="info-value">@(Model.BusinessAddress ?? Model.City + ", " + Model.District)</span>
                </div>
            </div>
        </div>
        <div class="col-lg-9">
            <div class="section-header">
                <h4 class="section-title">All Products</h4>
                <div class="dropdown">
                    <button class="sort-btn dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Sort by: Newest
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Price: Low to High</a></li>
                        <li><a class="dropdown-item" href="#">Price: High to Low</a></li>
                        <li><a class="dropdown-item" href="#">Best Rating</a></li>
                    </ul>
                </div>
            </div>

            @if (products.Any())
            {
                <div class="product-grid">
                    @foreach (var p in products)
                    {
                        <a href="/Home/Product/@p.Id" class="product-card">
                            <img src="@(p.Images?.FirstOrDefault()?.Url ?? "https://via.placeholder.com/210")" class="product-img" alt="@p.Title">
                            <div class="product-info">
                                <div class="product-title">@p.Title</div>
                                <div class="product-price">৳@p.BasePrice.ToString("N0")</div>
                                <div class="product-rating">
                                    <span class="text-warning">
                                        @for(int i=0; i<5; i++) { <i class="bi bi-star-fill" style="font-size: 10px;"></i> }
                                    </span>
                                    <span class="text-muted">(12)</span>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <p class="mb-0">No products found in this shop.</p>
                </div>
            }
        </div>
    </div>
</div>
