@model List<NotificationItem>
@{
    ViewData["Title"] = "Notifications";
    Layout = "_ProfileLayout";
}

<div class="tw-bg-white tw-rounded-2xl tw-border tw-border-slate-100 tw-overflow-hidden tw-shadow-sm">
    <!-- Header -->
    <div class="tw-px-6 tw-py-4 tw-border-b tw-border-slate-50 tw-flex tw-justify-between tw-items-center">
        <div>
            <h6 class="tw-font-bold tw-text-slate-900 tw-text-base tw-mb-0">
                <i class="bi bi-bell tw-mr-1.5 tw-text-orange-500"></i> Notifications
            </h6>
            <p class="tw-text-[11px] tw-text-slate-500 tw-mb-0">Stay updated with your latest activities</p>
        </div>
        @if (Model != null && Model.Any(n => !n.IsRead))
        {
            <button class="tw-bg-slate-50 tw-text-slate-600 tw-px-3 tw-py-1.5 tw-rounded-xl tw-text-[11px] tw-font-bold hover:tw-bg-slate-100 tw-transition-all tw-flex tw-items-center tw-gap-1.5" onclick="markAllAsRead()">
                <i class="bi bi-check2-all"></i> Mark All Read
            </button>
        }
    </div>

    <!-- Filter Section -->
    <div class="tw-px-6 tw-py-3 tw-bg-slate-50/30 tw-border-b tw-border-slate-50">
        <div class="tw-flex tw-gap-2 tw-overflow-x-auto tw-pb-1 no-scrollbar">
            <button class="filter-tab tw-px-4 tw-py-1.5 tw-rounded-xl tw-text-[11px] tw-font-bold tw-transition-all tw-whitespace-nowrap active tw-bg-orange-500 tw-text-white tw-shadow-md tw-shadow-orange-500/20" data-filter="all">All</button>
            <button class="filter-tab tw-px-4 tw-py-1.5 tw-rounded-xl tw-text-[11px] tw-font-bold tw-transition-all tw-whitespace-nowrap tw-bg-white tw-text-slate-600 tw-border tw-border-slate-100 hover:tw-border-orange-200" data-filter="order">Orders</button>
            <button class="filter-tab tw-px-4 tw-py-1.5 tw-rounded-xl tw-text-[11px] tw-font-bold tw-transition-all tw-whitespace-nowrap tw-bg-white tw-text-slate-600 tw-border tw-border-slate-100 hover:tw-border-orange-200" data-filter="message">Messages</button>
            <button class="filter-tab tw-px-4 tw-py-1.5 tw-rounded-xl tw-text-[11px] tw-font-bold tw-transition-all tw-whitespace-nowrap tw-bg-white tw-text-slate-600 tw-border tw-border-slate-100 hover:tw-border-orange-200" data-filter="promo">Promos</button>
            <button class="filter-tab tw-px-4 tw-py-1.5 tw-rounded-xl tw-text-[11px] tw-font-bold tw-transition-all tw-whitespace-nowrap tw-bg-white tw-text-slate-600 tw-border tw-border-slate-100 hover:tw-border-orange-200" data-filter="system">System</button>
        </div>
    </div>

    <!-- Notifications List -->
    <div id="notificationsList" class="tw-divide-y tw-divide-slate-50">
        @if (Model != null && Model.Any())
        {
            @foreach (var notification in Model)
            {
                var (iconBg, iconColor, icon) = notification.Type.ToLower() switch
                {
                    "order" => ("tw-bg-blue-50", "tw-text-blue-600", "bi-box-seam"),
                    "message" => ("tw-bg-emerald-50", "tw-text-emerald-600", "bi-chat-dots"),
                    "promo" => ("tw-bg-amber-50", "tw-text-amber-600", "bi-tag"),
                    _ => ("tw-bg-slate-50", "tw-text-slate-500", "bi-info-circle")
                };

                <div class="notification-item tw-flex tw-items-start tw-gap-4 tw-px-6 tw-py-5 hover:tw-bg-slate-50/50 tw-transition-all tw-group @(notification.IsRead ? "" : "tw-bg-orange-50/20 tw-border-l-4 tw-border-orange-500")" data-type="@notification.Type">
                    <div class="tw-w-10 tw-h-10 tw-rounded-2xl @iconBg @iconColor tw-flex tw-items-center tw-justify-center tw-text-lg tw-flex-shrink-0 tw-transition-all group-hover:tw-scale-110">
                        <i class="bi @icon"></i>
                    </div>
                    
                    <div class="tw-flex-1 tw-min-w-0">
                        <div class="tw-flex tw-justify-between tw-items-start tw-gap-2">
                            <h6 class="tw-font-bold tw-text-slate-900 tw-text-sm tw-mb-1 tw-truncate">@notification.Title</h6>
                            <span class="tw-text-[10px] tw-text-slate-400 tw-font-medium tw-whitespace-nowrap tw-mt-1">@FormatTime(notification.CreatedAt)</span>
                        </div>
                        <p class="tw-text-xs tw-text-slate-600 tw-mb-0 tw-leading-relaxed">@notification.Message</p>
                    </div>

                    <div class="tw-flex tw-gap-1.5 tw-opacity-0 group-hover:tw-opacity-100 tw-transition-all">
                        @if (!notification.IsRead)
                        {
                            <button class="tw-w-8 tw-h-8 tw-rounded-xl tw-bg-white tw-border tw-border-slate-100 tw-text-slate-400 hover:tw-text-orange-500 hover:tw-border-orange-200 tw-flex tw-items-center tw-justify-center tw-transition-all" onclick="markAsRead(@notification.Id)" title="Mark read">
                                <i class="bi bi-check2"></i>
                            </button>
                        }
                        <button class="tw-w-8 tw-h-8 tw-rounded-xl tw-bg-white tw-border tw-border-slate-100 tw-text-slate-400 hover:tw-text-red-500 hover:tw-border-red-200 tw-flex tw-items-center tw-justify-center tw-transition-all" onclick="deleteNotification(@notification.Id)" title="Delete">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="tw-text-center tw-py-20 tw-px-6">
                <div class="tw-w-16 tw-h-16 tw-mx-auto tw-mb-4 tw-bg-slate-50 tw-rounded-3xl tw-flex tw-items-center tw-justify-center tw-text-slate-300">
                    <i class="bi bi-bell-slash tw-text-2xl"></i>
                </div>
                <h6 class="tw-font-bold tw-text-slate-900 tw-text-base tw-mb-1">All caught up!</h6>
                <p class="tw-text-xs tw-text-slate-500 tw-mb-0">You don't have any new notifications at the moment.</p>
            </div>
        }
    </div>
</div>

@functions {
    string FormatTime(DateTime dt)
    {
        var now = DateTime.UtcNow;
        var diff = now - dt;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM d");
    }
}

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

@section Scripts {
    <script>
        // Filter functionality
        const tabs = document.querySelectorAll('.filter-tab');
        const items = document.querySelectorAll('.notification-item');

        tabs.forEach(tab => {
            tab.addEventListener('click', function() {
                // Update active tab styling
                tabs.forEach(t => {
                    t.classList.remove('tw-bg-orange-500', 'tw-text-white', 'tw-shadow-md', 'tw-shadow-orange-500/20', 'active');
                    t.classList.add('tw-bg-white', 'tw-text-slate-600', 'tw-border', 'tw-border-slate-100');
                });
                
                this.classList.remove('tw-bg-white', 'tw-text-slate-600', 'tw-border', 'tw-border-slate-100');
                this.classList.add('tw-bg-orange-500', 'tw-text-white', 'tw-shadow-md', 'tw-shadow-orange-500/20', 'active');

                const filter = this.dataset.filter;
                items.forEach(item => {
                    const type = item.dataset.type.toLowerCase();
                    if (filter === 'all' || type === filter) {
                        item.classList.remove('tw-hidden');
                        item.classList.add('tw-flex');
                    } else {
                        item.classList.add('tw-hidden');
                        item.classList.remove('tw-flex');
                    }
                });
            });
        });

        function markAsRead(id) {
            fetch(`/account-info/notifications/mark-read/${id}`, { method: 'POST' })
                .then(() => location.reload());
        }

        function deleteNotification(id) {
            if (confirm('Permanently delete this notification?')) {
                fetch(`/account-info/notifications/delete/${id}`, { method: 'POST' })
                    .then(() => location.reload());
            }
        }

        function markAllAsRead() {
            fetch('/account-info/notifications/mark-all-read', { method: 'POST' })
                .then(() => location.reload());
        }
    </script>
}
