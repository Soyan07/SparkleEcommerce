@model Sparkle.Api.Controllers.ProfileController.ProfileViewModel
@{
    ViewData["Title"] = "Account Info";
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
}

<!-- Stats Cards Row -->
<div class="row g-4 mb-5">
    <!-- Total Orders Card -->
    <div class="col-md-4">
        <div class="tw-bg-[#3949f5] tw-rounded-[10px] tw-p-5 tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center tw-h-full tw-shadow-sm tw-text-white tw-min-h-[140px]" style="background-color: #3949f5;">
            <div class="tw-w-10 tw-h-10 tw-rounded-md tw-bg-white/20 tw-flex tw-items-center tw-justify-center tw-mb-3">
                <i class="bi bi-box-seam tw-text-xl"></i>
            </div>
            <div class="tw-text-[28px] tw-font-bold tw-leading-none tw-mb-1.5">@Model.TotalOrders</div>
            <div class="tw-text-[11px] tw-font-bold tw-uppercase tw-tracking-widest">Total Orders</div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="tw-bg-[#10b981] tw-rounded-[10px] tw-p-5 tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center tw-h-full tw-shadow-sm tw-text-white tw-min-h-[140px]" style="background-color: #10b981;">
             <div class="tw-w-10 tw-h-10 tw-rounded-md tw-bg-white/20 tw-flex tw-items-center tw-justify-center tw-mb-3">
                <i class="bi bi-wallet2 tw-text-xl"></i>
            </div>
            <div class="tw-text-[28px] tw-font-bold tw-flex tw-items-baseline tw-justify-center tw-leading-none tw-mb-1.5">
                <span class="tw-text-2xl tw-mr-1.5 tw-font-solaimanlipi">৳</span>@Model.TotalSpent.ToString("N0")
            </div>
            <div class="tw-text-[11px] tw-font-bold tw-uppercase tw-tracking-widest">Total Spent</div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="tw-bg-[#f97316] tw-rounded-[10px] tw-p-5 tw-flex tw-flex-col tw-items-center tw-justify-center tw-text-center tw-h-full tw-shadow-sm tw-text-white tw-min-h-[140px]" style="background-color: #f97316;">
             <div class="tw-w-10 tw-h-10 tw-rounded-md tw-bg-white/20 tw-flex tw-items-center tw-justify-center tw-mb-3">
                <i class="bi bi-star tw-text-xl"></i>
            </div>
            <div class="tw-text-[28px] tw-font-bold tw-leading-none tw-mb-1.5">0</div>
            <div class="tw-text-[11px] tw-font-bold tw-uppercase tw-tracking-widest">Reward Points</div>
        </div>
    </div>
</div>

<!-- Main Content Area (Two Columns) -->
<div class="row g-4">
    
    <!-- Left Column: Recent Orders -->
    <div class="col-lg-7">
        <div class="tw-bg-white tw-rounded-sm tw-p-6">
            <div class="tw-flex tw-justify-between tw-items-center tw-mb-6">
                <h6 class="tw-text-xl tw-font-bold tw-text-slate-900 tw-mb-0">Recent Orders</h6>
                @if (Model.TotalOrders > 7)
                {
                    <a href="/orders" class="tw-text-sm tw-font-semibold tw-text-orange-500 hover:tw-text-orange-600 tw-no-underline hover:tw-underline tw-transition-colors">
                        View All
                    </a>
                }
            </div>
            
            @if (Model.RecentOrders != null && Model.RecentOrders.Any())
            {
                <div class="tw-flex tw-flex-col tw-gap-5">
                    @foreach (var order in Model.RecentOrders.Take(5))
                    {
                        var (statusBg, statusText) = order.Status.ToString() switch
                        {
                            "Pending" => ("tw-bg-orange-50", "tw-text-orange-600"),
                            "Confirmed" => ("tw-bg-blue-50", "tw-text-blue-700"),
                            "Packed" => ("tw-bg-indigo-50", "tw-text-indigo-700"),
                            "Shipped" => ("tw-bg-purple-50", "tw-text-purple-700"),
                            "Delivered" => ("tw-bg-emerald-50", "tw-text-emerald-700"),
                            "Cancelled" => ("tw-bg-red-50", "tw-text-red-700"),
                            _ => ("tw-bg-slate-50", "tw-text-slate-700")
                        };
                        
                        <a href="@Url.Action("Details", "Order", new { id = order.Id })" class="tw-block tw-group tw-no-underline hover:tw-opacity-80 tw-transition-opacity">
                            <div class="tw-flex tw-justify-between tw-items-start">
                                <div>
                                    <div class="tw-flex tw-items-center tw-gap-3 tw-mb-2">
                                        <div class="tw-text-[15px] tw-font-bold tw-text-slate-900 group-hover:tw-text-orange-500 tw-transition-colors">#@order.OrderNumber</div>
                                        <span class="tw-inline-flex tw-items-center tw-px-2 tw-py-0.5 tw-rounded-sm tw-text-[10px] tw-font-bold tw-uppercase tw-tracking-wide @statusBg @statusText">
                                            @order.Status
                                        </span>
                                    </div>
                                    <div class="tw-text-[13px] tw-text-slate-500 tw-flex tw-items-center tw-gap-2">
                                        <span>@order.OrderDate.ToString("MMM d, yyyy")</span>
                                        <span class="tw-w-1 tw-h-1 tw-rounded-full tw-bg-slate-300"></span>
                                        <span class="tw-truncate tw-max-w-[220px]" title="@(order.OrderItems?.FirstOrDefault()?.ProductName ?? "Items")">
                                            @(order.OrderItems?.FirstOrDefault()?.ProductName ?? "Items")
                                            @if (order.OrderItems?.Count > 1) { <text>(+@(order.OrderItems.Count - 1))</text> }
                                        </span>
                                    </div>
                                </div>
                                <div class="tw-text-right mt-1">
                                    <div class="tw-text-[16px] tw-font-bold tw-text-slate-900 tw-flex tw-items-baseline tw-justify-end">
                                        <span class="tw-text-[14px] tw-mr-0.5 tw-font-bold tw-text-slate-900 tw-font-solaimanlipi">৳</span>@order.TotalAmount.ToString("N0")
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="tw-text-center tw-py-8">
                    <i class="bi bi-box-seam tw-text-3xl tw-text-slate-300 tw-mb-3 tw-block"></i>
                    <h6 class="tw-text-sm tw-font-bold tw-text-slate-900 tw-mb-1">No Orders Yet</h6>
                    <p class="tw-text-sm tw-text-slate-500 tw-mb-4">Start shopping to see your orders here.</p>
                    <a href="/" class="tw-inline-flex tw-items-center tw-gap-2 tw-bg-orange-500 tw-text-white tw-px-4 tw-py-2 tw-rounded-md tw-font-semibold tw-text-sm hover:tw-bg-orange-600 tw-transition-colors tw-no-underline">
                        <i class="bi bi-shop"></i> Browse Products
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Address Book -->
    <div class="col-lg-5">
        <div class="tw-bg-white tw-rounded-sm tw-p-6 tw-flex tw-flex-col tw-h-full">
            <div class="tw-flex tw-justify-between tw-items-center tw-mb-6">
                <h6 class="tw-text-xl tw-font-bold tw-text-slate-900 tw-mb-0">Default Address</h6>
                <a href="/profile/addresses" class="tw-text-sm tw-font-semibold tw-text-orange-500 hover:tw-text-orange-600 tw-no-underline hover:tw-underline tw-transition-colors">
                    Manage
                </a>
            </div>

            <div class="tw-flex-1 tw-flex tw-flex-col">
            @if (Model.DefaultAddress != null)
            {
                <div class="tw-flex-1 tw-flex tw-flex-col">
                    <div class="tw-flex tw-justify-between tw-items-start tw-mb-2">
                        <div class="tw-flex tw-items-center tw-gap-2">
                            <span class="tw-bg-slate-800 tw-text-white tw-text-[10px] tw-font-bold tw-px-2 tw-py-0.5 tw-rounded-sm tw-uppercase tw-tracking-wide">@Model.DefaultAddress.AddressType</span>
                            <span class="tw-text-[16px] tw-font-bold tw-text-slate-900">@Model.DefaultAddress.FullName</span>
                        </div>
                    </div>
                    <div class="tw-text-[14px] tw-text-slate-600 tw-leading-relaxed tw-mb-3">
                        @Model.DefaultAddress.AddressLine1
                        @if(!string.IsNullOrEmpty(Model.DefaultAddress.AddressLine2)) { <br>@Model.DefaultAddress.AddressLine2 }
                        <br>@Model.DefaultAddress.City, @Model.DefaultAddress.Country @Model.DefaultAddress.PostalCode
                    </div>
                    <div class="tw-flex tw-items-center tw-gap-2 tw-text-[14px] tw-text-slate-700 tw-font-medium tw-mb-4">
                        <i class="bi bi-telephone tw-text-slate-400"></i> @Model.DefaultAddress.PhoneNumber
                    </div>
                    
                    <div class="tw-w-full tw-flex-1 tw-min-h-[200px] tw-bg-slate-100 tw-rounded-md tw-overflow-hidden tw-border tw-border-slate-200">
                        <iframe width="100%" height="100%" frameborder="0" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://maps.google.com/maps?q=@Uri.EscapeDataString(Model.DefaultAddress.City + ", " + Model.DefaultAddress.Country)&t=&z=13&ie=UTF8&iwloc=&output=embed"></iframe>
                    </div>
                </div>
            }
            else
            {
                <div class="tw-flex-1 tw-flex tw-flex-col tw-items-center tw-justify-center tw-bg-slate-50 tw-border-2 tw-border-dashed tw-border-slate-300 tw-rounded-xl tw-p-8 tw-text-center tw-h-full tw-min-h-[240px] tw-transition-colors hover:tw-border-orange-300">
                    <div class="tw-w-14 tw-h-14 tw-bg-orange-100 tw-text-orange-500 tw-rounded-full tw-flex tw-items-center tw-justify-center tw-mb-4 tw-shadow-sm" style="background-color: #ffedd5; color: #f97316;">
                        <i class="bi bi-geo-alt tw-text-2xl"></i>
                    </div>
                    <h6 class="tw-text-lg tw-font-bold tw-text-slate-800 tw-mb-1.5">No Default Address</h6>
                    <p class="tw-text-xs tw-text-slate-500 tw-mb-6 tw-max-w-xs">Add your shipping details to receive your orders quickly and securely.</p>
                    <a href="/addresses/create" class="tw-inline-flex tw-items-center tw-justify-center tw-px-5 tw-py-2 tw-bg-orange-500 tw-text-white tw-rounded-lg tw-font-semibold tw-text-sm tw-shadow-sm hover:tw-bg-orange-600 hover:tw-shadow-md tw-transition-all tw-no-underline" style="background-color: #f97316;">
                        <i class="bi bi-plus-lg tw-mr-1.5"></i> Add New Address
                    </a>
                </div>
            }
            </div>
        </div>
    </div>
</div>

