    const inputState = document.getElementById('inputState');
    const inputCity = document.getElementById('inputCity');
    const inputArea = document.getElementById('inputArea');

    function openAddressModal() {
        document.getElementById('newAddressForm').reset();
        document.getElementById('editAddressId').value = '';
        document.getElementById('modalTitle').textContent = 'Add New Shipping Address';
        document.getElementById('addressModal').style.display = 'flex';
        
        // Reset Logic
        populateDropdown(inputState, Object.keys(locationData), 'Please choose your region');
        populateDropdown(inputCity, [], 'Please choose your city');
        populateDropdown(inputArea, [], 'Please choose your area');
        
        // Reset labels
        document.querySelectorAll('.label-btn').forEach(b => {
            b.classList.remove('active');
            b.style.borderColor = '#ddd';
            b.style.color = '#555';
        });
        // Default Home
        selectLabel(document.querySelector('label[for="lblHome"]'), 'home');
    }

    function populateDropdown(select, items, placeholder) {
        select.innerHTML = `<option value="">${placeholder}</option>`;
        items.forEach(item => {
            const option = document.createElement('option');
            option.value = item;
            option.textContent = item;
            select.appendChild(option);
        });
    }

    // Cascading Logic
    inputState.addEventListener('change', function() {
        const division = this.value;
        if (division && locationData[division]) {
            populateDropdown(inputCity, Object.keys(locationData[division]), 'Please choose your city');
        } else {
            populateDropdown(inputCity, [], 'Please choose your city');
        }
        populateDropdown(inputArea, [], 'Please choose your area');
    });

    inputCity.addEventListener('change', function() {
        const division = inputState.value;
        const district = this.value;
        if (division && district && locationData[division] && locationData[division][district]) {
            populateDropdown(inputArea, locationData[division][district], 'Please choose your area');
        } else {
            populateDropdown(inputArea, [], 'Please choose your area');
        }
    });

    function deleteAddress(id) {
        if(confirm('Are you sure you want to delete this address?')) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '/checkout/delete-address';
            
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'id';
            input.value = id;
            
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }
    }

    function editAddress(data, event) {
        event.stopPropagation(); // Prevent row selection
        openAddressModal(); // Resets everything first
        
        document.getElementById('modalTitle').textContent = 'Edit Shipping Address';
        document.getElementById('editAddressId').value = data.Id;
        
        document.getElementById('inputFullName').value = data.FullName || '';
        document.getElementById('inputPhone').value = data.Phone || '';
        document.getElementById('inputLine1').value = data.Line1 || '';
        document.getElementById('inputLine2').value = data.Line2 || '';

        // Set Default Checkbox
        document.getElementById('checkDefaultShipping').checked = data.IsDefault;
        // Mock billing for now match IsDefault
        document.getElementById('checkDefaultBilling').checked = data.IsDefault;
        
        // Set Cascading Values
        if (data.State) {
            inputState.value = data.State;
            // Trigger manual cascade for City
            if (locationData[data.State]) {
                populateDropdown(inputCity, Object.keys(locationData[data.State]), 'Please choose your city');
                if (data.City) {
                    inputCity.value = data.City;
                    // Trigger manual cascade for Area
                    if (locationData[data.State][data.City]) {
                        populateDropdown(inputArea, locationData[data.State][data.City], 'Please choose your area');
                        if (data.Area) {
                            inputArea.value = data.Area;
                        }
                    }
                }
            }
        }
        
        // Infer label
        let isOffice = (data.Line1 + (data.Line2 || '')).toLowerCase().includes('office');
        if(isOffice) {
             selectLabel(document.querySelector('label[for="lblOffice"]'), 'office');
        } else {
             selectLabel(document.querySelector('label[for="lblHome"]'), 'home');
        }
    }

    function closeAddressModal() {
        document.getElementById('addressModal').style.display = 'none';
        document.body.removeChild(document.getElementById('addressModal')); // Remove from body if appended
        document.body.appendChild(document.getElementById('addressModal')); // Re-append to container if needed, but display:none is fine
        // Note: The move-to-body logic on load makes it permanent in body. 
        // We just toggle display.
    }

    function selectLabel(btn, type) {
        if(!btn) return;
        document.querySelectorAll('.label-btn').forEach(b => {
            b.classList.remove('active');
            b.style.borderColor = '#ddd';
            b.style.color = '#555';
        });
        btn.classList.add('active');
        btn.style.borderColor = '#f85606';
        btn.style.color = '#f85606';
    }

    function selectAddress(id, rowElement) {
        const radio = rowElement.querySelector('input[type="radio"]');
        radio.checked = true;
        document.getElementById('selectedAddressIdInput').value = id;
    }

    function submitSelection() {
        const selectedId = document.getElementById('selectedAddressIdInput').value;
        if (!selectedId) {
             const firstRadio = document.querySelector('input[name="address_radio"]');
             if(firstRadio) {
                 firstRadio.checked = true;
                 document.getElementById('selectedAddressIdInput').value = firstRadio.value;
             } else {
                 alert("Please add a shipping address first");
                 return;
             }
        }
        
        // Show loading state
        const btn = document.querySelector('.checkout-btn');
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
        btn.disabled = true;
        
        document.getElementById('selectAddressForm').submit();
    }
    
    // Auto-select Default & Move Modal
    window.onload = function() {
        const checked = document.querySelector('input[name="address_radio"]:checked');
        if(checked) {
             document.getElementById('selectedAddressIdInput').value = checked.value;
        } else {
             const first = document.querySelector('input[name="address_radio"]');
             if(first) {
                 first.checked = true;
                 document.getElementById('selectedAddressIdInput').value = first.value;
             }
        }
        
        const modal = document.getElementById('addressModal');
        if(modal) {
            document.body.appendChild(modal);
        }
        
        // Initial Populate
        populateDropdown(inputState, Object.keys(locationData), 'Please choose your region');
    }
</script>
