@model Sparkle.Api.Controllers.CartController.CartViewModel
@{
    ViewData["Title"] = "Your Cart";
}

<style>
    /* ========================================
       PREMIUM CART STYLES (Orange Theme)
       ======================================== */
    
    :root {
        --cart-font: 'Inter', system-ui, -apple-system, sans-serif;
        --cart-bg: #f5f5f5;
        --cart-text: #212121;
        --cart-text-light: #757575;
        --cart-border: #eff0f5;
        --cart-primary: #6706f8ff; /* Daraz Orange */
        --cart-link: #1a9cb7;
    }

    body {
        background-color: var(--cart-bg);
        font-family: var(--cart-font);
    }

    .cart-page-wrapper {
        max-width: 1188px;
        margin: 20px auto;
        padding: 0;
        color: var(--cart-text);
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .cart-items-column {
        flex: 1;
        min-width: 0;
    }

    .cart-summary-column {
        width: 380px;
        flex-shrink: 0;
    }

    /* Selection Header */
    .selection-header {
        background: #fff;
        padding: 12px 16px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        text-transform: uppercase;
        color: var(--cart-text-light);
        border-radius: 0;
    }

    .select-all-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
        color: var(--cart-text-light);
    }

    /* Custom Checkbox */
    .custom-checkbox {
        width: 18px;
        height: 18px;
        border: 1px solid #999;
        background: #fff;
        border-radius: 2px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        appearance: none;
        -webkit-appearance: none;
        position: relative;
    }
    .custom-checkbox:checked {
        background-color: var(--cart-primary);
        border-color: var(--cart-primary);
    }
    .custom-checkbox:checked::after {
        content: '✔';
        font-size: 12px;
        color: white;
        line-height: 1;
    }

    .delete-btn {
        color: var(--cart-text-light);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;
        font-weight: 600;
        border: none;
        background: none;
    }
    .delete-btn:hover { color: var(--cart-primary); }

    /* Shop Group */
    .shop-group {
        background: #fff;
        margin-bottom: 12px;
        border-radius: 0;
    }

    .shop-header {
        padding: 12px 16px;
        border-bottom: 1px solid var(--cart-border);
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        color: #212121;
    }
    .shop-header a { text-decoration: none; color: #212121; font-weight: 500;}
    .shop-header a:hover { text-decoration: underline; }

    /* Cart Item */
    .cart-item {
        padding: 16px;
        border-bottom: 1px solid var(--cart-border);
        display: flex;
        gap: 16px;
    }
    .cart-item:last-child { border-bottom: none; }

    .item-checkbox {
        padding-top: 4px; /* Align with image top */
    }

    .product-thumb {
        width: 80px;
        height: 80px;
        object-fit: cover;
    }

    .item-details {
        flex: 1;
    }

    .product-title {
        font-size: 14px !important;
        line-height: 20px !important;
        margin-bottom: 6px;
        color: #212121;
        max-width: 400px;
        font-weight: 500;
        display: block;
    }
    .product-title a { color: inherit; text-decoration: none; }
    .product-title a:hover { color: var(--cart-primary); }

    .product-meta {
        font-size: 12px;
        color: var(--cart-text-light);
        margin-bottom: 4px;
    }

    .price-original {
        text-decoration: line-through;
        color: var(--cart-text-light);
        font-size: 12px;
        margin-right: 4px;
    }

    .price-current {
        color: var(--cart-primary);
        font-size: 18px;
        font-weight: 500;
    }

    .item-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 8px;
    }

    .action-icon {
        color: var(--cart-text-light);
        font-size: 16px;
        cursor: pointer;
        transition: color 0.2s;
        background: none;
        border: none;
        padding: 0;
    }
    .action-icon:hover { color: var(--cart-primary); }

    /* Quantity Control */
    .qty-control {
        display: flex;
        align-items: center;
    }
    .qty-btn {
        width: 28px;
        height: 28px;
        background: #eff0f5;
        border: none;
        font-size: 16px;
        color: #9e9e9e;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }
    .qty-btn:hover { background: #e0e0e0; color: #757575; }
    
    .qty-display {
        width: 40px;
        height: 28px;
        border: none;
        text-align: center;
        font-size: 14px;
        color: #212121;
    }

    /* Summary Card */
    .summary-card {
        background: #fff;
        padding: 12px;
    }

    .bg-white { background: #fff; }

    .summary-title {
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 12px;
        color: #212121;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 14px;
        color: #757575;
    }
    .summary-row.total {
        margin-top: 16px;
        color: #212121;
        font-size: 18px;
    }
    .total-amount {
        color: var(--cart-primary);
        font-weight: 500;
    }

    .checkout-btn {
        display: block;
        width: 100%;
        background-color: var(--cart-primary);
        color: white;
        text-align: center;
        padding: 12px 0;
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        border: none;
        border-radius: 2px;
        text-decoration: none;
        margin-top: 16px;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    .checkout-btn:hover {
        background-color: #d34b05;
    }

    .coupon-input-group {
        display: flex;
        gap: 8px;
        margin-top: 20px;
    }
    .coupon-input {
        flex: 1;
        padding: 8px;
        border: 1px solid #eff0f5;
        border-radius: 2px;
        font-size: 14px;
    }
    .coupon-btn {
        background: #1a9cb7;
        color: white;
        border: none;
        padding: 0 20px;
        font-weight: 500;
        font-size: 14px;
        cursor: pointer;
        border-radius: 2px;
    }

    /* Responsive */
    @@media (max-width: 991px) {
        .cart-page-wrapper {
            flex-direction: column;
            padding: 0 10px;
        }
        .cart-summary-column {
            width: 100%;
        }
    }
</style>

<div class="cart-page-wrapper">
    
    @if (!Model.Cart.Items.Any())
    {
         <div class="cart-items-column bg-white" style="text-align: center; padding: 60px 20px;">
            <img src="https://via.placeholder.com/150/f5f5f5/cccccc?text=Empty+Cart" alt="Empty Cart" style="width: 100px; margin-bottom: 20px; opacity: 0.5;">
            <p style="font-size: 14px; color: #757575; margin-bottom: 16px;">There are no items in this cart</p>
            <a href="/" style="display: inline-block; padding: 10px 40px; border: 1px solid var(--cart-primary); color: var(--cart-primary); text-transform: uppercase; font-weight: 500; text-decoration: none; font-size: 14px;">Continue Shopping</a>
        </div>
    }
    else
    {
        <!-- Left Column: Items -->
        <div class="cart-items-column">
            
            <!-- Global Select All -->
            <div class="selection-header">
                <label class="select-all-wrap">
                    <input type="checkbox" class="custom-checkbox" checked>
                    SELECT ALL (@Model.Cart.Items.Sum(i => i.Quantity) ITEM(S))
                </label>
                <button class="delete-btn">
                    <i class="bi bi-trash"></i> DELETE
                </button>
            </div>

            <!-- Group items by Seller -->
            @{
                var groups = Model.Cart.Items.GroupBy(i => i.ProductVariant.Product.Seller).ToList();
            }

            @foreach (var group in groups)
            {
                var seller = group.Key;
                var shopName = seller?.ShopName ?? "Sparkle Official";
                var shopId = seller?.Id ?? 0;

                <div class="shop-group">
                    <div class="shop-header">
                        <input type="checkbox" class="custom-checkbox" checked>
                        <i class="bi bi-shop" style="color: #757575;"></i>
                        <a href="/shop/@shopId">@shopName</a>
                        <i class="bi bi-chevron-right" style="font-size: 12px; color: #757575;"></i>
                    </div>

                    @foreach (var item in group)
                    {
                        var product = item.ProductVariant.Product;
                        var variant = item.ProductVariant;
                        var imageUrl = product.Images?.FirstOrDefault()?.Url ?? "https://via.placeholder.com/150";
                        var lineTotal = item.UnitPrice * item.Quantity;
                        
                        // Fake discount data for visuals
                        var fakeOriginalPrice = item.UnitPrice * 1.2m; 
                        var discountPercent = "-20%";

                        <div class="cart-item">
                            <div class="item-checkbox">
                                <input type="checkbox" class="custom-checkbox" checked>
                            </div>
                            
                            <img src="@imageUrl" alt="@product.Title" class="product-thumb">
                            
                            <div class="item-details">
                                <h3 class="product-title"><a href="/product/@product.Id">@product.Title</a></h3>
                                <div class="product-meta">
                                    @if (!string.IsNullOrEmpty(variant.Color)) { <span>Color Family: @variant.Color, </span> }
                                    @if (!string.IsNullOrEmpty(variant.Size)) { <span>Size: @variant.Size</span> }
                                </div>
                                <div class="product-brand" style="font-size: 12px; color: #757575; margin-bottom: 8px;">
                                    Brand: No Brand
                                </div>
                            </div>

                            <div class="item-pricing" style="text-align: right; min-width: 100px;">
                                <div class="price-current">৳ @item.UnitPrice.ToString("N0")</div>
                                <div style="margin-bottom: 8px;">
                                    <span class="price-original">৳ @fakeOriginalPrice.ToString("N0")</span>
                                    <span style="font-size: 12px; color: #212121;">@discountPercent</span>
                                </div>
                                
                                <div style="display: flex; gap: 12px; justify-content: flex-end; align-items: center;">
                                    <div class="item-actions">
                                        <form method="post" action="/cart/remove" style="display:inline;">
                                            <input type="hidden" name="itemId" value="@item.Id">
                                            <button type="submit" class="action-icon" title="Remove"><i class="bi bi-trash"></i></button>
                                        </form>
                                        <button class="action-icon" title="Add to Wishlist"><i class="bi bi-heart"></i></button>
                                    </div>

                                    <div class="qty-control">
                                        <form method="post" action="/cart/update" id="form-update-@item.Id" style="display: flex;">
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <button type="button" class="qty-btn" onclick="updateQty(@item.Id, -1)">−</button>
                                            <input type="text" name="quantity" class="qty-display" value="@item.Quantity" readonly>
                                            <button type="button" class="qty-btn" onclick="updateQty(@item.Id, 1)">+</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>

        <!-- Right Column: Summary -->
        <div class="cart-summary-column">
            <div class="summary-card">
                <div style="font-size: 14px; color: #757575; margin-bottom: 4px;">Location</div>
                <div style="font-size: 12px; color: #212121; margin-bottom: 20px; display: flex; align-items: center; gap: 6px;">
                    <i class="bi bi-geo-alt"></i> Add Shipping Address
                </div>

                <h3 class="summary-title">Order Summary</h3>
                <div class="summary-row">
                    <span>Subtotal (@Model.Cart.Items.Sum(i => i.Quantity) items)</span>
                    <span>৳ @Model.Subtotal.ToString("N0")</span>
                </div>
                <div class="summary-row">
                    <span>Shipping Fee</span>
                    <span>৳ 60</span>
                </div>

                <div class="coupon-input-group">
                    <input type="text" class="coupon-input" placeholder="Enter Voucher Code">
                    <button class="coupon-btn">APPLY</button>
                </div>

                <div class="summary-row total">
                    <span>Total</span>
                    <span class="total-amount">৳ @((Model.Subtotal + 60).ToString("N0"))</span>
                </div>

                <button onclick="window.location.href='/checkout'" class="checkout-btn">
                    PROCEED TO CHECKOUT (@Model.Cart.Items.Sum(i => i.Quantity))
                </button>
            </div>
        </div>
    }
</div>

<script>
    function updateQty(itemId, change) {
        const form = document.getElementById('form-update-' + itemId);
        const input = form.querySelector('input[name="quantity"]');
        let val = parseInt(input.value);
        val += change;
        if (val < 1) val = 1; 
        input.value = val;
        form.submit();
    }
</script>
