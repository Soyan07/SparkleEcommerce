                            </div>
                        </div>
                    </div>
                </div>

                <!-- Banner 4: Fitness & Wellness -->
                <div class="carousel-item">
                    <div class="hero-slide" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); background-image: url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=2070&auto=format&fit=crop'); background-size: cover; background-position: center;">
                        <div class="hero-content">
                            <div class="hero-text" data-aos="zoom-in" data-aos-delay="200">
                                <span class="hero-badge"><i class="bi bi-heart-pulse-fill"></i> @(isBangla ? "ফিটনেস গোল" : "FITNESS GOALS")</span>
                                <h1 class="hero-title">@(isBangla ? "স্বাস্থ্যকর জীবনযাপন শুরু করুন" : "Start Your Fitness Journey")</h1>
                                <p class="hero-subtitle">@(isBangla ? "জিম ইকুইপমেন্ট, ইয়োগা ম্যাট ও হেলথ সাপ্লিমেন্ট" : "Gym Equipment, Yoga Mats & Health Supplements")</p>
                                <a href="/category/fitness-gym" class="btn-hero">@(isBangla ? "শপ করুন" : "Shop Fitness") <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Banner 5: Kids & Baby Products -->
                <div class="carousel-item">
                    <div class="hero-slide" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); background-image: url('https://images.unsplash.com/photo-1515488042361-ee00e0ddd4e4?q=80&w=2073&auto=format&fit=crop'); background-size: cover; background-position: center;">
                        <div class="hero-content">
                            <div class="hero-text" data-aos="fade-down" data-aos-delay="200">
                                <span class="hero-badge"><i class="bi bi-balloon-heart-fill"></i> @(isBangla ? "বাচ্চাদের জন্য" : "FOR KIDS")</span>
                                <h1 class="hero-title">@(isBangla ? "শিশুদের বিশেষ কালেকশন" : "Kids Special Collection")</h1>
                                <p class="hero-subtitle">@(isBangla ? "খেলনা, পোশাক, বই ও শিক্ষামূলক পণ্যে ৪০% ছাড়" : "Toys, Clothing, Books & Educational Products - 40% Off")</p>
                                <a href="/category/baby-kids-mom" class="btn-hero">@(isBangla ? "দেখুন" : "Explore Now") <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
</section>


<!-- Quick Category Access Grid -->
<div class="container my-5" data-aos="fade-up" data-aos-duration="400">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom" style="border-color: #e0e0e0 !important;">
        <div class="d-flex align-items-center gap-3">
            <h2 class="flash-sale-title mb-0" style="font-size: 1.25rem; font-weight: 500 !important; color: #212121;">
                @(isBangla ? "ক্যাটাগরি থেকে কিনুন" : "Shop by Category")
            </h2>
        </div>
        @if (featuredCategories.Count > 12)
        {
            <a href="javascript:void(0)" id="seeMoreBtn" class="see-more-pill text-decoration-none" onclick="toggleCategoryDisplay(event)">
                <span id="seeMoreText">@(isBangla ? "আরও দেখুন" : "See More")</span> <i class="bi bi-chevron-down" id="seeMoreIcon"></i>
            </a>
        }
    </div>

    <div class="row g-3 g-lg-4" id="categoryGrid">
        @for (int i = 0; i < featuredCategories.Count; i++)
        {
            var category = featuredCategories[i];
            var slugKey = category.Slug ?? string.Empty;
            var iconInfo = categoryIconMap.TryGetValue(slugKey, out var info)
                ? info
                : (Icon: "bi-grid-1x2", ColorClass: "text-muted");

            var displayTitle = categoryTitleMap.TryGetValue(slugKey, out var titleInfo)
                ? (isBangla ? titleInfo.Bn : titleInfo.En)
                : category.Name;

            var displayStyle = i >= 12 ? "display: none;" : "";

            <div class="col-6 col-sm-4 col-md-3 col-lg-2 category-card-item" data-index="@i" style="@displayStyle">
                <a href="/category/@category.Slug" class="category-card text-decoration-none d-block">
                    <div class="card border-0 shadow-sm h-100 text-center p-3 hover-lift">
                        <div class="category-icon mb-2 mx-auto">
                            <i class="@iconInfo.Icon fs-2 @iconInfo.ColorClass"></i>
                        </div>
                        <h6 class="mb-0 category-title">@displayTitle</h6>
                    </div>
                </a>
            </div>
        }
    </div>
    
    

</div>


@foreach (var item in Model.Sections)
{
    @if (item.SectionType == "FlashSale")
    {
        <section class="flash-sale-section py-4" id="flash-deals-@item.Id" style="@(item.BackgroundColor != null ? $"background-color: {item.BackgroundColor};" : "background-color: white;")">
            @if (!string.IsNullOrEmpty(item.BannerImageUrl))
            {
                <div style="background-image: url('@item.BannerImageUrl'); background-size: cover; background-position: center; position: absolute; inset: 0; opacity: 0.1; pointer-events: none;"></div>
            }
            <div class="container" style="position: relative; z-index: 2;">
                <!-- Section Header -->
                <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom" style="border-color: rgba(0,0,0,0.1) !important;">
                    <div class="d-flex align-items-center gap-3">
                        <h2 class="flash-sale-title mb-0" style="font-size: 1.25rem; font-weight: 500 !important; color: #212121;">@(item.DisplayTitle ?? (isBangla ? "ফ্ল্যাশ সেল" : "Flash Sale"))</h2>
                        <span class="on-sale-badge" style="background-color: #f57224; color: white; padding: 4px 12px; border-radius: 4px; font-size: 0.75rem; font-weight: 600;">@(isBangla ? "চলছে এখন" : "On Sale Now")</span>
                    </div>
                    <a href="/search" class="shop-all-btn" style="position: relative; z-index: 100; border: 1px solid #f57224; color: #f57224; background: transparent; padding: 8px 20px; border-radius: 4px; font-size: 0.85rem; font-weight: 600; text-decoration: none; transition: all 0.2s; cursor: pointer;">@(isBangla ? "সব দেখুন" : "ALL PRODUCT")</a>
                </div>
                
                <!-- Products Grid -->
                <div>
                    <div class="horizontal-scroll-container" id="flashDealsContainer" style="scroll-behavior: smooth; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none;">
                        <div class="d-flex gap-4 pb-3" style="min-width: min-content;">
                        @foreach (var product in Model.FlashDeals.Take(item.MaxProductsToDisplay > 0 ? item.MaxProductsToDisplay : 24))
                        {
                            var firstImage = product.Images.FirstOrDefault()?.Url ?? "https://via.placeholder.com/300x300";
                            var rnd = new Random(product.Id);
                            var ratingVal = (3.5 + (rnd.NextDouble() * 1.5));
                            var reviewCount = rnd.Next(10, 500);
                            var stockVal = rnd.Next(5, 50);
                            var isFree = rnd.Next(0, 2) == 0;
                            
                            <div class="flash-product-card" style="flex: 0 0 185px; max-width: 185px;">
                                <partial name="_ProductCard" model="@(new {
                                    Id = product.Id,
                                    Title = product.Title,
                                    ImageUrl = firstImage,
                                    Price = product.Price,
                                    BasePrice = product.BasePrice,
                                    DiscountPercent = product.DiscountPercent ?? 0,
                                    Stock = stockVal,
                                    Rating = ratingVal,
                                    Reviews = reviewCount,
                                    IsFreeShipping = isFree,
                                    ConfidenceScore = 0
                                })" />
                            </div>
                        }
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
    else if (item.SectionType == "TrendingProducts")
    {
        <!-- Trending Now Section -->
        <section class="trending-section py-4" style="@(item.BackgroundColor != null ? $"background-color: {item.BackgroundColor};" : "background-color: #fafafa;")">
            <div class="container">
                <!-- Section Header - Minimal -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="mb-0" style="font-size: 1.15rem; font-weight: 600; color: #333;">
                            @(item.DisplayTitle ?? (isBangla ? "ট্রেন্ডিং পণ্য" : "Trending Now"))
                        </h2>
                        <span class="d-inline-flex align-items-center gap-1 px-2 py-0 rounded" 
                              style="background: #10b981; font-size: 0.55rem; font-weight: 600; color: white;">
                            <span class="spinner-grow spinner-grow-sm" style="width: 5px; height: 5px;" role="status"></span>
                            LIVE
                        </span>
                    </div>
                    
                    <a href="/search" class="d-inline-flex align-items-center gap-1 text-decoration-none px-3 py-1" 
                       style="background: #f57224; color: white; font-size: 0.75rem; font-weight: 500; border-radius: 4px;">
                        @(isBangla ? "সব দেখুন" : "See All")
                        <i class="bi bi-arrow-right" style="font-size: 0.7rem;"></i>
                    </a>
                </div>
                
                <!-- Products Grid -->
                <div class="position-relative">
                    <!-- Scrollable Container -->
                    <div class="trending-scroll-container" id="trendingContainer-@item.Id">
                        <div class="d-flex gap-3 pb-2">
                            @for (int i = 0; i < Model.TrendingProducts.Take(item.MaxProductsToDisplay > 0 ? item.MaxProductsToDisplay : 12).Count(); i++)
                            {
                                var product = Model.TrendingProducts[i];
                                var firstImage = product.Images.FirstOrDefault()?.Url ?? "https://via.placeholder.com/300x300";
                                var stock = product.Variants.Sum(v => v.Stock);
                                
                                <div class="trending-product-card" data-product-id="@product.Id">
                                    <partial name="_ProductCard" model="@(new {
                                        Id = product.Id,
                                        Title = product.Title,
                                        ImageUrl = firstImage,
                                        Price = product.Price,
                                        BasePrice = product.BasePrice,
                                        DiscountPercent = product.DiscountPercent ?? 0,
                                        Stock = stock,
                                        Rating = product.AverageRating,
                                        Reviews = product.TotalReviews,
                                        IsFreeShipping = false,
                                        ConfidenceScore = 0
                                    })" />
                                </div>
                            }
                            
                            @if (Model.TrendingProducts.Count() > 12)
                            {
                                <div class="trending-view-all-card">
                                    <a href="/search" class="text-decoration-none d-flex flex-column align-items-center justify-content-center h-100">
                                        <div class="view-all-icon">
                                            <i class="bi bi-arrow-right"></i>
                                        </div>
                                        <span class="view-all-text">@(isBangla ? "সব দেখুন" : "View All")</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
    else if (item.SectionType == "RecommendedProducts")
    {
        <!-- Featured Products Grid -->
        <div class="container my-5" data-aos="fade-up">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom" style="border-color: #e0e0e0 !important;">
                <div class="d-flex align-items-center gap-3">
                    <h2 class="flash-sale-title mb-0" style="font-size: 1.25rem; font-weight: 500 !important; color: #212121;">@(item.DisplayTitle ?? (isBangla ? "আপনার জন্য সাজানো পণ্য" : "Recommended For You"))</h2>
                </div>
            </div>
            
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3 g-lg-4" id="featuredProductsGrid-@item.Id">
                @for (int i = 0; i < Model.FeaturedProducts.Take(item.MaxProductsToDisplay > 0 ? item.MaxProductsToDisplay : 24).Count(); i++)
                {
                    var product = Model.FeaturedProducts.ElementAt(i);
                    var firstImage = product.Images.FirstOrDefault()?.Url ?? "https://via.placeholder.com/300x300";
                    var stock = product.Variants.Sum(v => v.Stock);
                    var isHidden = i >= 15 ? "product-card-hidden" : "";
                    
                    <div class="col product-card-item @isHidden" data-index="@i">
                        <partial name="_ProductCard" model="@(new {
                            Id = product.Id,
                            Title = product.Title,
                            ImageUrl = firstImage,
                            Price = product.Price,
                            BasePrice = product.BasePrice,
                            DiscountPercent = product.DiscountPercent ?? 0,
                            Stock = stock,
                            Rating = product.AverageRating,
                            Reviews = product.TotalReviews,
                            IsFreeShipping = false,
                            ConfidenceScore = 0
                        })" />
                    </div>
                }
            </div>
            
            @if (Model.FeaturedProducts.Count() > 15)
            {
                <div class="text-center mt-4 mb-4">
                    <button class="btn btn-primary px-4 py-2 rounded-pill shadow-sm see-more-button" onclick="toggleFeaturedProducts(this)">
                        <span class="fw-semibold">@(isBangla ? "আরও প্রোডাক্ট দেখুন" : "See More Products")</span>
                        <i class="bi bi-chevron-down ms-2 fs-5"></i>
                    </button>
                </div>
            }
        </div>
    }
}

