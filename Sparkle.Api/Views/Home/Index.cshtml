        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(0.9); }
    }

    .btn-see-all {
        background: white;
        color: #10b981;
        border: 1px solid #10b981;
        padding: 10px 28px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
