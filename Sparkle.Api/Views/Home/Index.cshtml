        transition: all 0.2s ease;
        background: white;
        box-shadow: none;
        border: 1px solid #e5e5e5;
    }

    .trending-card:hover .card {
        transform: translateY(-2px);
        box-shadow: none;
        border-color: #f57224;
    }

    .trending-image-wrapper {
        position: relative;
