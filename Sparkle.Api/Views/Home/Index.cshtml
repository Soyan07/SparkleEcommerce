    /* ============================================
       TRENDING SECTION - OPTIMIZED
       ============================================ */
    
    .trending-section {
        background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
        position: relative;
        overflow: hidden;
    }

