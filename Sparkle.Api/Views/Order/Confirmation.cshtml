@model IEnumerable<Sparkle.Domain.Orders.Order>
@{
    ViewData["Title"] = "Order Confirmation";
    var langCookie = Context.Request.Cookies["sparkle-lang"] == "bn" ? "bn" : "en";
    var isBangla = langCookie == "bn";
    var firstOrder = Model.First();
}

<style>
    :root {
        --primary: #f97316;
        --slate-50: #f8fafc;
        --slate-100: #f1f5f9;
        --slate-500: #64748b;
        --slate-800: #1e293b;
        --slate-900: #0f172a;
    }

    .confirmation-container {
        font-family: 'Inter', sans-serif;
        padding: 4rem 0;
        min-height: 85vh;
        background: #fff;
    }

    /* Minimal Hero */
    .hero-section {
        text-align: center;
        margin-bottom: 4rem;
    }
    .success-icon-wrapper {
        width: 96px;
        height: 96px;
        background: #ecfdf5;
        color: #10b981;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin-bottom: 2rem;
        box-shadow: 0 0 0 10px #f0fdf4; /* Pulse effect ring */
        animation: pulse-soft 2s infinite;
    }
    @@keyframes pulse-soft {
        0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.2); }
        70% { box-shadow: 0 0 0 20px rgba(16, 185, 129, 0); }
        100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }
    
    .page-title {
        font-size: 2.25rem;
        font-weight: 800;
        color: var(--slate-900);
        letter-spacing: -0.025em;
        margin-bottom: 1rem;
    }
    .page-subtitle {
        color: var(--slate-500);
        font-size: 1.125rem;
        margin-bottom: 2rem;
        font-weight: 400;
    }

    /* Order Summary Badge */
    .order-summary-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: var(--slate-50);
        border: 1px solid var(--slate-100);
        padding: 24px;
        border-radius: 16px;
        margin-bottom: 2.5rem;
        width: 100%;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }
    .order-id-val {
        color: var(--slate-900);
        font-family: 'Monaco', monospace;
        font-weight: 600;
        margin-left: 8px;
    }

    /* Modern Card */
    .modern-card {
        background: white;
        border-radius: 20px;
        border: 1px solid var(--slate-100);
        margin-bottom: 24px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .modern-card:hover {
        border-color: #cbd5e1;
    }
    .card-body-clean {
        padding: 32px;
    }
    .section-header {
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        font-weight: 700;
        color: var(--slate-500);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Buttons */
    .btn-pill {
        padding: 12px 32px;
        border-radius: 100px;
        font-weight: 600;
        letter-spacing: 0.01em;
        transition: all 0.2s;
        border: none;
    }
    .btn-primary-pill {
        background: var(--primary);
        color: white;
        box-shadow: 0 4px 12px rgba(249, 115, 22, 0.25);
    }
    .btn-primary-pill:hover {
        background: #ea580c;
        transform: translateY(-2px);
        color: white;
        box-shadow: 0 6px 16px rgba(249, 115, 22, 0.3);
    }
    .btn-secondary-pill {
        background: white;
        border: 1px solid var(--slate-200);
        color: var(--slate-800);
    }
    .btn-secondary-pill:hover {
        border-color: var(--slate-500);
        color: var(--slate-900);
    }

    /* Info Group */
    .info-group {
        margin-bottom: 1.5rem;
    }
    .info-label {
        font-size: 0.8rem;
        color: var(--slate-500);
        margin-bottom: 4px;
        font-weight: 500;
    }
    .info-val {
        font-size: 0.95rem;
        color: var(--slate-900);
        font-weight: 500;
        line-height: 1.5;
    }

    /* Order Items */
    .order-item-grid {
        display: grid;
        gap: 1.5rem;
    }
    .item-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 1.5rem;
        align-items: center;
        padding-bottom: 1.5rem;
        border-bottom: 1px dashed var(--slate-100);
    }
    .item-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .item-img {
        width: 64px;
        height: 64px;
        border-radius: 12px;
        object-fit: cover;
        background: var(--slate-50);
    }
</style>

<div class="confirmation-container">
    <div class="container" style="max-width: 960px;">
        
        <!-- Hero -->
        <div class="hero-section">
            <div class="success-icon-wrapper">
                <i class="bi bi-check-lg"></i>
            </div>
            
            <h1 class="page-title">@(isBangla ? "অর্ডার সফল হয়েছে!" : "Order Placed Successfully")</h1>
            <p class="page-subtitle">@(isBangla ? "আমাদের সাথে কেনাকাটা করার জন্য ধন্যবাদ" : "Thank you for shopping with Sparkle.")</p>
            
            <div class="order-summary-badge">
                <!-- Product Name(s) -->
                <div class="fw-bold text-dark text-center fs-5" style="line-height: 1.3; margin-bottom: 12px;">
                    @{
                        var allItems = Model.SelectMany(o => o.OrderItems).ToList();
                        var firstItem = allItems.FirstOrDefault()?.ProductName ?? "Product";
                        var count = allItems.Count;
                    }
                    @firstItem @(count > 1 ? $" +{count - 1} others" : "")
                </div>

                <!-- Customer Info -->
                <div class="d-flex align-items-center gap-2 text-muted small" style="margin-bottom: 12px;">
                    <span><i class="bi bi-person me-1"></i> @firstOrder.ShippingFullName</span>
                    <span style="opacity: 0.3;">|</span>
                    <span><i class="bi bi-telephone me-1"></i> @firstOrder.ShippingPhone</span>
                </div>

                <!-- Order ID (Bottom) -->
                <div class="pt-3 border-top border-secondary-subtle w-100 text-center">
                    <span class="text-uppercase text-secondary" style="font-size: 0.7rem; letter-spacing: 0.05em; font-weight: 700;">Order ID:</span>
                    <span class="font-monospace fw-bold text-dark small">@string.Join(", ", Model.Select(o => "#" + o.OrderNumber))</span>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a href="/account-info/orders" class="btn btn-pill btn-primary-pill">
                    @(isBangla ? "অর্ডার দেখুন" : "View My Orders")
                </a>
                <a href="/" class="btn btn-pill btn-secondary-pill">
                    @(isBangla ? "আরও কেনাকাটা" : "Continue Shopping")
                </a>
            </div>
        </div>

        <div class="row g-5">
            <!-- Left Column: Order Summary -->
            <div class="col-lg-8">
                @foreach (var order in Model)
                {
                    <div class="modern-card">
                        <div class="card-body-clean">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-shop text-primary"></i>
                                    <span class="fw-bold text-dark">@(order.Seller?.ShopName ?? "Sparkle Shop")</span>
                                </div>
                                <a href="/orders/track/@order.Id" class="text-decoration-none text-primary fw-bold" style="font-size: 0.85rem;">
                                    Track Order <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>

                            <div class="order-item-grid">
                                @foreach (var item in order.OrderItems)
                                {
                                    <div class="item-row">
                                        <img src="@(!string.IsNullOrEmpty(item.ProductImage) ? item.ProductImage : (item.Product?.Images?.OrderBy(i => i.SortOrder).FirstOrDefault()?.Url ?? "https://placehold.co/100"))" class="item-img" />
                                        
                                        <div>
                                            <div class="fw-bold text-dark">@item.ProductName</div>
                                            <div class="text-muted small mt-1">
                                                @if(!string.IsNullOrEmpty(item.VariantName)) { <span>@item.VariantName &bull;</span> }
                                                Qty: @item.Quantity
                                            </div>
                                        </div>
                                        
                                        <div class="text-end fw-bold text-dark">
                                            ৳@item.TotalPrice.ToString("N0")
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <!-- Totals -->
                            <div class="mt-4 pt-4 border-top border-light">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Subtotal</span>
                                    <span class="fw-medium">৳@order.SubTotal.ToString("N0")</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">Shipping</span>
                                    <span class="fw-medium">৳@order.ShippingCost.ToString("N0")</span>
                                </div>
                                @if(order.DiscountAmount > 0)
                                {
                                    <div class="d-flex justify-content-between mb-2 text-success">
                                        <span class="small">Discount</span>
                                        <span class="fw-medium">-৳@order.DiscountAmount.ToString("N0")</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between mt-3 pt-3 border-top border-light">
                                    <span class="fw-bold text-dark">Total</span>
                                    <span class="fw-bold text-primary fs-5">৳@order.TotalAmount.ToString("N0")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Column: Delivery Info -->
            <div class="col-lg-4">
                <div class="modern-card h-100">
                    <div class="card-body-clean bg-light rounded-4 h-100" style="background: #f8fafc; border: none;">
                        <div class="section-header">
                            <i class="bi bi-geo-alt"></i> DELIVERY DETAILS
                        </div>
                        
                        <div class="info-group">
                            <div class="info-label">Shipping Address</div>
                            <div class="info-val">
                                @firstOrder.ShippingFullName <br>
                                <span class="text-muted" style="font-weight: 400; font-size: 0.9rem;">
                                    @firstOrder.ShippingAddressLine1
                                    @if (!string.IsNullOrEmpty(firstOrder.ShippingAddressLine2)) { <br> @firstOrder.ShippingAddressLine2 }
                                    <br>@firstOrder.ShippingCity - @firstOrder.ShippingPostalCode
                                </span>
                            </div>
                        </div>

                        <div class="info-group">
                            <div class="info-label">Contact</div>
                            <div class="info-val">
                                @firstOrder.ShippingPhone
                            </div>
                        </div>

                        <hr class="my-4" style="border-color: #e2e8f0;">

                        <div class="section-header">
                             <i class="bi bi-credit-card"></i> PAYMENT
                        </div>
                        
                        <div class="info-group">
                            <div class="info-label">Method</div>
                            <div class="info-val">@firstOrder.PaymentMethod</div>
                        </div>
                        
                        <div class="info-group mb-0">
                            <div class="info-label">Status</div>
                            <span class="badge @(firstOrder.PaymentStatus == Sparkle.Domain.Orders.PaymentStatus.Paid ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning-emphasis") rounded-pill px-3 py-2">
                                @firstOrder.PaymentStatus
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
