@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold mb-4" style="color: #2c3e50;">About Sparkle</h1>
            <p class="lead text-muted mb-4">Empowering Bangladesh with a seamless online shopping experience. We bring quality products right to your doorstep.</p>
            <p>Sparkle is more than just an ecommerce platform; we are a community-driven marketplace connecting trusted sellers with happy customers. Founded in 2024, our mission is to make online shopping in Bangladesh reliable, fast, and enjoyable.</p>
            <p>We are committed to providing:</p>
            <ul class="list-unstyled">
                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Authentic products</li>
                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Fast and secure delivery</li>
                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Excellent customer support</li>
            </ul>
        </div>
        <div class="col-lg-6 text-center">
            <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop" alt="About Us" class="img-fluid rounded-3 shadow-sm" style="max-height: 400px;">
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-4 text-center py-5 bg-light rounded-3 mb-5">
        <div class="col-md-3">
            <h2 class="fw-bold display-5 text-primary">10k+</h2>
            <p class="text-muted">Active Users</p>
        </div>
        <div class="col-md-3">
            <h2 class="fw-bold display-5 text-primary">500+</h2>
            <p class="text-muted">Verified Sellers</p>
        </div>
        <div class="col-md-3">
            <h2 class="fw-bold display-5 text-primary">50k+</h2>
            <p class="text-muted">Products</p>
        </div>
        <div class="col-md-3">
            <h2 class="fw-bold display-5 text-primary">99%</h2>
            <p class="text-muted">Customer Satisfaction</p>
        </div>
    </div>
</div>
