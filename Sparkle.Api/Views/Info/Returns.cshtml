@{
    ViewData["Title"] = "Returns & Refunds";
}

<div class="container py-5 limit-width">
    <h1 class="fw-bold mb-4">Returns & Refunds Policy</h1>

    <div class="alert alert-info border-0 shadow-sm mb-5">
        <i class="bi bi-info-circle-fill me-2"></i>
        Returns are accepted within <strong class="text-dark">7 days</strong> of delivery for most items.
    </div>

    <div class="row g-5">
        <div class="col-lg-8">
            <h4 class="fw-bold mb-3">Eligibility for Returns</h4>
            <ul class="list-group list-group-flush mb-4 shadow-sm rounded-3">
                <li class="list-group-item bg-transparent border-light py-3"><i class="bi bi-check2 text-success me-2"></i> Product is defective or damaged</li>
                <li class="list-group-item bg-transparent border-light py-3"><i class="bi bi-check2 text-success me-2"></i> Wrong item delivered</li>
                <li class="list-group-item bg-transparent border-light py-3"><i class="bi bi-check2 text-success me-2"></i> Item is different from description</li>
                <li class="list-group-item bg-transparent border-light py-3"><i class="bi bi-check2 text-success me-2"></i> Size/Fit issue (for apparel)</li>
            </ul>

            <h4 class="fw-bold mb-3">How to Return</h4>
            <div class="timeline ps-3 border-start border-2 border-primary mb-5">
                <div class="ps-4 mb-4 position-relative">
                    <span class="position-absolute top-0 start-0 translate-middle bg-primary rounded-circle" style="width: 12px; height: 12px; border: 2px solid white; margin-left: -1px;"></span>
                    <h6 class="fw-bold">1. Initiate Return</h6>
                    <p class="text-muted small">Go into My Orders, select the order, and click "Request Return".</p>
                </div>
                <div class="ps-4 mb-4 position-relative">
                    <span class="position-absolute top-0 start-0 translate-middle bg-primary rounded-circle" style="width: 12px; height: 12px; border: 2px solid white; margin-left: -1px;"></span>
                    <h6 class="fw-bold">2. Pack Item</h6>
                    <p class="text-muted small">Pack the item securely with all original tags and packaging.</p>
                </div>
                <div class="ps-4 mb-4 position-relative">
                    <span class="position-absolute top-0 start-0 translate-middle bg-primary rounded-circle" style="width: 12px; height: 12px; border: 2px solid white; margin-left: -1px;"></span>
                    <h6 class="fw-bold">3. Pickup / Drop-off</h6>
                    <p class="text-muted small">Our delivery partner will pick up the item or you can drop it off at a nearby hub.</p>
                </div>
                 <div class="ps-4 position-relative">
                    <span class="position-absolute top-0 start-0 translate-middle bg-primary rounded-circle" style="width: 12px; height: 12px; border: 2px solid white; margin-left: -1px;"></span>
                    <h6 class="fw-bold">4. Refund Processed</h6>
                    <p class="text-muted small">Once verified, your refund will be processed within 5-7 business days.</p>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
             <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Nedd Help?</h5>
                    <p class="small text-muted mb-4">If you have any questions about returns, our support team is here to help.</p>
                    <a href="/contact" class="btn btn-outline-primary w-100 rounded-pill">Contact Support</a>
                </div>
            </div>
        </div>
    </div>
</div>
