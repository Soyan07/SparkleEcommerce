@{
    ViewData["Title"] = "Shipping Information";
}

<div class="container py-5 limit-width">
    <h1 class="fw-bold mb-4">Shipping Information</h1>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center card-hover">
                <div class="card-body p-4">
                     <i class="bi bi-geo-alt fs-1 text-primary mb-3"></i>
                    <h5 class="fw-bold">Inside Dhaka</h5>
                    <h3 class="text-primary fw-bold my-3">৳ 60</h3>
                    <p class="text-muted small mb-0">Delivery within 2-3 days</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center card-hover">
                <div class="card-body p-4">
                    <i class="bi bi-map fs-1 text-primary mb-3"></i>
                    <h5 class="fw-bold">Outside Dhaka</h5>
                     <h3 class="text-primary fw-bold my-3">৳ 120</h3>
                    <p class="text-muted small mb-0">Delivery within 3-5 days</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center card-hover">
                <div class="card-body p-4">
                    <i class="bi bi-lightning-charge fs-1 text-primary mb-3"></i>
                    <h5 class="fw-bold">Express Delivery</h5>
                    <h3 class="text-primary fw-bold my-3">৳ 150</h3>
                     <p class="text-muted small mb-0">Next day delivery (Selected areas)</p>
                </div>
            </div>
        </div>
    </div>

     <div class="content-block">
        <h5>Delivery Process</h5>
        <p>Once your order is confirmed, we will dispatch it within 24 hours. You will receive an SMS and email notification with tracking details.</p>
        
        <h5>Coverage Area</h5>
        <p>We deliver to all 64 districts of Bangladesh. However, delivery time may vary depending on the location and accessibility.</p>

        <h5>Failed Delivery Attempts</h5>
        <p>Our delivery partner will make 3 attempts to deliver your package. If unsuccessful, the item will be returned to us.</p>
    </div>
</div>
