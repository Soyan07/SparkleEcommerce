@{
    ViewData["Title"] = "Help Center";
}

<div class="container py-5 limit-width">
    <div class="text-center mb-5">
        <h1 class="fw-bold mb-3">How can we help you?</h1>
        <p class="text-muted">Search our help center or browse topics below</p>
        <div class="input-group shadow-sm" style="max-width: 600px; margin: 0 auto;">
            <input type="text" class="form-control border-end-0 py-3" placeholder="Type your question...">
            <button class="btn btn-primary px-4"><i class="bi bi-search"></i> Search</button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4">
                    <div class="icon-box bg-light text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Orders & Shipping</h5>
                    <p class="card-text text-muted small">Track your order, shipping rates, and delivery times</p>
                    <a href="/shipping" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4">
                    <div class="icon-box bg-light text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-arrow-return-left fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Returns & Refunds</h5>
                    <p class="card-text text-muted small">Return policy, how to return, and refund status</p>
                    <a href="/returns" class="stretched-link"></a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4">
                    <div class="icon-box bg-light text-primary rounded-circle mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-person-gear fs-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Account Settings</h5>
                    <p class="card-text text-muted small">Manage your account, password, and preferences</p>
                    <a href="/auth/login" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pt-4 border-top">
        <h3 class="fw-bold mb-4">Frequently Asked Questions</h3>
        <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                        How do I track my order?
                    </button>
                </h2>
                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        You can track your order by visiting the <a href="/orders">My Orders</a> page. Click on "View Details" to see the realtime status of your shipment.
                    </div>
                </div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                        What payment methods do you accept?
                    </button>
                </h2>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">
                        We accept bKash, Nagad, Rocket, Visa, Mastercard, and Cash on Delivery (COD) for most locations.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
