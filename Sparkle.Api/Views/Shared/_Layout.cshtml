    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>


    
    <script>
        // Expose Authentication State
        window.isAuthenticated = '@(isAuthenticated.ToString().ToLower())';

        
        // Load cart count
        fetch('/cart/count')
            .then(res => res.json())
            .then(data => {
                document.getElementById('cartCount').textContent = data.count;
            })
            .catch(err => {});



        // Initialize SignalR connections
        const inventoryConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/inventory")
            .withAutomaticReconnect()
            .build();

        const notificationConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/notification")
            .withAutomaticReconnect()
            .build();

        // Start connections
        inventoryConnection.start().catch(err => console.error('Inventory Hub Error:', err));
        notificationConnection.start().catch(err => console.error('Notification Hub Error:', err));

        // Listen for stock updates
        inventoryConnection.on("ReceiveStockUpdate", (data) => {
            // Update UI with real-time stock changes
            const stockElement = document.querySelector(`[data-product-id="${data.productId}"] .stock-level`);
            if (stockElement) {
                stockElement.textContent = data.stockLevel;
                if (data.isLowStock) {
                    stockElement.classList.add('text-danger');
                    stockElement.textContent += ' (Low Stock!)';
                }
            }
        });

        // Listen for notifications
        notificationConnection.on("ReceiveNotification", (data) => {
            showNotification(data.title, data.message, data.type);
        });

        // Show toast notification
        function showToast(message, type = 'success', title = '') {
            const toast = document.createElement('div');
            
            // Map types to colors
            let bgColor = 'bg-dark';
            let icon = 'info-circle';
            
            if (type === 'success') {
                bgColor = 'bg-success';
                icon = 'check-circle';
            } else if (type === 'error' || type === 'danger') {
                bgColor = 'bg-danger';
                icon = 'x-circle';
            } else if (type === 'warning') {
                bgColor = 'bg-warning text-dark';
                icon = 'exclamation-triangle';
            } else if (type === 'info') {
                bgColor = 'bg-info';
                icon = 'info-circle';
            }

            // Minimal Styles
            toast.className = `position-fixed top-0 end-0 m-4 p-2 px-3 rounded-pill shadow-lg d-flex align-items-center gap-2 text-white ${bgColor}`;
            toast.style.zIndex = '12000';
            toast.style.fontSize = '13px';
            toast.style.fontWeight = '500';
            toast.style.minWidth = '200px';
            toast.style.maxWidth = '350px';
            toast.style.width = 'fit-content';
            toast.style.transform = 'translateY(0)';
            toast.style.transition = 'all 0.3s ease';
            toast.style.opacity = '0';
            toast.style.animation = 'slideInToast 0.3s forwards';

            // Add animation keyframes if not exists
            if (!document.getElementById('toast-style')) {
                const style = document.createElement('style');
                style.id = 'toast-style';
                style.innerHTML = `
                    @@keyframes slideInToast {
                        from { transform: translateY(-20px); opacity: 0; }
                        to { transform: translateY(0); opacity: 1; }
                    }
                    @@keyframes fadeOutToast {
                        from { opacity: 1; }
                        to { opacity: 0; }
                    }
                `;
                document.head.appendChild(style);
            }

            // Minimal Content Structure
            toast.innerHTML = `
                <i class="bi bi-${icon} fs-6"></i>
                <span class="text-truncate" style="max-width: 250px;">${message}</span>
            `;

            document.body.appendChild(toast);

            // Auto Remove (3 Seconds)
            setTimeout(() => {
                toast.style.animation = 'fadeOutToast 0.3s forwards';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Backward compatibility for SignalR
        function showNotification(title, message, type) {
            showToast(message, type, title);
        }

        // Update cart count from backend (Unified for Guest & Auth)
        function updateCartCount() {
            const badge = document.getElementById('cartCount');
            if (!badge) return;

            fetch('/cart/count')
                .then(response => response.ok ? response.json() : { count: 0 })
                .then(data => {
                    const count = (data && typeof data.count === 'number') ? data.count : 0;
                    badge.textContent = count > 99 ? '99+' : count;
                })
                .catch(() => {
                    badge.textContent = '0';
                });
        }
        
        updateCartCount();
        window.addEventListener('storage', updateCartCount);
    </script>

