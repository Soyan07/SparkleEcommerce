{
  "name": "SparkleEcommerce",
  "description": ".NET 8 Razor Pages E-commerce Application",
  "repo": "https://github.com/Soyan07/SparkleEcommerce",
  "logo": "https://render.com/images/render-logo.png",
  "keywords": [
    "dotnet",
    "csharp",
    "aspnet",
    "ecommerce",
    "sql-server"
  ],
  "env": [
    {
      "key": "ASPNETCORE_ENVIRONMENT",
      "description": "ASP.NET Core environment (Development/Staging/Production)",
      "value": "production"
    },
    {
      "key": "ASPNETCORE_URLS",
      "description": "URLs to listen on",
      "value": "http://+:5000"
    },
    {
      "key": "ConnectionStrings__DefaultConnection",
      "description": "Database connection string",
      "generator": "postgres"
    }
  ],
  "services": [
    {
      "key": "web",
      "name": "SparkleApi",
      "plan": "free",
      "region": "oregon",
      "runtime": "docker"
    },
    {
      "key": "db",
      "name": "SparkleDatabase",
      "plan": "free",
      "type": "postgres"
    }
  ],
  "autoDeploy": true
}
